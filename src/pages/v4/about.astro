---
import BaseHead from '../../components/BaseHead.astro';
import { SITE_TITLE } from '../../consts';
const description = 'Sobre Fábio Machado — empresário, consultor e construtor de sistemas de IA.';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={`Sobre — ${SITE_TITLE} v4`} description={description} lang="pt-BR" noindex={true} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Source+Sans+3:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root { --bg: #FAFAFA; --fg: #09090B; --muted: #3F3F46; --faint: #71717A; --line: #E4E4E7; --accent: #EC4899; }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--bg); color: var(--fg);
        font-family: 'Source Sans 3', -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: 17px; line-height: 1.55; min-height: 100vh; -webkit-font-smoothing: antialiased;
      }
      ::selection { background: var(--accent); color: #fff; }
      a { color: inherit; text-decoration: none; }

      .container { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

      header.top {
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px; align-items: center;
        padding: 28px 0 24px; border-bottom: 1px solid var(--line);
      }
      .brand { grid-column: 1 / 4; font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 0.02em; line-height: 1; }
      .brand .dot { color: var(--accent); }
      .nav { grid-column: 8 / 13; display: flex; gap: 32px; justify-content: flex-end; align-items: center; font-size: 14px; font-weight: 500; }
      .nav > a { color: var(--muted); transition: color 150ms; }
      .nav > a:hover, .nav > a.active { color: var(--fg); }
      .skin-switch { display: flex; gap: 4px; }
      .skin-switch a { padding: 4px 9px; font-size: 12px; border: 1px solid var(--line); border-radius: 999px; color: var(--muted); transition: all 150ms; }
      .skin-switch a.active { background: var(--fg); color: var(--bg); border-color: var(--fg); }
      .skin-switch a:hover { border-color: var(--fg); color: var(--fg); }

      .layout {
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
        padding: 80px 0;
      }
      .photo-col { grid-column: 1 / 5; }
      .photo {
        width: 100%; aspect-ratio: 1; object-fit: cover;
        border-radius: 24px;
      }
      .photo-meta {
        margin-top: 20px; font-size: 13px; color: var(--muted); line-height: 1.7;
      }
      .photo-meta div { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid var(--line); }
      .photo-meta .key { color: var(--faint); text-transform: uppercase; font-size: 11px; letter-spacing: 0.08em; }

      .text-col { grid-column: 6 / 12; }
      h1.title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(64px, 9vw, 112px); line-height: 0.95; letter-spacing: 0.005em;
        text-transform: uppercase; margin-bottom: 24px;
      }
      h1.title .accent { color: var(--accent); }
      .pill { display: inline-block; background: var(--fg); color: var(--bg); padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 24px; }

      .prose p { font-size: 18px; line-height: 1.75; margin-bottom: 1.4em; color: var(--fg); }
      .prose strong { font-weight: 700; }
      .prose a { color: var(--accent); border-bottom: 1px solid currentColor; transition: opacity 150ms; }
      .prose a:hover { opacity: 0.7; }

      footer.bottom {
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
        padding: 32px 0; border-top: 1px solid var(--line); font-size: 13px; color: var(--muted);
      }
      footer .left { grid-column: 1 / 7; }
      footer .right { grid-column: 7 / 13; text-align: right; }

      @media (max-width: 800px) {
        header.top { grid-template-columns: 1fr 1fr; }
        .brand, .nav { grid-column: span 1; }
        .nav { gap: 12px; flex-wrap: wrap; }
        .layout { padding: 40px 0; }
        .photo-col, .text-col { grid-column: 1 / 13; }
        .photo-col { max-width: 280px; }
        h1.title { font-size: 56px; }
        footer .left, footer .right { grid-column: 1; text-align: left; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header class="top">
        <a class="brand" href="/v4">FÁBIO MACHADO<span class="dot">.</span></a>
        <nav class="nav">
          <a href="/v4/about" class="active">sobre</a>
          <span class="skin-switch">
            <a href="/about">v1</a>
            <a href="/v2/about">v2</a>
            <a href="/v3/about">v3</a>
            <a href="/v4/about" class="active">v4</a>
          </span>
        </nav>
      </header>

      <section class="layout">
        <div class="photo-col">
          <img src="/fabio.jpg" alt="Fábio Machado" class="photo" width="400" height="400" />
          <div class="photo-meta">
            <div><span class="key">Role</span><span>Founder · Consultor</span></div>
            <div><span class="key">Stack</span><span>AI agents</span></div>
            <div><span class="key">Local</span><span>Porto Alegre, BR</span></div>
            <div><span class="key">Twitter</span><span>@machadofabio</span></div>
          </div>
        </div>
        <div class="text-col">
          <span class="pill">Empresário · Consultor</span>
          <h1 class="title">Sou o Fábio<span class="accent">.</span></h1>
          <div class="prose">
            <p>Empresário e consultor. Passo a maior parte do tempo construindo sistemas de IA. Não é ironia — é o ponto.</p>
            <p>Comecei em 1999 aos 15 anos montando computadores e criando sites. Em 2003 abri minha primeira empresa de webdesign. Vinte e poucos anos depois, passei pela gestão de marcas como Latam, Petrobras, Gerdau, XP e Vivo via Pcom Marketing Estratégico — onde aprendi o que funciona quando o cliente é grande e a margem pra erro é pequena.</p>
            <p>Em 2012 abri a <strong>Lov Pizza</strong>. Em 2015 comprei a M&E Pizza, hoje <strong>Dáme Pizza</strong>. Cheguei a operar 6 marcas simultâneas — o melhor stress test que eu poderia ter pedido: operação real, margem apertada, time reduzido, decisão todo dia.</p>
            <p>Foi com elas que entendi o problema: o dono de PME não consegue contratar todos os papéis que a operação exige. Em 2022 comecei a construir a resposta com IA. Hoje minhas empresas rodam com um time de agentes cobrindo essas funções — como infraestrutura, não como experimento.</p>
            <p>Este site documenta o processo. <a href="https://x.com/machadofabio" target="_blank" rel="noopener">@machadofabio</a></p>
          </div>
        </div>
      </section>

      <footer class="bottom">
        <span class="left">© Fábio Machado</span>
        <span class="right">Skin v4 · Swiss Modernism</span>
      </footer>
    </div>
  </body>
</html>
