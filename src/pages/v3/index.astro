---
import BaseHead from '../../components/BaseHead.astro';
import { SITE_DESCRIPTION, HOME_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('labs'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={`${HOME_TITLE} — v3`} description={SITE_DESCRIPTION} lang="pt-BR" noindex={true} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Orbitron:wght@700;900&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #020617;
        --bg-2: #0F172A;
        --bg-3: #1E293B;
        --fg: #F8FAFC;
        --fg-muted: #94A3B8;
        --accent: #22C55E;
        --accent-2: #06B6D4;
        --danger: #EF4444;
        --border: #1E293B;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--bg);
        background-image:
          linear-gradient(rgba(34, 197, 94, 0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(34, 197, 94, 0.03) 1px, transparent 1px);
        background-size: 32px 32px;
        color: var(--fg);
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 15px; line-height: 1.7;
        min-height: 100vh;
      }
      ::selection { background: var(--accent); color: var(--bg); }
      a { color: inherit; text-decoration: none; }

      .container { max-width: 980px; margin: 0 auto; padding: 24px 24px 96px; }

      .terminal-bar {
        display: flex; align-items: center; gap: 8px;
        padding: 12px 16px; background: var(--bg-2);
        border: 1px solid var(--border); border-bottom: none;
        font-size: 12px; color: var(--fg-muted);
      }
      .dot { width: 11px; height: 11px; border-radius: 50%; }
      .dot.r { background: var(--danger); }
      .dot.y { background: #EAB308; }
      .dot.g { background: var(--accent); }
      .terminal-bar .path { margin-left: 12px; opacity: 0.6; }

      .terminal-body {
        background: var(--bg);
        border: 1px solid var(--border);
        padding: 32px 28px;
      }

      .top-nav {
        display: flex; align-items: center; justify-content: space-between;
        padding-bottom: 24px; margin-bottom: 40px;
        border-bottom: 1px dashed var(--border);
      }
      .brand { font-family: 'Orbitron', sans-serif; font-weight: 900; font-size: 20px; letter-spacing: 0.04em; color: var(--accent); text-shadow: 0 0 12px rgba(34, 197, 94, 0.4); }
      .nav-right { display: flex; gap: 12px; align-items: center; font-size: 12px; }
      .nav-right > a { color: var(--fg-muted); transition: color 150ms; }
      .nav-right > a:hover { color: var(--accent); }
      .skin-switch { display: flex; gap: 4px; }
      .skin-switch a { padding: 3px 7px; border: 1px solid var(--border); color: var(--fg-muted); font-size: 11px; border-radius: 3px; }
      .skin-switch a.active { background: var(--accent); color: var(--bg); border-color: var(--accent); }
      .skin-switch a:hover { color: var(--fg); }

      .prompt { color: var(--accent); font-weight: 700; }
      .cursor { display: inline-block; width: 8px; height: 16px; background: var(--accent); animation: blink 1s steps(1) infinite; vertical-align: text-bottom; margin-left: 4px; }
      @keyframes blink { 50% { opacity: 0; } }
      @media (prefers-reduced-motion: reduce) { .cursor { animation: none; } }

      .hero {
        margin-bottom: 56px;
        padding: 24px 0;
      }
      .hero-cmd { font-size: 12px; color: var(--fg-muted); margin-bottom: 16px; }
      .hero-cmd .prompt { margin-right: 8px; }
      .hero h1 {
        font-family: 'Orbitron', sans-serif;
        font-size: clamp(36px, 5.5vw, 56px); font-weight: 900;
        line-height: 1.1; letter-spacing: -0.01em; margin-bottom: 20px;
        text-shadow: 0 0 24px rgba(34, 197, 94, 0.2);
      }
      .hero h1 .accent { color: var(--accent); }
      .hero p { font-size: 15px; line-height: 1.8; color: var(--fg-muted); max-width: 640px; }
      .hero .ascii {
        font-size: 11px; line-height: 1.2; color: var(--accent); opacity: 0.4;
        margin-bottom: 24px; white-space: pre; overflow: hidden;
      }

      .stats {
        display: grid; grid-template-columns: repeat(4, 1fr);
        gap: 8px; margin-bottom: 48px;
      }
      .stat {
        padding: 14px; background: var(--bg-2);
        border: 1px solid var(--border); border-left: 3px solid var(--accent);
      }
      .stat .label { font-size: 10px; text-transform: uppercase; color: var(--fg-muted); letter-spacing: 0.1em; margin-bottom: 4px; }
      .stat .value { font-family: 'Orbitron', sans-serif; font-size: 22px; font-weight: 900; color: var(--accent); }

      .section-label {
        font-size: 12px; color: var(--fg-muted); margin-bottom: 14px;
        display: flex; align-items: center; gap: 8px;
      }
      .section-label::before { content: '>'; color: var(--accent); }

      .post-list {
        border: 1px solid var(--border);
        background: var(--bg-2);
      }
      .post-row {
        display: grid; grid-template-columns: 90px 100px 1fr auto;
        gap: 16px; padding: 16px 20px; align-items: center;
        border-bottom: 1px solid var(--border);
        transition: background 150ms, padding-left 150ms;
      }
      .post-row:last-child { border-bottom: none; }
      .post-row:hover { background: rgba(34, 197, 94, 0.06); padding-left: 28px; border-left: 3px solid var(--accent); padding-right: 17px; }
      .post-num { font-size: 11px; color: var(--accent); font-weight: 700; }
      .post-date { font-size: 11px; color: var(--fg-muted); font-variant-numeric: tabular-nums; }
      .post-title { font-size: 15px; color: var(--fg); line-height: 1.4; font-weight: 500; }
      .arrow { color: var(--accent); font-size: 14px; }

      .end {
        margin-top: 56px; padding-top: 24px; border-top: 1px dashed var(--border);
        font-size: 12px; color: var(--fg-muted); display: flex; justify-content: space-between;
      }
      .end .status { color: var(--accent); }

      @media (max-width: 720px) {
        .terminal-body { padding: 20px 16px; }
        .hero h1 { font-size: 32px; }
        .stats { grid-template-columns: repeat(2, 1fr); }
        .post-row { grid-template-columns: 80px 1fr auto; gap: 10px; padding: 14px 16px; }
        .post-num { display: none; }
        .nav-right { gap: 8px; font-size: 11px; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="terminal-bar">
        <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
        <span class="path">~/machado-labs</span>
      </div>

      <div class="terminal-body">
        <header class="top-nav">
          <a href="/v3" class="brand">[ FM://LABS ]</a>
          <div class="nav-right">
            <a href="/v3/about">~/about</a>
            <span class="skin-switch">
              <a href="/">v1</a>
              <a href="/v2">v2</a>
              <a href="/v3" class="active">v3</a>
              <a href="/v4">v4</a>
              <a href="/v5">v5</a>
            </span>
          </div>
        </header>

        <section class="hero">
          <div class="hero-cmd"><span class="prompt">$</span>whoami<span class="cursor"></span></div>
          <h1>Construindo <span class="accent">agentes de IA</span> que operam negócio em produção.</h1>
          <p>// Documentação aberta de quem usa IA como infraestrutura, não como experimento. Cada decisão registrada com contexto, resultado e erro junto.</p>
        </section>

        <div class="stats">
          <div class="stat"><div class="label">posts</div><div class="value">{posts.length}</div></div>
          <div class="stat"><div class="label">empresas</div><div class="value">2</div></div>
          <div class="stat"><div class="label">anos</div><div class="value">25+</div></div>
          <div class="stat"><div class="label">status</div><div class="value">online</div></div>
        </div>

        <div class="section-label">ls -lh /posts</div>
        <div class="post-list">
          {posts.map((post, i) => {
            const d = new Date(post.data.pubDate);
            const ymd = `${d.getFullYear()}.${String(d.getMonth()+1).padStart(2,'0')}.${String(d.getDate()).padStart(2,'0')}`;
            return (
              <a class="post-row" href={`/v3/labs/${post.id}`}>
                <span class="post-num">[{String(posts.length - i).padStart(3, '0')}]</span>
                <span class="post-date">{ymd}</span>
                <span class="post-title">{post.data.title}</span>
                <span class="arrow">→</span>
              </a>
            );
          })}
        </div>

        <div class="end">
          <span><span class="prompt">$</span> _<span class="cursor"></span></span>
          <span class="status">// SKIN V3 / TERMINAL</span>
        </div>
      </div>
    </div>
  </body>
</html>
