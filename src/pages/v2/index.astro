---
import BaseHead from '../../components/BaseHead.astro';
import { SITE_DESCRIPTION, HOME_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('labs'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={`${HOME_TITLE} — v2`} description={SITE_DESCRIPTION} lang="pt-BR" noindex={true} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #FAFAFA;
        --fg: #09090B;
        --muted: #3F3F46;
        --acid: #DFE104;
        --line: 2px solid #09090B;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--bg); color: var(--fg);
        font-family: 'Space Mono', ui-monospace, monospace;
        font-size: 16px; line-height: 1.55;
      }
      ::selection { background: var(--acid); }
      a { color: inherit; text-decoration: none; }

      .marquee { border-bottom: var(--line); background: var(--fg); color: var(--bg); overflow: hidden; white-space: nowrap; }
      .marquee-track {
        display: inline-block; padding: 10px 0; animation: scroll 22s linear infinite;
        font-weight: 700; font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase;
      }
      .marquee-track span { padding: 0 28px; }
      @keyframes scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
      @media (prefers-reduced-motion: reduce) { .marquee-track { animation: none; } }

      .container { max-width: 1200px; margin: 0 auto; padding: 0 24px 96px; }

      header.top {
        display: flex; align-items: center; justify-content: space-between;
        padding: 20px 0; border-bottom: var(--line); margin-bottom: 0;
      }
      .brand { font-weight: 700; font-size: 20px; text-transform: uppercase; letter-spacing: -0.02em; }
      .brand a:hover { background: var(--acid); }
      nav.top-nav { display: flex; gap: 14px; font-size: 12px; text-transform: uppercase; font-weight: 700; align-items: center; }
      nav.top-nav > a { padding: 6px 10px; border: var(--line); transition: background 100ms, color 100ms; }
      nav.top-nav > a:hover { background: var(--fg); color: var(--bg); }
      .skin-switch { display: flex; gap: 6px; font-size: 11px; }
      .skin-switch a { padding: 4px 8px; border: 1px solid var(--fg); }
      .skin-switch a.active { background: var(--fg); color: var(--bg); }

      .hero {
        padding: 80px 0 64px; border-bottom: var(--line);
      }
      .hero h1 {
        font-size: clamp(56px, 12vw, 156px);
        font-weight: 700;
        line-height: 0.9;
        letter-spacing: -0.05em;
        text-transform: uppercase;
        margin-bottom: 32px;
      }
      .hero h1 .highlight { background: var(--acid); padding: 0 8px; display: inline-block; }
      .hero p {
        font-size: 18px; max-width: 640px; line-height: 1.6;
        font-weight: 400;
      }
      .hero .tag {
        display: inline-block; padding: 6px 12px; background: var(--fg); color: var(--bg);
        font-size: 11px; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.1em; margin-bottom: 32px;
      }

      .section-title {
        font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em;
        padding: 24px 0 16px; border-bottom: var(--line); margin: 0 0 0 0;
        display: flex; justify-content: space-between; align-items: baseline;
      }
      .section-title .count { font-size: 11px; opacity: 0.6; }

      .post-list { border-bottom: var(--line); }
      .post-row {
        display: grid;
        grid-template-columns: 110px 1fr auto;
        gap: 24px;
        padding: 20px 0;
        border-bottom: var(--line);
        align-items: center;
        transition: background 100ms, padding-left 100ms;
      }
      .post-row:last-child { border-bottom: none; }
      .post-row:hover { background: var(--fg); color: var(--bg); padding-left: 16px; }
      .post-row:hover .arrow { transform: translateX(8px); }
      .post-date { font-size: 12px; font-weight: 700; text-transform: uppercase; font-variant-numeric: tabular-nums; }
      .post-title { font-size: 22px; font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; text-transform: uppercase; }
      .arrow { font-size: 24px; transition: transform 150ms; }

      footer.bottom {
        margin-top: 96px; padding-top: 32px; border-top: var(--line);
        font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em;
        font-weight: 700; display: flex; justify-content: space-between;
      }

      @media (max-width: 720px) {
        .hero h1 { font-size: 56px; }
        .post-row { grid-template-columns: 80px 1fr auto; gap: 12px; }
        .post-title { font-size: 16px; }
        nav.top-nav { gap: 8px; font-size: 10px; }
        nav.top-nav > a { padding: 5px 7px; }
      }
    </style>
  </head>
  <body>
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        <span>MACHADO LABS</span><span>★</span><span>FASE 1 — OBSERVAR</span><span>★</span><span>FASE 2 — RESPONDER</span><span>★</span><span>AGENTES DE IA</span><span>★</span><span>AUTOMAÇÃO</span><span>★</span>
        <span>MACHADO LABS</span><span>★</span><span>FASE 1 — OBSERVAR</span><span>★</span><span>FASE 2 — RESPONDER</span><span>★</span><span>AGENTES DE IA</span><span>★</span><span>AUTOMAÇÃO</span><span>★</span>
      </div>
    </div>

    <div class="container">
      <header class="top">
        <div class="brand"><a href="/v2">FÁBIO//MACHADO</a></div>
        <nav class="top-nav">
          <a href="/v2/about">SOBRE</a>
          <span class="skin-switch">
            <a href="/">v1</a>
            <a href="/v2" class="active">v2</a>
            <a href="/v3">v3</a>
            <a href="/v4">v4</a>
          </span>
        </nav>
      </header>

      <section class="hero">
        <span class="tag">EMPRESÁRIO / CONSULTOR / BUILDER</span>
        <h1>Construo<br/><span class="highlight">agentes</span> de IA<br/>que rodam<br/>negócio.</h1>
        <p>Documentação aberta de quem usa IA como infraestrutura — não como experimento. Cada decisão registrada com contexto, resultado e erro junto.</p>
      </section>

      <div class="section-title">
        <span>// LABS</span>
        <span class="count">{posts.length} POSTS</span>
      </div>

      <div class="post-list">
        {posts.map((post) => {
          const d = new Date(post.data.pubDate);
          const my = `${String(d.getMonth()+1).padStart(2,'0')}.${d.getFullYear()}`;
          return (
            <a class="post-row" href={`/v2/labs/${post.id}`}>
              <span class="post-date">{my}</span>
              <span class="post-title">{post.data.title}</span>
              <span class="arrow">→</span>
            </a>
          );
        })}
      </div>

      <footer class="bottom">
        <span>© FÁBIO MACHADO</span>
        <span>SKIN V2 / KINETIC BRUTALISM</span>
      </footer>
    </div>
  </body>
</html>
