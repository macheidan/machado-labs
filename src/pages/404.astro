---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('labs'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead
      title={`Página não encontrada — ${SITE_TITLE}`}
      description="Essa página não existe ou foi movida. Volte para a home ou veja os posts mais recentes."
      lang="pt-BR"
      noindex
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #1c1c1c;
        --fg: #ededed;
        --fg-muted: #a1a1a1;
        --fg-faint: #6e6e6e;
        --max-width: 640px;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html {
        -webkit-text-size-adjust: 100%;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      body {
        background: var(--bg);
        color: var(--fg);
        font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-feature-settings: 'ss01', 'cv11';
        font-size: 16px;
        line-height: 1.5;
        min-height: 100vh;
        letter-spacing: -0.01em;
      }

      a { color: inherit; text-decoration: none; }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 32px 24px 64px;
      }

      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding-top: 16px;
        padding-bottom: 80px;
      }

      .site-name {
        font-size: 17px;
        font-weight: 700;
        color: var(--fg);
        letter-spacing: -0.02em;
        line-height: 1;
      }

      nav {
        display: flex;
        align-items: center;
        gap: 28px;
        font-size: 15px;
      }
      nav a { color: var(--fg); line-height: 1; transition: opacity 0.15s ease; }
      nav a:hover { opacity: 0.65; }

      .lang { display: inline-flex; align-items: center; gap: 6px; font-size: 15px; line-height: 1; }
      .lang a { color: var(--fg-muted); }
      .lang a.active { color: var(--fg); }
      .lang .pipe { color: var(--fg-faint); }

      .code {
        font-family: 'Geist Mono', monospace;
        font-size: 12px;
        color: var(--fg-faint);
        margin-bottom: 12px;
      }
      .h1 {
        font-size: 28px;
        font-weight: 700;
        line-height: 1.25;
        margin-bottom: 16px;
      }
      .lede {
        color: var(--fg-muted);
        margin-bottom: 32px;
      }
      .lede a { color: var(--fg); border-bottom: 1px solid var(--fg-faint); }
      .lede a:hover { border-color: var(--fg); }

      .section-label {
        font-family: 'Geist Mono', monospace;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--fg-faint);
        margin-bottom: 12px;
      }

      .posts { display: flex; flex-direction: column; }
      .post {
        display: flex;
        align-items: baseline;
        padding: 6px 0;
        transition: opacity 0.15s ease;
      }
      .post:hover { opacity: 0.6; }
      .post-date {
        flex: 0 0 52px;
        color: #737373;
        font-family: 'Geist Mono', monospace;
        font-size: 12px;
        font-variant-numeric: tabular-nums;
        line-height: 1.6;
      }
      .post-title {
        flex: 1 1 auto;
        color: var(--fg);
        font-size: 14px;
        font-weight: 400;
        line-height: 1.6;
      }

      @media (max-width: 480px) {
        header { padding-bottom: 56px; }
        .h1 { font-size: 22px; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <a href="/" class="site-name">Fábio Machado</a>
        <nav>
          <a href="/about">sobre</a>
          <span class="lang">
            <a href="/en">en</a>
            <span class="pipe">|</span>
            <a href="/" class="active">ptbr</a>
          </span>
        </nav>
      </header>

      <p class="code">404 · página não encontrada</p>
      <h1 class="h1">Esse caminho não leva a lugar nenhum.</h1>
      <p class="lede">
        A página pode ter sido movida ou nunca ter existido. Volta pra <a href="/">home</a>,
        lê <a href="/about">sobre</a>, ou pega um dos posts abaixo.
      </p>

      <p class="section-label">posts recentes</p>
      <div class="posts">
        {posts.map((post) => {
          const d = new Date(post.data.pubDate);
          const date = `${String(d.getFullYear()).slice(2)}.${String(d.getMonth() + 1).padStart(2, '0')}`;
          return (
            <a class="post" href={`/labs/${post.id}`}>
              <span class="post-date">{date}</span>
              <span class="post-title">{post.data.title}</span>
            </a>
          );
        })}
      </div>
    </div>
  </body>
</html>
