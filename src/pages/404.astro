---
import Shell from '../components/Shell.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('labs'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<Shell
  title={`Página não encontrada — ${SITE_TITLE}`}
  description="Essa página não existe ou foi movida. Volte para a home ou veja os posts mais recentes."
  lang="pt-BR"
  noindex
>
  <section class="nf-page">
    <div class="nf-hero">
      <span class="kicker">404</span>
      <h1>esse caminho não <em>existe</em>.</h1>
      <p class="sub">A página foi movida ou nunca esteve aqui. <a href="/">volta pra home</a> ou pega um dos posts abaixo.</p>
    </div>

    <div class="posts">
      {posts.map((post) => {
        const d = new Date(post.data.pubDate);
        const mmyy = `${String(d.getMonth()+1).padStart(2,'0')}.${d.getFullYear()}`;
        return (
          <a class="row" href={`/labs/${post.id}`}>
            <span class="date">{mmyy}</span>
            <span class="title">{post.data.title}</span>
            <span class="arrow">→</span>
          </a>
        );
      })}
    </div>
  </section>
</Shell>

<style>
  .nf-page {
    padding-top: calc(var(--header-offset) + 80px);
    padding-bottom: 80px;
    max-width: 880px; margin: 0 auto;
    padding-left: 28px; padding-right: 28px;
  }
  .nf-hero { margin-bottom: 48px; }
  .kicker {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px; letter-spacing: 0.2em;
    color: var(--accent);
    display: inline-block; margin-bottom: 16px;
  }
  .nf-hero h1 {
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 700; letter-spacing: -0.035em; line-height: 1;
    color: var(--fg);
    margin-bottom: 18px;
  }
  .nf-hero h1 em {
    font-style: italic; font-weight: 600;
    background: linear-gradient(120deg, var(--accent), var(--pink));
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .nf-hero .sub {
    font-size: 17px; color: var(--fg-soft);
    max-width: 60ch;
  }
  .nf-hero .sub a {
    color: var(--accent);
    border-bottom: 1px solid rgba(255,92,43,0.4);
  }

  .posts { display: flex; flex-direction: column; }
  .row {
    display: grid; grid-template-columns: 80px 1fr auto;
    gap: 18px; padding: 18px 4px; align-items: baseline;
    border-bottom: 1px solid var(--line);
    color: var(--fg-soft);
    transition: padding-left 200ms, color 200ms;
  }
  .row:hover { padding-left: 12px; color: var(--fg); }
  .row .date { font-size: 11px; color: var(--accent); letter-spacing: 0.08em; text-transform: uppercase; font-variant-numeric: tabular-nums; }
  .row .title { font-size: 17px; font-weight: 500; }
  .row .arrow { color: var(--fg-muted); transition: transform 200ms, color 200ms; }
  .row:hover .arrow { transform: translateX(6px); color: var(--accent); }

  @media (max-width: 800px) {
    .nf-page { padding-left: 16px; padding-right: 16px; padding-top: calc(var(--header-offset) + 40px); }
    .nf-hero h1 { font-size: 44px; }
    .row { grid-template-columns: 60px 1fr auto; gap: 10px; }
    .row .title { font-size: 15px; }
  }
</style>
