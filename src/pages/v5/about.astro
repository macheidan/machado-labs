---
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import { SITE_TITLE } from '../../consts';
import mountains from '../../content/imgs/montanhas.png';

const description = 'Sobre Fábio Machado — empresário, consultor e construtor de sistemas de IA.';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={`Sobre — ${SITE_TITLE} v5`} description={description} lang="pt-BR" noindex={true} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #F4ECDC; --fg: #1A1410; --muted: #5C4F42;
        --faint: #8B7B6A; --line: #D9CCB8; --accent: #C2683A; --warm: #ECB05A;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--bg); color: var(--fg);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: 17px; line-height: 1.55; min-height: 100vh; -webkit-font-smoothing: antialiased;
      }
      ::selection { background: var(--accent); color: #fff; }
      a { color: inherit; text-decoration: none; }

      .hero {
        position: relative;
        height: 60vh;
        min-height: 480px;
        overflow: hidden;
        background: linear-gradient(
          180deg,
          #6e5e7f 0%, #a88a87 14%, #c9b18d 32%, #d7b88b 46%,
          #e1ba81 58%, #e7b874 68%, #ecb05a 78%, #c28242 88%, #6b4628 100%
        );
      }
      .hero::after {
        content: ''; position: absolute; inset: 0;
        background: radial-gradient(ellipse 70% 35% at 50% 78%, rgba(255,210,140,0.55), transparent 70%);
        z-index: 1;
      }
      .hero-nav {
        position: absolute; top: 0; left: 0; right: 0; z-index: 5;
        display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
        padding: 28px 40px; color: #2c1f15;
      }
      .hero-nav .left { font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.75; }
      .hero-nav .brand { font-family: 'Fraunces', serif; font-weight: 500; font-size: 22px; letter-spacing: 0.18em; text-transform: uppercase; text-align: center; }
      .hero-nav .right { display: flex; gap: 14px; justify-content: flex-end; align-items: center; font-size: 13px; }
      .hero-nav .right a { opacity: 0.75; transition: opacity 150ms; }
      .hero-nav .right a:hover, .hero-nav .right a.active { opacity: 1; }
      .skin-switch { display: flex; gap: 4px; }
      .skin-switch a { padding: 4px 9px; font-size: 11px; border: 1px solid rgba(44,31,21,0.25); border-radius: 999px; font-weight: 500; opacity: 0.7; }
      .skin-switch a.active { background: #2c1f15; color: #f4ecdc; border-color: #2c1f15; opacity: 1; }
      .skin-switch a:hover { opacity: 1; }

      .hero-title-wrap { position: absolute; left: 0; right: 0; bottom: 38%; z-index: 2; text-align: center; padding: 0 24px; }
      .hero-title {
        font-family: 'Fraunces', serif; font-weight: 300; font-style: italic;
        font-size: clamp(60px, 13vw, 180px); line-height: 0.92;
        letter-spacing: -0.02em; color: #2a1a0e;
      }
      .hero-title .accent { font-style: normal; font-weight: 500; color: #6b3d20; }
      .hero-mountains { position: absolute; left: 0; right: 0; bottom: 0; width: 100%; z-index: 3; line-height: 0; pointer-events: none; }
      .hero-mountains img { width: 100%; height: auto; display: block; }

      .container { max-width: 1100px; margin: 0 auto; padding: 0 32px; }

      .layout {
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 32px;
        padding: 80px 0;
      }
      .photo-col { grid-column: 1 / 5; }
      .photo {
        width: 100%; aspect-ratio: 1; object-fit: cover;
        border-radius: 24px;
        border: 1px solid var(--line);
      }
      .photo-meta { margin-top: 20px; font-size: 13px; color: var(--muted); line-height: 1.7; }
      .photo-meta div { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--line); }
      .photo-meta .key { color: var(--faint); text-transform: uppercase; font-size: 11px; letter-spacing: 0.1em; }

      .text-col { grid-column: 6 / 13; }
      .pill {
        display: inline-flex; align-items: center; gap: 10px;
        font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
        color: var(--muted); font-weight: 600; margin-bottom: 18px;
      }
      .pill::before { content: ''; width: 28px; height: 1px; background: var(--accent); }
      h1.title {
        font-family: 'Fraunces', serif; font-weight: 400;
        font-size: clamp(48px, 7vw, 88px); line-height: 1; letter-spacing: -0.015em;
        margin-bottom: 28px;
      }
      h1.title em { font-style: italic; color: var(--accent); }

      .prose p { font-size: 18px; line-height: 1.75; margin-bottom: 1.4em; color: var(--fg); }
      .prose strong { font-weight: 600; }
      .prose a { color: var(--accent); border-bottom: 1px solid currentColor; transition: opacity 150ms; }
      .prose a:hover { opacity: 0.7; }

      footer.site {
        padding: 32px 0; border-top: 1px solid var(--line);
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
        font-size: 13px; color: var(--muted);
      }
      footer .left { grid-column: 1 / 7; }
      footer .right { grid-column: 7 / 13; text-align: right; }

      @media (max-width: 800px) {
        .hero-nav { grid-template-columns: 1fr; gap: 8px; padding: 20px 24px; text-align: center; }
        .hero-nav .left, .hero-nav .right { justify-content: center; display: flex; }
        .hero-title { font-size: 16vw; }
        .layout { padding: 48px 0; }
        .photo-col, .text-col { grid-column: 1 / 13; }
        .photo-col { max-width: 280px; }
        h1.title { font-size: 48px; }
        footer .left, footer .right { grid-column: 1 / 13; text-align: left; }
      }
    </style>
  </head>
  <body>
    <section class="hero">
      <nav class="hero-nav">
        <span class="left">Macheidan Labs · sobre</span>
        <a href="/v5" class="brand">Fábio Machado</a>
        <span class="right">
          <a href="/v5/about" class="active">sobre</a>
          <span class="skin-switch">
            <a href="/about">v1</a>
            <a href="/v2/about">v2</a>
            <a href="/v3/about">v3</a>
            <a href="/v4/about">v4</a>
            <a href="/v5/about" class="active">v5</a>
          </span>
        </span>
      </nav>
      <div class="hero-title-wrap">
        <h1 class="hero-title">sou o <em>Fábio</em></h1>
      </div>
      <div class="hero-mountains">
        <Image src={mountains} alt="" width={2752} height={898} loading="eager" />
      </div>
    </section>

    <main class="container">
      <section class="layout">
        <div class="photo-col">
          <img src="/fabio.jpg" alt="Fábio Machado" class="photo" width="400" height="400" />
          <div class="photo-meta">
            <div><span class="key">Role</span><span>Founder · Consultor</span></div>
            <div><span class="key">Stack</span><span>AI agents</span></div>
            <div><span class="key">Local</span><span>Porto Alegre, BR</span></div>
            <div><span class="key">Twitter</span><span>@machadofabio</span></div>
          </div>
        </div>
        <div class="text-col">
          <span class="pill">Empresário · Consultor</span>
          <h1 class="title">Construindo um <em>cortex digital</em>.</h1>
          <div class="prose">
            <p>Empresário e consultor. Passo a maior parte do tempo construindo sistemas de IA. Não é ironia — é o ponto.</p>
            <p>Comecei em 1999 aos 15 anos montando computadores e criando sites. Em 2003 abri minha primeira empresa de webdesign. Vinte e poucos anos depois, passei pela gestão de marcas como Latam, Petrobras, Gerdau, XP e Vivo via Pcom Marketing Estratégico, onde aprendi o que funciona quando o cliente é grande e a margem pra erro é pequena.</p>
            <p>Em 2012 abri a <strong>Lov Pizza</strong>. Em 2015 comprei a M&E Pizza, hoje <strong>Dáme Pizza</strong>. Cheguei a operar 6 marcas simultâneas, o melhor stress test que eu poderia ter pedido: operação real, margem apertada, time reduzido, decisão todo dia.</p>
            <p>Foi com elas que entendi o problema: o dono de PME não consegue contratar todos os papéis que a operação exige. Em 2022 comecei a construir a resposta com IA. Hoje minhas empresas rodam com um time de agentes cobrindo essas funções, como infraestrutura, não como experimento.</p>
            <p>Este site documenta o processo. <a href="https://x.com/machadofabio" target="_blank" rel="noopener">@machadofabio</a></p>
          </div>
        </div>
      </section>

      <footer class="site">
        <span class="left">© Fábio Machado · Porto Alegre</span>
        <span class="right">Skin v5 · Dawn Ridge</span>
      </footer>
    </main>
  </body>
</html>
