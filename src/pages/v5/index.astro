---
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import { SITE_DESCRIPTION, HOME_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import mountains from '../../content/imgs/montanhas.png';

const posts = (await getCollection('labs'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = posts[0];
const rest = posts.slice(1);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={`${HOME_TITLE} — v5`} description={SITE_DESCRIPTION} lang="pt-BR" noindex={true} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #F4ECDC; --fg: #1A1410; --muted: #5C4F42;
        --faint: #8B7B6A; --line: #D9CCB8; --accent: #C2683A; --warm: #ECB05A;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { background: var(--bg); }
      body {
        color: var(--fg);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: 17px; line-height: 1.55;
        -webkit-font-smoothing: antialiased;
      }
      ::selection { background: var(--accent); color: #fff; }
      a { color: inherit; text-decoration: none; }

      /* DAWN — sky gradient over the whole section, mountains sticky at bottom */
      .dawn {
        position: relative;
        background: linear-gradient(
          180deg,
          #6e5e7f 0%,
          #a88a87 7%,
          #c9b18d 16%,
          #d7b88b 26%,
          #e1ba81 36%,
          #e7b874 46%,
          #ecb05a 58%,
          #c28242 72%,
          #6b4628 100%
        );
      }

      .dawn-nav {
        position: relative; z-index: 5;
        display: grid; grid-template-columns: 1fr auto 1fr;
        align-items: center;
        padding: 28px 40px;
        color: #2c1f15;
      }
      .dawn-nav .left { font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.75; }
      .dawn-nav .brand {
        font-family: 'Fraunces', serif; font-weight: 500;
        font-size: 22px; letter-spacing: 0.18em; text-transform: uppercase;
        text-align: center;
      }
      .dawn-nav .right { display: flex; gap: 12px; justify-content: flex-end; align-items: center; font-size: 13px; }
      .dawn-nav .right > a { opacity: 0.75; transition: opacity 150ms; }
      .dawn-nav .right > a:hover, .dawn-nav .right > a.active { opacity: 1; }
      .dawn-nav .right .sep { opacity: 0.35; user-select: none; }
      .x-icon { display: inline-flex; align-items: center; opacity: 0.75; transition: opacity 150ms; }
      .x-icon:hover { opacity: 1; }
      .x-icon svg { width: 14px; height: 14px; fill: currentColor; display: block; }
      .dawn-nav .brand { will-change: transform; }

      /* HERO INTRO — 3 rows: 15% top / text / 30% bottom */
      .dawn-hero {
        position: relative; z-index: 1;
        display: grid;
        grid-template-rows: 15fr 55fr 30fr;
        min-height: calc(100vh - 80px);
        max-width: 1280px;
        margin: 0 auto;
      }
      .dawn-hero .copy {
        grid-row: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 28px;
        padding: 0 24px;
        --scrollPara: 0px;
        transform: translate3d(0, calc(-10% + var(--scrollPara)), 0);
        will-change: transform;
      }
      .dawn-hero h1 a, .dawn-hero p.sub a {
        color: inherit; text-decoration: none;
        transition: opacity 200ms;
      }
      .dawn-hero h1 a:hover, .dawn-hero p.sub a:hover { opacity: 0.82; }
      .dawn-hero h1 {
        font-family: 'Fraunces', serif;
        font-weight: 300; font-style: italic;
        font-size: clamp(64px, 12vw, 154px);
        line-height: 0.95; letter-spacing: -0.02em;
        color: #2a1a0e;
        text-wrap: balance;
      }
      .dawn-hero h1 :global(em) {
        font-style: italic;
        font-weight: 500;
        color: #6b3d20;
        font-size: 1.1em;
      }
      .dawn-hero h1 :global(.accent) {
        font-style: normal;
        font-weight: 600;
        color: #c2683a;
        font-size: 1.05em;
        letter-spacing: -0.025em;
      }
      .dawn-hero p.sub {
        margin: 0; font-size: 13px;
        letter-spacing: 0.18em; text-transform: uppercase;
        color: #2c1f15; opacity: 0.8;
      }
      .scroll-cue {
        position: relative;
        width: 1px;
        height: 48px;
        background: rgba(44, 31, 21, 0.18);
        margin-top: 4px;
      }
      .scroll-cue::after {
        content: '';
        position: absolute;
        top: 0;
        left: -2px;
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: #2c1f15;
        animation: scrollDot 2.2s cubic-bezier(.45, 0, .55, 1) infinite;
      }
      @keyframes scrollDot {
        0%   { transform: translateY(-10px); opacity: 0; }
        18%  { transform: translateY(0); opacity: 1; }
        82%  { transform: translateY(43px); opacity: 1; }
        100% { transform: translateY(56px); opacity: 0; }
      }
      @media (prefers-reduced-motion: reduce) {
        .scroll-cue::after { animation: none; opacity: 0.6; }
      }

      /* POSTS BLOCK */
      .dawn-posts {
        position: relative; z-index: 1;
        max-width: 1180px; margin: 0 auto;
        padding: 0 32px;
      }

      .section-intro {
        padding: 28px 0 32px;
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
      }
      .section-intro .pill {
        grid-column: 1 / 13;
        display: inline-flex; align-items: center; gap: 10px;
        font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
        color: #2c1f15; opacity: 0.85;
      }
      .section-intro .pill::before { content: ''; width: 28px; height: 1px; background: #2c1f15; opacity: 0.6; }
      .section-intro h2 {
        grid-column: 1 / 13;
        font-family: 'Fraunces', serif; font-weight: 400;
        font-size: clamp(32px, 4.5vw, 56px); line-height: 1.1;
        letter-spacing: -0.015em;
        color: #1a1410;
        margin-top: 18px;
      }
      .section-intro h2 em { font-style: italic; font-weight: 500; color: #6b3d20; }
      .section-intro h2 .accent { font-style: normal; font-weight: 600; color: #c2683a; letter-spacing: -0.02em; }
      .section-intro h2 .sub { font-size: 0.72em; color: #2c1f15; opacity: 0.82; display: inline-block; margin-top: 6px; }

      .featured {
        padding: 32px 0 56px;
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
      }
      .featured a.card {
        grid-column: 1 / 8;
        display: block;
        background: rgba(244,236,220,0.92);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(217, 204, 184, 0.6);
        border-radius: 24px;
        padding: 36px;
        transition: transform 250ms ease, border-color 200ms;
      }
      .featured a.card:hover { transform: translateY(-3px); border-color: var(--accent); }
      .featured .label { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); font-weight: 600; }
      .featured h3 {
        font-family: 'Fraunces', serif; font-weight: 400;
        font-size: clamp(26px, 3.2vw, 40px); line-height: 1.1;
        letter-spacing: -0.01em;
        margin: 12px 0 14px;
        color: var(--fg);
      }
      .featured p { font-size: 16px; color: var(--muted); line-height: 1.6; }
      .featured .meta { font-size: 12px; color: var(--faint); margin-top: 22px; font-variant-numeric: tabular-nums; }

      .stats { grid-column: 8 / 13; display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
      .stat {
        background: rgba(244,236,220,0.92);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(217, 204, 184, 0.6);
        border-radius: 18px;
        padding: 22px;
        display: flex; flex-direction: column; justify-content: space-between;
        min-height: 130px;
      }
      .stat .k { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--faint); font-weight: 600; }
      .stat .v { font-family: 'Fraunces', serif; font-size: 40px; line-height: 1; font-weight: 400; color: var(--fg); }
      .stat .d { font-size: 13px; color: var(--muted); margin-top: 4px; }
      .stat.dark { background: rgba(26,20,16,0.92); color: var(--bg); border-color: rgba(26,20,16,0.92); }
      .stat.dark .k { color: rgba(244,236,220,0.55); }
      .stat.dark .d { color: rgba(244,236,220,0.65); }
      .stat.dark .v { color: var(--bg); }
      .stat.warm { background: rgba(194,104,58,0.95); color: #fff; border-color: rgba(194,104,58,0.95); }
      .stat.warm .k { color: rgba(255,255,255,0.7); }
      .stat.warm .d { color: rgba(255,255,255,0.85); }
      .stat.warm .v { color: #fff; }

      .archive-head {
        padding: 32px 0 12px;
        border-top: 1px solid rgba(44,31,21,0.18);
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
        align-items: baseline;
      }
      .archive-head h3 {
        grid-column: 1 / 7;
        font-family: 'Fraunces', serif; font-weight: 400; font-style: italic;
        font-size: 30px; letter-spacing: -0.01em; color: #1a1410;
      }
      .archive-head .count { grid-column: 7 / 13; text-align: right; font-size: 13px; color: rgba(44,31,21,0.6); font-variant-numeric: tabular-nums; }

      .post-row {
        display: grid; grid-template-columns: 60px 110px 1fr auto;
        gap: 20px; padding: 18px 0; align-items: baseline;
        border-bottom: 1px solid rgba(44,31,21,0.15);
        transition: padding-left 250ms;
        color: var(--fg);
      }
      .post-row:hover { padding-left: 12px; }
      .post-row:hover .post-title { color: var(--accent); }
      .post-row:hover .arrow { transform: translateX(8px); color: var(--accent); }
      .post-num { font-size: 12px; color: rgba(44,31,21,0.55); font-variant-numeric: tabular-nums; }
      .post-date { font-size: 12px; color: rgba(44,31,21,0.55); font-variant-numeric: tabular-nums; }
      .post-title {
        font-family: 'Fraunces', serif; font-weight: 400;
        font-size: 21px; line-height: 1.2; letter-spacing: -0.01em;
        transition: color 200ms;
      }
      .arrow { color: rgba(44,31,21,0.5); font-size: 18px; transition: transform 250ms, color 250ms; }

      /* room below the last post so it can scroll above the mountain line */
      .dawn-tail { height: 50vh; }

      /* BOTTOM BRAND — pixel-perfect mirror, 50% size of the nav brand */
      .brand-bottom {
        position: fixed;
        left: 0; right: 0; top: 0;
        z-index: 5;
        text-align: center;
        pointer-events: none;
        user-select: none;
        font-family: 'Fraunces', serif;
        font-weight: 500;
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #ffffff;
        transform: translateY(150vh);
        will-change: transform;
      }

      /* MOUNTAINS — fixed at viewport bottom, in front of watermark */
      .mountains-fixed {
        position: fixed;
        left: 0; right: 0; bottom: 0;
        width: 100%;
        z-index: 4;
        pointer-events: none;
        line-height: 0;
      }
      .mountains-fixed img {
        width: 100%;
        height: auto;
        display: block;
      }

      @media (max-width: 800px) {
        .dawn-nav { grid-template-columns: 1fr; gap: 8px; padding: 20px 24px; text-align: center; }
        .dawn-nav .left, .dawn-nav .right { justify-content: center; display: flex; }
        .dawn-hero { min-height: calc(100vh - 130px); }
        .dawn-hero .copy { padding: 0 16px; gap: 20px; transform: translate3d(0, calc(-30px - 5% + var(--scrollPara)), 0); }
        .dawn-hero h1 { font-size: 12vw; }
        .dawn-posts { padding: 0 20px; }
        .section-intro { padding: 20px 0 24px; }
        .section-intro h2 { grid-column: 1 / 13; }
        .featured a.card, .stats { grid-column: 1 / 13; }
        .featured a.card { padding: 24px; }
        .archive-head h3 { grid-column: 1 / 8; }
        .archive-head .count { grid-column: 8 / 13; }
        .post-row { grid-template-columns: 90px 1fr auto; gap: 10px; }
        .post-num { display: none; }
        .post-title { font-size: 17px; }
      }
    </style>
  </head>
  <body>
    <section class="dawn">
      <nav class="dawn-nav">
        <span class="left">2026</span>
        <a href="/v5" class="brand">Fábio Machado</a>
        <span class="right">
          <a href="/v5/about">sobre</a>
          <span class="sep">|</span>
          <a href="/en">english</a>
          <span class="sep">|</span>
          <a class="x-icon" href="https://x.com/machadofabio" target="_blank" rel="noopener" aria-label="X (Twitter)">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </span>
      </nav>

      {featured && (
        <section class="dawn-hero">
          <div class="copy">
            {featured.data.heroTitle
              ? <h1><a href={`/v5/labs/${featured.id}`} set:html={featured.data.heroTitle} /></h1>
              : <h1><a href={`/v5/labs/${featured.id}`}>{featured.data.title}</a></h1>}
            <p class="sub"><a href={`/v5/labs/${featured.id}`}>Ler</a></p>
            <div class="scroll-cue" aria-hidden="true"></div>
          </div>
        </section>
      )}

      <div class="dawn-posts">
        <section class="section-intro">
          <span class="pill">Macheidan Labs</span>
          <h2>Como estou aplicando <em>IA</em> nos meus <span class="accent">negócios</span>. <span class="sub">projetos que já <em>estão rodando</em> e implementando.</span></h2>
        </section>

        <section class="featured">
          {featured && (
            <a class="card" href={`/v5/labs/${featured.id}`}>
              <span class="label">Último post</span>
              <h3>{featured.data.title}</h3>
              <p>{featured.data.description}</p>
              <div class="meta">
                {new Date(featured.data.pubDate).toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' })}
              </div>
            </a>
          )}
          <div class="stats">
            <div class="stat warm">
              <span class="k">Posts</span>
              <div><div class="v">{posts.length}</div><div class="d">no arquivo</div></div>
            </div>
            <div class="stat">
              <span class="k">Empresas</span>
              <div><div class="v">2</div><div class="d">Lov · Dáme</div></div>
            </div>
            <div class="stat">
              <span class="k">Anos</span>
              <div><div class="v">25+</div><div class="d">tech · gestão</div></div>
            </div>
            <div class="stat dark">
              <span class="k">Stack</span>
              <div><div class="v" style="font-size: 22px;">AI agents</div><div class="d">como infra</div></div>
            </div>
          </div>
        </section>

        <div class="archive-head">
          <h3>Arquivo completo</h3>
          <span class="count">{posts.length} posts</span>
        </div>
        <div class="posts">
          {rest.map((post, i) => {
            const d = new Date(post.data.pubDate);
            const ddmm = `${String(d.getDate()).padStart(2,'0')}.${String(d.getMonth()+1).padStart(2,'0')}.${d.getFullYear()}`;
            return (
              <a class="post-row" href={`/v5/labs/${post.id}`}>
                <span class="post-num">№ {String(rest.length - i).padStart(2, '0')}</span>
                <span class="post-date">{ddmm}</span>
                <span class="post-title">{post.data.title}</span>
                <span class="arrow">→</span>
              </a>
            );
          })}
        </div>
      </div>

      <div class="dawn-tail"></div>
    </section>

    <div class="mountains-fixed">
      <Image src={mountains} alt="" width={2752} height={898} loading="eager" />
    </div>
    <div class="brand-bottom">Fábio Machado</div>

    <script is:inline>
      (function () {
        const topBrand = document.querySelector('.dawn-nav .brand');
        const bot = document.querySelector('.brand-bottom');
        const copy = document.querySelector('.dawn-hero .copy');
        if (!topBrand || !bot) return;
        const REST = 10; /* px between bottom brand bottom and viewport bottom once fully in */
        let raf = null;
        function update() {
          /* Parallax: brand visually moves at 1/3 of scroll speed.
             Push it down by 2/3 of scrollY so the net visual motion is scrollY/3. */
          topBrand.style.transform = 'translateY(' + (window.scrollY * 2 / 3) + 'px)';

          const r = topBrand.getBoundingClientRect();
          const vh = window.innerHeight;
          const mirror = r.top + vh;
          const restCap = vh - bot.getBoundingClientRect().height - REST;
          const offset = Math.max(mirror, restCap);
          bot.style.transform = 'translateY(' + offset + 'px)';

          /* Hero copy parallax (title + sub + scroll cue): 40% slower than the page.
             Push down by 0.4 * scrollY so net upward motion is 0.6 * scrollY. */
          if (copy) {
            copy.style.setProperty('--scrollPara', (window.scrollY * 0.4) + 'px');
          }
          raf = null;
        }
        window.addEventListener('scroll', () => { if (!raf) raf = requestAnimationFrame(update); }, { passive: true });
        window.addEventListener('resize', () => { if (!raf) raf = requestAnimationFrame(update); }, { passive: true });
        update();
      })();
    </script>
  </body>
</html>
