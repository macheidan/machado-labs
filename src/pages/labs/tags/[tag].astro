---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import { SITE_TITLE } from '../../../consts';
import { tagDescription, tagLabel, type Lang } from '../../../lib/tags';
import { tagGraph } from '../../../lib/seo';

export async function getStaticPaths() {
  const posts = await getCollection('labs');
  const tagMap = new Map<string, typeof posts>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag)!.push(post);
    }
  }
  return [...tagMap.entries()].map(([tag, postsForTag]) => ({
    params: { tag },
    props: {
      tag,
      posts: postsForTag.sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
      ),
    },
  }));
}

const { tag, posts } = Astro.props;
const lang: Lang = 'pt';
const label = tagLabel(tag, lang);
const description = tagDescription(tag, lang, posts.length);
const pageTitle = `${label} — ${SITE_TITLE}`;
const altUrl = `/en/labs/tags/${tag}`;
const jsonLd = tagGraph({ lang, tag, tagLabel: label, description });
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead
      title={pageTitle}
      description={description}
      lang="pt-BR"
      alternateUrl={altUrl}
      jsonLd={jsonLd}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #1c1c1c;
        --fg: #ededed;
        --fg-muted: #a1a1a1;
        --fg-faint: #6e6e6e;
        --max-width: 640px;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 16px;
        line-height: 1.5;
        min-height: 100vh;
        letter-spacing: -0.01em;
        -webkit-font-smoothing: antialiased;
      }
      a { color: inherit; text-decoration: none; }
      .container { max-width: var(--max-width); margin: 0 auto; padding: 32px 24px 80px; }
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding-top: 16px;
        padding-bottom: 56px;
      }
      .site-name { font-size: 17px; font-weight: 700; letter-spacing: -0.02em; line-height: 1; }
      nav { display: flex; align-items: center; gap: 28px; font-size: 15px; }
      nav a { line-height: 1; transition: opacity 0.15s ease; }
      nav a:hover { opacity: 0.65; }
      .lang { display: inline-flex; align-items: center; gap: 6px; font-size: 15px; line-height: 1; }
      .lang a { color: var(--fg-muted); }
      .lang a.active { color: var(--fg); }
      .lang .pipe { color: var(--fg-faint); }
      .breadcrumb {
        font-family: 'Geist Mono', monospace;
        font-size: 11px;
        color: var(--fg-faint);
        margin-bottom: 24px;
        display: flex;
        gap: 6px;
        align-items: center;
        flex-wrap: wrap;
      }
      .breadcrumb a { color: var(--fg-muted); }
      .breadcrumb a:hover { color: var(--fg); }
      .tag-title { font-size: 24px; font-weight: 700; line-height: 2rem; margin-bottom: 4px; }
      .tag-meta {
        font-family: 'Geist Mono', monospace;
        font-size: 12px;
        color: #737373;
        margin-bottom: 40px;
      }
      .post {
        display: grid;
        grid-template-columns: 70px 1fr;
        column-gap: 14px;
        padding: 6px 0;
        align-items: baseline;
        transition: opacity 0.15s ease;
      }
      .post:hover { opacity: 0.6; }
      .post-date {
        text-align: right;
        font-family: 'Geist Mono', monospace;
        font-size: 12px;
        color: #737373;
        line-height: 1.6;
      }
      .post-title { color: var(--fg); font-size: 14px; line-height: 1.6; }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <a href="/" class="site-name">Fábio Machado</a>
        <nav>
          <a href="/about">sobre</a>
          <span class="lang">
            <a href={altUrl}>en</a>
            <span class="pipe">|</span>
            <a href={`/labs/tags/${tag}`} class="active">ptbr</a>
          </span>
        </nav>
      </header>

      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/">Labs</a>
        <span>/</span>
        <span>{label}</span>
      </nav>

      <h1 class="tag-title">#{label}</h1>
      <p class="tag-meta">{description}</p>

      <div class="posts">
        {posts.map((post) => {
          const d = new Date(post.data.pubDate);
          const dateStr = `${String(d.getFullYear()).slice(2)}.${String(d.getMonth() + 1).padStart(2, '0')}`;
          return (
            <a class="post" href={`/labs/${post.id}`}>
              <span class="post-date">{dateStr}</span>
              <span class="post-title">{post.data.title}</span>
            </a>
          );
        })}
      </div>
    </div>
  </body>
</html>
