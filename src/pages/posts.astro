---
import Shell from '../components/Shell.astro';
import { SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('labs'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Shell
  title="Arquivo completo — Fábio Machado"
  description={SITE_DESCRIPTION}
  lang="pt-BR"
  alternateUrl="/en/posts"
  active="posts"
>
  <section class="posts-page">
    <div class="heading">
      <h1>Arquivo <em>completo</em></h1>
    </div>

    <div class="posts-grid">
      {posts.map((post) => {
        const d = new Date(post.data.pubDate);
        const mmyy = `${String(d.getMonth()+1).padStart(2,'0')}.${d.getFullYear()}`;
        return (
          <a class="post-card" href={`/labs/${post.id}`}>
            <span class="date">{mmyy}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="arrow">Ler post <span aria-hidden="true">→</span></span>
          </a>
        );
      })}
    </div>
  </section>
</Shell>

<style>
  .posts-page {
    padding-top: calc(var(--header-h) + 80px);
    padding-bottom: 80px;
    max-width: 1180px; margin: 0 auto;
    padding-left: 28px; padding-right: 28px;
  }
  .heading {
    display: flex; align-items: baseline; justify-content: space-between;
    flex-wrap: wrap; gap: 12px;
    margin-bottom: 36px;
  }
  .posts-page h1 {
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 700; letter-spacing: -0.03em; line-height: 1;
    color: var(--fg);
  }
  .posts-page h1 :global(em) {
    font-style: italic; font-weight: 600;
    background: linear-gradient(120deg, var(--accent), var(--pink));
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }
  .post-card {
    display: flex; flex-direction: column; gap: 14px;
    padding: 28px;
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 20px;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    transition: border-color 180ms, transform 200ms, background 200ms;
    position: relative; overflow: hidden;
  }
  .post-card::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(600px circle at var(--mx, 50%) var(--my, 0%), rgba(255,92,43,0.08), transparent 40%);
    opacity: 0; transition: opacity 240ms;
    pointer-events: none;
  }
  .post-card:hover { border-color: var(--line-strong); transform: translateY(-2px); background: rgba(28,28,32,0.7); }
  .post-card:hover::before { opacity: 1; }
  .post-card .date {
    font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--accent); font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .post-card h3 {
    font-size: 22px; font-weight: 600;
    line-height: 1.2; letter-spacing: -0.02em;
    color: var(--fg);
  }
  .post-card p {
    font-size: 14px; line-height: 1.55;
    color: var(--fg-muted);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }
  .post-card .arrow {
    margin-top: auto; padding-top: 6px;
    font-size: 13px; color: var(--fg-soft);
    display: inline-flex; align-items: center; gap: 6px;
    transition: gap 200ms, color 200ms;
  }
  .post-card:hover .arrow { gap: 10px; color: var(--accent); }

  @media (max-width: 800px) {
    .posts-page { padding-left: 16px; padding-right: 16px; padding-top: calc(var(--header-h) + 40px); }
    .posts-page h1 { font-size: 38px; }
    .posts-grid { grid-template-columns: 1fr; gap: 14px; }
    .post-card { padding: 22px; }
    .post-card h3 { font-size: 19px; }
  }
</style>

<script is:inline>
  (function () {
    function bind() {
      document.addEventListener('mousemove', onMove, { passive: true });
    }
    function onMove(e) {
      document.querySelectorAll('.post-card').forEach((card) => {
        const rect = card.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        if (x >= -10 && x <= 110 && y >= -10 && y <= 110) {
          card.style.setProperty('--mx', x + '%');
          card.style.setProperty('--my', y + '%');
        }
      });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind);
    else bind();
  })();
</script>
