---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION, HOME_TITLE } from '../consts';
import { homeGraph } from '../lib/seo';
import { getCollection } from 'astro:content';

const posts = (await getCollection('labs'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const jsonLd = homeGraph('pt', SITE_DESCRIPTION);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead
      title={HOME_TITLE}
      description={SITE_DESCRIPTION}
      lang="pt-BR"
      alternateUrl="/en"
      jsonLd={jsonLd}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #1c1c1c;
        --fg: #ededed;
        --fg-muted: #a1a1a1;
        --fg-faint: #6e6e6e;
        --max-width: 640px;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html {
        -webkit-text-size-adjust: 100%;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      body {
        background: var(--bg);
        color: var(--fg);
        font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-feature-settings: 'ss01', 'cv11';
        font-size: 16px;
        line-height: 1.5;
        min-height: 100vh;
        letter-spacing: -0.01em;
      }

      ::selection { background: rgba(255,255,255,0.15); }

      a { color: inherit; text-decoration: none; }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 32px 24px 64px;
      }

      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding-top: 16px;
        padding-bottom: 56px;
      }

      .site-name {
        font-size: 17px;
        font-weight: 700;
        color: var(--fg);
        letter-spacing: -0.02em;
        line-height: 1;
        transition: opacity 0.15s ease;
      }
      .site-name:hover { opacity: 0.7; }

      nav {
        display: flex;
        align-items: center;
        gap: 28px;
        font-size: 15px;
      }

      nav a {
        color: var(--fg);
        line-height: 1;
        transition: opacity 0.15s ease;
      }
      nav a:hover { opacity: 0.65; }

      .lang {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 15px;
        line-height: 1;
      }
      .lang a { color: var(--fg-muted); }
      .lang a.active { color: var(--fg); }
      .lang .pipe { color: var(--fg-faint); }

      .x-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .x-link svg {
        display: block;
        width: 14px;
        height: 14px;
        fill: currentColor;
      }

      .posts {
        display: flex;
        flex-direction: column;
      }

      .post {
        display: grid;
        grid-template-columns: auto 1fr;
        column-gap: 14px;
        padding: 10px 0;
        transition: opacity 0.15s ease;
      }
      .post:hover { opacity: 0.6; }

      .post-date {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        font-family: 'Geist Mono', monospace;
        font-size: 12px;
        font-variant-numeric: tabular-nums;
        color: #737373;
        line-height: 1.5;
        min-width: 44px;
      }

      .post-title {
        align-self: end;
        color: var(--fg);
        font-size: 14px;
        font-weight: 400;
        line-height: 1.6;
      }

      @media (max-width: 480px) {
        header { padding-bottom: 40px; }
        nav { gap: 18px; font-size: 14px; }
        .lang { font-size: 14px; }
      }
    </style>
  </head>
  <body>
    <div class="container">

      <header>
        <a href="/" class="site-name">Fábio Machado</a>
        <nav>
          <a href="/about">sobre</a>
          <span class="lang">
            <a href="/en">en</a>
            <span class="pipe">|</span>
            <a href="/" class="active">ptbr</a>
          </span>
          <a href="https://x.com/machadofabio" class="x-link" target="_blank" rel="noopener" aria-label="X">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
            </svg>
          </a>
        </nav>
      </header>

      <div class="posts">
        {posts.map((post) => {
          const d = new Date(post.data.pubDate);
          const year = String(d.getFullYear());
          const month = String(d.getMonth() + 1).padStart(2, '0');
          return (
            <a class="post" href={`/labs/${post.id}`}>
              <span class="post-date">
                <span>{year}</span>
                <span>{month}</span>
              </span>
              <span class="post-title">{post.data.title}</span>
            </a>
          );
        })}
      </div>

    </div>
  </body>
</html>
