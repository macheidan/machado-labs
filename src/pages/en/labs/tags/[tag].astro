---
import { getCollection } from 'astro:content';
import Shell from '../../../../components/Shell.astro';
import { SITE_TITLE } from '../../../../consts';
import { tagDescription, tagLabel, type Lang } from '../../../../lib/tags';
import { tagGraph } from '../../../../lib/seo';

export async function getStaticPaths() {
  const posts = await getCollection('labs-en');
  const tagMap = new Map<string, typeof posts>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag)!.push(post);
    }
  }
  return [...tagMap.entries()].map(([tag, postsForTag]) => ({
    params: { tag },
    props: {
      tag,
      posts: postsForTag.sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
      ),
    },
  }));
}

const { tag, posts } = Astro.props;
const lang: Lang = 'en';
const label = tagLabel(tag, lang);
const description = tagDescription(tag, lang, posts.length);
const pageTitle = `#${label} — ${SITE_TITLE}`;
const altUrl = `/labs/tags/${tag}`;
const jsonLd = tagGraph({ lang, tag, tagLabel: label, description });
---

<Shell
  title={pageTitle}
  description={description}
  lang="en"
  alternateUrl={altUrl}
  jsonLd={jsonLd}
>
  <section class="tag-hero">
    <div class="copy">
      <span class="kicker">tag</span>
      <h1>#<em>{label}</em></h1>
      <p class="sub">{description}</p>
    </div>
  </section>

  <div class="tag-posts">
    <div class="archive-head">
      <h3>Posts</h3>
      <span class="count">{posts.length}</span>
    </div>
    <div class="posts">
      {posts.map((post, i) => {
        const d = new Date(post.data.pubDate);
        const ddmm = `${String(d.getDate()).padStart(2,'0')}.${String(d.getMonth()+1).padStart(2,'0')}.${d.getFullYear()}`;
        return (
          <a class="post-row" href={`/en/labs/${post.id}`}>
            <span class="post-num">№ {String(posts.length - i).padStart(2, '0')}</span>
            <span class="post-date">{ddmm}</span>
            <span class="post-title">{post.data.title}</span>
            <span class="arrow">→</span>
          </a>
        );
      })}
    </div>
    <a href="/en" class="back-all">← All posts</a>
  </div>

  <div class="tag-tail"></div>
</Shell>

<style>
  .tag-hero {
    position: relative; z-index: 1;
    display: grid; grid-template-rows: 15fr 55fr 30fr;
    min-height: calc(100vh - 80px);
    max-width: 1280px; margin: 0 auto;
  }
  .tag-hero .copy {
    grid-row: 2;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; gap: 18px; padding: 0 24px;
    transform: translate3d(0, -10%, 0);
  }
  .tag-hero .kicker {
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: #2c1f15; opacity: 0.7;
  }
  .tag-hero h1 {
    font-family: 'Fraunces', serif;
    font-weight: 300; font-style: italic;
    font-size: clamp(64px, 12vw, 154px);
    line-height: 0.95; letter-spacing: -0.02em;
    color: #2a1a0e;
  }
  .tag-hero h1 em {
    font-style: italic; font-weight: 500;
    color: #6b3d20; font-size: 1.05em;
  }
  .tag-hero .sub {
    font-size: 14px; color: #2c1f15; opacity: 0.75;
    max-width: 560px;
  }

  .tag-posts {
    position: relative; z-index: 1;
    max-width: 1180px; margin: 0 auto;
    padding: 0 32px;
  }
  .archive-head {
    padding: 32px 0 12px;
    border-top: 1px solid rgba(44,31,21,0.18);
    display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
    align-items: baseline;
  }
  .archive-head h3 {
    grid-column: 1 / 7;
    font-family: 'Fraunces', serif; font-weight: 400; font-style: italic;
    font-size: 30px; letter-spacing: -0.01em; color: #1a1410;
  }
  .archive-head .count { grid-column: 7 / 13; text-align: right; font-size: 13px; color: rgba(44,31,21,0.6); font-variant-numeric: tabular-nums; }

  .post-row {
    display: grid; grid-template-columns: 60px 110px 1fr auto;
    gap: 20px; padding: 18px 0; align-items: baseline;
    border-bottom: 1px solid rgba(44,31,21,0.15);
    transition: padding-left 250ms;
    color: var(--fg);
  }
  .post-row:hover { padding-left: 12px; }
  .post-row:hover .post-title { color: var(--accent); }
  .post-row:hover .arrow { transform: translateX(8px); color: var(--accent); }
  .post-num { font-size: 12px; color: rgba(44,31,21,0.55); font-variant-numeric: tabular-nums; }
  .post-date { font-size: 12px; color: rgba(44,31,21,0.55); font-variant-numeric: tabular-nums; }
  .post-title {
    font-family: 'Fraunces', serif; font-weight: 400;
    font-size: 21px; line-height: 1.2; letter-spacing: -0.01em;
    transition: color 200ms;
  }
  .arrow { color: rgba(44,31,21,0.5); font-size: 18px; transition: transform 250ms, color 250ms; }

  .back-all {
    display: inline-block; margin-top: 28px;
    font-size: 13px; color: var(--muted);
    transition: color 150ms;
  }
  .back-all:hover { color: var(--accent); }

  .tag-tail { height: 30vw; }

  @media (max-width: 800px) {
    .tag-hero { min-height: calc(100vh - 130px); }
    .tag-hero .copy { padding: 0 16px; transform: translate3d(0, calc(-30px - 5%), 0); }
    .tag-hero h1 { font-size: 12vw; }
    .tag-posts { padding: 0 20px; }
    .archive-head h3 { grid-column: 1 / 8; }
    .archive-head .count { grid-column: 8 / 13; }
    .post-row { grid-template-columns: 90px 1fr auto; gap: 10px; }
    .post-num { display: none; }
    .post-title { font-size: 17px; }
  }
</style>
