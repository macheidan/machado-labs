---
import BaseHead from '../../components/BaseHead.astro';
import { SITE_DESCRIPTION_EN, HOME_TITLE_EN } from '../../consts';
import { homeGraph } from '../../lib/seo';
import { getCollection } from 'astro:content';

const posts = (await getCollection('labs-en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const grouped = new Map<string, typeof posts>();
for (const post of posts) {
  const year = String(new Date(post.data.pubDate).getFullYear());
  if (!grouped.has(year)) grouped.set(year, []);
  grouped.get(year)!.push(post);
}
const years = [...grouped.keys()].sort((a, b) => Number(b) - Number(a));

const jsonLd = homeGraph('en', SITE_DESCRIPTION_EN);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={HOME_TITLE_EN}
      description={SITE_DESCRIPTION_EN}
      lang="en"
      alternateUrl="/"
      jsonLd={jsonLd}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #1c1c1c;
        --fg: #ededed;
        --fg-muted: #a1a1a1;
        --fg-faint: #6e6e6e;
        --max-width: 640px;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html {
        -webkit-text-size-adjust: 100%;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      body {
        background: var(--bg);
        color: var(--fg);
        font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-feature-settings: 'ss01', 'cv11';
        font-size: 16px;
        line-height: 1.5;
        min-height: 100vh;
        letter-spacing: -0.01em;
      }

      ::selection { background: rgba(255,255,255,0.15); }

      a { color: inherit; text-decoration: none; }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 32px 24px 64px;
      }

      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding-top: 16px;
        padding-bottom: 56px;
      }

      .site-name {
        font-size: 17px;
        font-weight: 700;
        color: var(--fg);
        letter-spacing: -0.02em;
        line-height: 1;
        transition: opacity 0.15s ease;
      }
      .site-name:hover { opacity: 0.7; }

      nav {
        display: flex;
        align-items: center;
        gap: 28px;
        font-size: 15px;
      }

      nav a {
        color: var(--fg);
        line-height: 1;
        transition: opacity 0.15s ease;
      }
      nav a:hover { opacity: 0.65; }

      .lang {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 15px;
        line-height: 1;
      }
      .lang a { color: var(--fg-muted); }
      .lang a.active { color: var(--fg); }
      .lang .pipe { color: var(--fg-faint); }

      .x-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .x-link svg {
        display: block;
        width: 14px;
        height: 14px;
        fill: currentColor;
      }

      .posts {
        display: flex;
        flex-direction: column;
      }

      .year-group + .year-group { margin-top: 24px; }

      .year-header {
        font-family: 'Geist Mono', monospace;
        font-size: 12px;
        font-variant-numeric: tabular-nums;
        color: var(--fg-muted);
        text-align: right;
        width: 44px;
        margin-bottom: 4px;
      }

      .post {
        display: grid;
        grid-template-columns: 44px 1fr;
        column-gap: 14px;
        padding: 6px 0;
        align-items: baseline;
        transition: opacity 0.15s ease;
      }
      .post:hover { opacity: 0.6; }

      .post-month {
        text-align: right;
        font-family: 'Geist Mono', monospace;
        font-size: 12px;
        font-variant-numeric: tabular-nums;
        color: #737373;
        line-height: 1.6;
      }

      .post-title {
        color: var(--fg);
        font-size: 14px;
        font-weight: 400;
        line-height: 1.6;
      }

      @media (max-width: 480px) {
        header { padding-bottom: 40px; }
        nav { gap: 18px; font-size: 14px; }
        .lang { font-size: 14px; }
      }
    </style>
  </head>
  <body>
    <div class="container">

      <header>
        <a href="/en" class="site-name">Fábio Machado</a>
        <nav>
          <a href="/en/about">about</a>
          <span class="lang">
            <a href="/en" class="active">en</a>
            <span class="pipe">|</span>
            <a href="/">ptbr</a>
          </span>
          <a href="https://x.com/machadofabio" class="x-link" target="_blank" rel="noopener" aria-label="X">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
            </svg>
          </a>
        </nav>
      </header>

      <div class="posts">
        {years.map((year) => (
          <div class="year-group">
            <div class="year-header">{year}</div>
            {grouped.get(year)!.map((post) => {
              const month = String(new Date(post.data.pubDate).getMonth() + 1).padStart(2, '0');
              return (
                <a class="post" href={`/en/labs/${post.id}`}>
                  <span class="post-month">{month}</span>
                  <span class="post-title">{post.data.title}</span>
                </a>
              );
            })}
          </div>
        ))}
      </div>

    </div>
  </body>
</html>
