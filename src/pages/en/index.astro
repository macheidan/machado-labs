---
import Shell from '../../components/Shell.astro';
import { SITE_DESCRIPTION_EN, HOME_TITLE_EN } from '../../consts';
import { homeGraph } from '../../lib/seo';

const jsonLd = homeGraph('en', SITE_DESCRIPTION_EN);
---

<Shell
  title={HOME_TITLE_EN}
  description={SITE_DESCRIPTION_EN}
  lang="en"
  alternateUrl="/"
  jsonLd={jsonLd}
  active="home"
  variant="home"
>
  <section class="home-hero">
    <h1>How I automated my <em>businesses</em> with <span class="accent">AI agents.</span></h1>
    <p class="sub">Documenting how a team of AI agents is built inside real businesses. Decisions, metrics, mistakes, and cases &mdash; no theory.</p>
    <div class="cta-row">
      <a class="btn" href="/en/posts">Full Archive <span class="arrow">→</span></a>
      <a class="btn-dark" href="/en/about">About the author</a>
    </div>
  </section>
</Shell>

<style>
  .home-hero {
    flex: 1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    padding: 24px 28px;
    min-height: 0;
  }
  .home-hero h1 {
    font-size: clamp(40px, 7vw, 88px);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.035em;
    max-width: 14ch;
    margin-bottom: 22px;
    background: linear-gradient(180deg, #ffffff 0%, #cfcfd6 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .home-hero h1 :global(em) {
    font-style: italic; font-weight: 600;
    background: linear-gradient(120deg, #ffb088 0%, var(--accent) 60%, var(--pink) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .home-hero h1 :global(.accent) {
    font-weight: 700;
    background: linear-gradient(120deg, var(--accent) 0%, var(--pink) 50%, var(--violet) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .home-hero p.sub {
    font-size: clamp(15px, 1.4vw, 19px);
    color: var(--Text-Default);
    max-width: 56ch;
    line-height: 1.5;
    margin-bottom: 32px;
  }
  .home-hero .cta-row {
    display: flex; gap: 12px; align-items: center; flex-wrap: wrap;
    justify-content: center;
  }
  @media (max-width: 800px) {
    .home-hero h1 { font-size: 12vw; }
    .home-hero p.sub { font-size: 15px; margin-bottom: 24px; }
  }
  @media (max-height: 720px) {
    .home-hero h1 { font-size: clamp(32px, 6vw, 56px); margin-bottom: 14px; }
    .home-hero p.sub { font-size: 14px; margin-bottom: 22px; }
  }
</style>
