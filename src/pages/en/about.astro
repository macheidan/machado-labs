---
import Shell from '../../components/Shell.astro';
import { SITE_TITLE } from '../../consts';
import { profileGraph } from '../../lib/seo';

const description = 'About Fábio Machado — entrepreneur, consultant, and builder of AI systems.';
const jsonLd = profileGraph('en', description);
---

<Shell
  title={`About — ${SITE_TITLE}`}
  description={description}
  lang="en"
  alternateUrl="/about"
  jsonLd={jsonLd}
  active="about"
>
  <section class="about-page">
    <header class="about-head">
      <span class="pill">Founder · Consultant</span>
      <h1>I'm <em>Fábio</em>.</h1>
      <p class="lede">Entrepreneur and consultant. I spend most of my time building AI systems inside real businesses.</p>
    </header>

    <article class="about-body">
      <div class="bio">
        <p>I started in 1999 at 15, building computers and websites. Opened my first webdesign company in 2003. Twenty-plus years later I worked on brands like Latam, Petrobras, Gerdau, XP and Vivo via Pcom Marketing Estratégico, learning what works when the client is large and the margin for error is small.</p>
        <p>In 2012 I opened <strong>Lov Pizza</strong>. In 2015 I acquired M&amp;E Pizza, today <strong>Dáme Pizza</strong>. Operated 6 brands simultaneously at peak &mdash; the best stress test I could have asked for: real operations, tight margins, small team, daily decisions.</p>
        <p>That's how I understood the problem: a small business owner can't hire every role the operation demands. In 2022 I started building the answer with AI. Today my companies run with a team of agents covering those functions &mdash; as infrastructure, not as an experiment.</p>
        <p>This site documents the process. <a href="https://www.instagram.com/machadofabio" target="_blank" rel="noopener">@machadofabio</a></p>
      </div>

      <aside class="facts">
        <div class="fact"><span class="k">Role</span><span class="v">Founder · Consultant</span></div>
        <div class="fact"><span class="k">Stack</span><span class="v">AI agents</span></div>
        <div class="fact"><span class="k">Based</span><span class="v">Porto Alegre, BR</span></div>
        <div class="fact"><span class="k">Businesses</span><span class="v">8 founded</span></div>
        <div class="fact"><span class="k">Years</span><span class="v">25+ tech · mgmt</span></div>
        <div class="fact"><span class="k">AI projects</span><span class="v">18 applied</span></div>
      </aside>
    </article>
  </section>
</Shell>

<style>
  .about-page {
    padding-top: calc(var(--header-offset) + 32px);
    padding-bottom: 80px;
    max-width: 980px; margin: 0 auto;
    padding-left: 28px; padding-right: 28px;
  }
  .about-head { margin-bottom: 48px; max-width: 720px; }
  .pill {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--accent); font-weight: 600;
    padding: 6px 12px;
    background: var(--accent-soft);
    border-radius: 999px;
    margin-bottom: 22px;
  }
  .about-head h1 {
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 700; letter-spacing: -0.035em; line-height: 1;
    color: var(--Base-White);
    margin-bottom: 18px;
  }
  .about-head h1 em {
    font-style: italic; font-weight: 600;
    background: linear-gradient(120deg, #ffb088 0%, var(--accent) 60%, var(--pink) 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .about-head .lede {
    font-size: clamp(16px, 1.6vw, 19px);
    color: var(--Text-Default);
    line-height: 1.55;
    max-width: 60ch;
  }

  .about-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 48px;
    align-items: start;
  }
  .bio {
    font-size: 17px; line-height: 1.75;
    color: var(--Text-Default);
  }
  .bio p { margin: 0 0 1.4em; }
  .bio strong { color: var(--Base-White); font-weight: 600; }
  .bio a {
    color: var(--accent);
    border-bottom: 1px solid rgba(255,92,43,0.4);
    transition: border-color 160ms, opacity 160ms;
  }
  .bio a:hover { border-color: var(--accent); opacity: 0.85; }

  .facts {
    display: flex; flex-direction: column;
    padding: 22px;
    background: var(--Card-BG);
    border: 1px solid var(--Card-Border);
    border-radius: var(--rounding-md);
  }
  .fact {
    display: flex; justify-content: space-between; gap: 16px;
    padding: 12px 0;
    border-bottom: 1px solid var(--Card-Border);
    font-size: 13px;
  }
  .fact:last-child { border-bottom: none; }
  .fact .k {
    color: var(--Text-Muted);
    font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
    font-weight: 600;
  }
  .fact .v { color: var(--Base-White); text-align: right; }

  @media (max-width: 800px) {
    .about-page { padding-left: 16px; padding-right: 16px; padding-top: calc(var(--header-offset) + 24px); }
    .about-body { grid-template-columns: 1fr; gap: 32px; }
    .about-head h1 { font-size: 44px; }
  }
</style>
