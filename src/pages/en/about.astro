---
import Shell from '../../components/Shell.astro';
import { SITE_TITLE } from '../../consts';
import { profileGraph } from '../../lib/seo';

const description = 'About Fábio Machado — entrepreneur, consultant, and builder of AI systems.';
const jsonLd = profileGraph('en', description);
---

<Shell
  title={`About — ${SITE_TITLE}`}
  description={description}
  lang="en"
  alternateUrl="/about"
  jsonLd={jsonLd}
  active="about"
>
  <section class="post-hero">
    <h1>I'm <em>Fábio</em>.</h1>
    <p class="lede">Entrepreneur and consultant. I spend most of my time building AI systems inside real businesses.</p>
  </section>

  <article class="post-body">
    <p>I started in 1999 at 15, building computers and websites. Opened my first webdesign company in 2003. Twenty-plus years later I worked on brands like Latam, Petrobras, Gerdau, XP and Vivo via Pcom Marketing Estratégico, learning what works when the client is large and the margin for error is small.</p>
    <p>In 2012 I opened <strong>Lov Pizza</strong>. In 2015 I acquired M&amp;E Pizza, today <strong>Dáme Pizza</strong>. Operated 6 brands simultaneously at peak — the best stress test I could have asked for: real operations, tight margins, small team, daily decisions.</p>
    <p>That's how I understood the problem: a small business owner can't hire every role the operation demands. In 2022 I started building the answer with AI. Today my companies run with a team of agents covering those functions — as infrastructure, not as an experiment.</p>
    <p>This site documents the process. <a href="https://www.instagram.com/machadofabio" target="_blank" rel="noopener">@machadofabio</a></p>
  </article>
</Shell>

<style>
  .post-hero {
    max-width: 760px; margin: 0 auto;
    padding: calc(var(--header-offset) + 32px) 28px 32px;
    text-align: left;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 64px;
    margin-bottom: 64px;
  }
  .post-hero h1 {
    font-size: clamp(34px, 5.4vw, 64px);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.04;
    color: var(--Base-White);
    margin-bottom: 18px;
    text-wrap: balance;
  }
  .post-hero h1 :global(em) {
    font-style: italic; font-weight: 600;
    background: linear-gradient(120deg, #ffb088 0%, var(--accent) 60%, var(--pink) 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .post-hero .lede {
    margin-bottom: 0;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: 0.2px;
    color: var(--grey-200);
  }

  .post-body {
    max-width: 760px; margin: 0 auto;
    padding: 0 28px;
    color: rgba(255, 255, 255, 0.85);
  }
  .post-body :global(p) {
    margin-bottom: 32px;
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.02em;
  }
  .post-body :global(strong) { font-weight: 600; color: rgba(255, 255, 255, 0.9); }
  .post-body :global(em) { font-style: italic; }
  .post-body :global(a) {
    color: #ff6363;
    text-decoration: none;
    text-underline-offset: 0;
    transition: text-underline-offset 0.1s ease-out;
  }
  .post-body :global(a:hover), .post-body :global(a:focus) {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-style: dashed;
    text-decoration-color: rgba(255, 255, 255, 0.4);
    text-underline-offset: 5px;
    outline: none;
  }

  @media (max-width: 800px) {
    .post-hero { padding: calc(var(--header-offset) + 16px) 16px 24px; padding-bottom: 42px; margin-bottom: 42px; }
    .post-body { padding: 0 16px; }
  }
</style>
