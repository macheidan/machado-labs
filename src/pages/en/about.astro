---
import Shell from '../../components/Shell.astro';
import { SITE_TITLE } from '../../consts';
import { profileGraph } from '../../lib/seo';

const description = 'About Fábio Machado — entrepreneur, consultant, and builder of AI systems.';
const jsonLd = profileGraph('en', description);
---

<Shell
  title={`About — ${SITE_TITLE}`}
  description={description}
  lang="en"
  alternateUrl="/about"
  jsonLd={jsonLd}
  active="about"
>
  <section class="about-hero">
    <h1 class="hero-title">I'm <em>Fábio</em></h1>
  </section>

  <main class="container">
    <section class="layout">
      <div class="photo-col">
        <img src="/fabio.jpg" alt="Fábio Machado" class="photo" width="400" height="400" />
        <div class="photo-meta">
          <div><span class="key">Role</span><span>Founder · Consultant</span></div>
          <div><span class="key">Stack</span><span>AI agents</span></div>
          <div><span class="key">Based</span><span>Porto Alegre, BR</span></div>
          <div><span class="key">Twitter</span><span>@machadofabio</span></div>
        </div>
      </div>
      <div class="text-col">
        <span class="pill">Entrepreneur · Consultant</span>
        <h2 class="title">Building a <em>digital cortex</em>.</h2>
        <div class="prose">
          <p>I'm Fábio Machado. Entrepreneur and consultant. I spend most of my time building AI systems. Not irony — that's the point.</p>
          <p>Started in 1999 at 15, building PCs and websites. In 2003 I opened my first web design company. Twenty-plus years later, I had been around brands like Latam, Petrobras, Gerdau, XP and Vivo via Pcom Marketing Estratégico, where I learned what works when the client is big and the margin for error is small.</p>
          <p>In 2012 I opened <strong>Lov Pizza</strong>. In 2015 I bought M&amp;E Pizza, today <strong>Dáme Pizza</strong>. I ran 6 brands at once — the best stress test I could have picked: real operations, tight margins, lean teams, decisions every day.</p>
          <p>That's where I understood the problem: small business owners can't hire every role the operation demands. In 2022 I started building the answer with AI. Today my companies run with a team of agents covering those functions — as infrastructure, not as an experiment.</p>
          <p>This site documents the process. <a href="https://x.com/machadofabio" target="_blank" rel="noopener">@machadofabio</a></p>
        </div>
      </div>
    </section>

    <footer class="site">
      <span class="left">© Fábio Machado · Porto Alegre</span>
      <span class="right">Skin · Dawn Ridge</span>
    </footer>
  </main>
</Shell>

<style>
  .about-hero {
    position: relative;
    min-height: 60vh;
    display: flex; align-items: center; justify-content: center;
    padding: 0 24px;
  }
  .hero-title {
    font-family: 'Fraunces', serif; font-weight: 300; font-style: italic;
    font-size: clamp(60px, 13vw, 180px); line-height: 0.92;
    letter-spacing: -0.02em; color: #2a1a0e;
    text-align: center;
  }
  .hero-title em { font-style: italic; font-weight: 500; color: #6b3d20; }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 32px; position: relative; z-index: 6; }
  .layout {
    display: grid; grid-template-columns: repeat(12, 1fr); gap: 32px;
    background: rgba(244,236,220,0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 24px;
    border: 1px solid rgba(217, 204, 184, 0.6);
    padding: 56px;
  }
  .photo-col { grid-column: 1 / 5; }
  .photo {
    width: 100%; aspect-ratio: 1; object-fit: cover;
    border-radius: 24px;
    border: 1px solid var(--line);
  }
  .photo-meta { margin-top: 20px; font-size: 13px; color: var(--muted); line-height: 1.7; }
  .photo-meta div { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--line); }
  .photo-meta .key { color: var(--faint); text-transform: uppercase; font-size: 11px; letter-spacing: 0.1em; }

  .text-col { grid-column: 6 / 13; }
  .pill {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--muted); font-weight: 600; margin-bottom: 18px;
  }
  .pill::before { content: ''; width: 28px; height: 1px; background: var(--accent); }
  h2.title {
    font-family: 'Fraunces', serif; font-weight: 400;
    font-size: clamp(40px, 5.5vw, 72px); line-height: 1; letter-spacing: -0.015em;
    margin-bottom: 28px;
  }
  h2.title em { font-style: italic; color: var(--accent); }

  .prose p { font-size: 18px; line-height: 1.75; margin-bottom: 1.4em; color: var(--fg); }
  .prose strong { font-weight: 600; }
  .prose a { color: var(--accent); border-bottom: 1px solid currentColor; transition: opacity 150ms; }
  .prose a:hover { opacity: 0.7; }

  footer.site {
    padding: 32px 0; margin-top: 32px;
    display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
    font-size: 13px; color: rgba(44,31,21,0.7);
    position: relative; z-index: 6;
  }
  footer .left { grid-column: 1 / 7; }
  footer .right { grid-column: 7 / 13; text-align: right; }

  @media (max-width: 800px) {
    .hero-title { font-size: 16vw; }
    .layout { padding: 32px; gap: 24px; }
    .photo-col, .text-col { grid-column: 1 / 13; }
    .photo-col { max-width: 280px; }
    h2.title { font-size: 44px; }
    footer .left, footer .right { grid-column: 1 / 13; text-align: left; }
  }
</style>
