---
import Shell from '../../components/Shell.astro';
import { SITE_TITLE } from '../../consts';
import { profileGraph } from '../../lib/seo';
import { getEntry, render } from 'astro:content';

const description = 'About Fábio Machado — entrepreneur, consultant, and builder of AI systems.';
const jsonLd = profileGraph('en', description);

const entry = await getEntry('about', 'about-en');
const { heroTitle, lede, heroImage, heroAlt } = entry!.data;
const { Content } = await render(entry!);
---

<Shell
  title={`About — ${SITE_TITLE}`}
  description={description}
  lang="en"
  alternateUrl="/about"
  jsonLd={jsonLd}
  active="about"
>
  <section class="post-hero">
    <h1 set:html={heroTitle} />
    <p class="lede">{lede}</p>
  </section>

  <article class="post-body">
    {heroImage && (
      <img class="newspaper-photo" src={heroImage} alt={heroAlt ?? 'Fábio Machado'} width="320" height="320" loading="eager" />
    )}
    <Content />
  </article>
</Shell>

<style>
  .post-hero {
    max-width: 760px; margin: 0 auto;
    padding: calc(var(--header-offset) + 32px) 28px 32px;
    text-align: left;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 64px;
    margin-bottom: 64px;
  }
  .post-hero h1 {
    font-size: clamp(34px, 5.4vw, 64px);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.04;
    color: var(--Base-White);
    margin-bottom: 18px;
    text-wrap: balance;
  }
  .post-hero h1 :global(em) {
    font-style: italic; font-weight: 600;
    background: linear-gradient(120deg, #ffb088 0%, var(--accent) 60%, var(--pink) 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .post-hero .lede {
    margin-bottom: 0;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: 0.2px;
    color: var(--grey-200);
  }

  .post-body {
    max-width: 760px; margin: 0 auto;
    padding: 0 28px;
    color: rgba(255, 255, 255, 0.85);
  }
  .newspaper-photo {
    float: right;
    shape-outside: margin-box;
    width: 42%;
    max-width: 280px;
    aspect-ratio: 1;
    object-fit: cover;
    margin: 6px 0 16px 28px;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  @media (max-width: 600px) {
    .newspaper-photo {
      float: none;
      width: 100%;
      max-width: 100%;
      margin: 0 0 24px;
    }
  }
  .post-body :global(p) {
    margin-bottom: 32px;
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.02em;
  }
  .post-body :global(strong) { font-weight: 600; color: rgba(255, 255, 255, 0.9); }
  .post-body :global(em) { font-style: italic; }
  .post-body :global(a) {
    color: #ff6363;
    text-decoration: none;
    text-underline-offset: 0;
    transition: text-underline-offset 0.1s ease-out;
  }
  .post-body :global(a:hover), .post-body :global(a:focus) {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-style: dashed;
    text-decoration-color: rgba(255, 255, 255, 0.4);
    text-underline-offset: 5px;
    outline: none;
  }

  @media (max-width: 800px) {
    .post-hero { padding: calc(var(--header-offset) + 16px) 16px 24px; padding-bottom: 42px; margin-bottom: 42px; }
    .post-body { padding: 0 16px; }
  }
</style>
