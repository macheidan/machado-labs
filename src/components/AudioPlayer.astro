---
type Props = {
  src: string;
  label?: string;
  /** Título mostrado na tela de bloqueio do celular. */
  title?: string;
  /** Capa mostrada na tela de bloqueio (URL absoluta ou do site). */
  artwork?: string;
};

const { src, label = 'Ouvir o post', title, artwork } = Astro.props;
---

<div
  class="audio-glaze"
  data-audio-player
  data-title={title}
  data-artwork={artwork}
>
  <div class="inner">
    <button type="button" class="play" aria-label={label} data-play>
      <svg class="icon-play" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M4.5 2.6v10.8c0 .5.55.8.97.53l8.4-5.4a.63.63 0 0 0 0-1.06l-8.4-5.4A.63.63 0 0 0 4.5 2.6Z" />
      </svg>
      <svg class="icon-pause" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M4.6 2.4h2.1c.3 0 .5.2.5.5v10.2c0 .3-.2.5-.5.5H4.6a.5.5 0 0 1-.5-.5V2.9c0-.3.2-.5.5-.5ZM9.3 2.4h2.1c.3 0 .5.2.5.5v10.2c0 .3-.2.5-.5.5H9.3a.5.5 0 0 1-.5-.5V2.9c0-.3.2-.5.5-.5Z" />
      </svg>
    </button>

    <div
      class="track"
      role="slider"
      tabindex="0"
      aria-label="Andamento do áudio"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="0"
      data-track
    >
      <div class="rail"></div>
      <div class="fill" data-fill></div>
      <div class="knob" data-knob></div>
    </div>

    <span class="time" data-time>0:00</span>
  </div>

  <!-- playsinline evita que o iOS assuma a sessão em tela cheia. -->
  <audio preload="metadata" src={src} playsinline data-audio></audio>
</div>

<style>
  /* Mesmo tratamento do .btn-glaze da home: casca com gradiente cônico
     animado e miolo escuro arredondado. */
  .audio-glaze {
    --r2: 0deg;
    --x: 9%;
    display: block;
    width: 100%;
    padding: 1px;
    background:
      conic-gradient(from calc(var(--r2) - 80deg) at var(--x) 50%,
        transparent 0,
        rgb(236, 165, 167) 20%,
        transparent 25%),
      #452324;
    border-radius: 43px;
    box-shadow: 0 0 20px 0 rgba(245, 48, 107, 0.1);
    transition: box-shadow 0.2s ease;
    transform: translateZ(0);
    animation:
      glaze-rot 3s linear -0.64s infinite,
      glaze-x 3s linear -0.64s infinite;
  }
  .audio-glaze:hover { box-shadow: 0 0 20px 3px rgba(245, 49, 108, 0.25); }

  .inner {
    display: flex;
    gap: 14px;
    align-items: center;
    height: 44px;
    padding: 0 16px 0 12px;
    background: rgb(19, 13, 14);
    border-radius: 1000px;
  }

  .play {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 28px; height: 28px;
    padding: 0;
    color: var(--Base-White);
    background: rgba(255, 255, 255, 0.08);
    border: 0;
    border-radius: 50%;
    cursor: pointer;
    transition: background 0.15s ease, transform 0.1s ease;
  }
  .play:hover { background: rgba(255, 255, 255, 0.16); }
  .play:active { transform: scale(0.94); }
  .play:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .play svg { width: 13px; height: 13px; }
  .play .icon-pause { display: none; }
  .audio-glaze[data-playing] .play .icon-play { display: none; }
  .audio-glaze[data-playing] .play .icon-pause { display: block; }

  .track {
    position: relative;
    flex: 1;
    height: 20px;
    display: flex;
    align-items: center;
    cursor: pointer;
    touch-action: none;
  }
  .track:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; border-radius: 4px; }
  .rail {
    position: absolute;
    inset-inline: 0;
    height: 3px;
    background: rgba(255, 255, 255, 0.18);
    border-radius: 999px;
  }
  .fill {
    position: absolute;
    left: 0;
    width: 0%;
    height: 3px;
    background: linear-gradient(90deg, #ffb088 0%, var(--accent) 60%, var(--pink) 100%);
    border-radius: 999px;
  }
  .knob {
    position: absolute;
    left: 0;
    width: 10px; height: 10px;
    margin-left: -5px;
    background: var(--Base-White);
    border-radius: 50%;
    box-shadow: 0 0 6px rgba(245, 48, 107, 0.5);
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .track:hover .knob,
  .track:focus-visible .knob,
  .audio-glaze[data-playing] .knob { opacity: 1; }

  .time {
    flex-shrink: 0;
    /* cabe "-10:00" sem a barra pular quando o numero encolhe */
    min-width: 5.5ch;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--grey-200);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }

  @keyframes glaze-x {
    0%           { --x: 9%; }
    32.82275711% { --x: 91%; }
    50%          { --x: 91%; }
    82.82275711% { --x: 9%; }
    100%         { --x: 9%; }
  }
  @keyframes glaze-rot {
    0%           { --r2: 0deg; }
    32.82275711% { --r2: 0deg; }
    50%          { --r2: 180deg; }
    82.82275711% { --r2: 180deg; }
    100%         { --r2: 360deg; }
  }

  @media (prefers-reduced-motion: reduce) {
    .audio-glaze { animation: none; }
  }
  @media (max-width: 800px) {
    .inner { height: 40px; gap: 10px; padding: 0 12px 0 10px; }
  }
</style>

<script>
  function fmt(s: number) {
    if (!Number.isFinite(s)) return '0:00';
    // Arredonda o total antes de quebrar em min/seg: truncar faria um audio de
    // 479.99s (8:00) aparecer como 7:59.
    const total = Math.round(s);
    const m = Math.floor(total / 60);
    return `${m}:${String(total % 60).padStart(2, '0')}`;
  }

  function initAudioPlayers() {
   document.querySelectorAll<HTMLElement>('[data-audio-player]').forEach((root) => {
    // Com o ClientRouter (view transitions) o script não roda de novo a cada
    // navegação; religamos no astro:page-load. A guarda evita ligar o mesmo
    // player duas vezes (o page-load também dispara na carga inicial).
    if (root.dataset.bound) return;
    root.dataset.bound = '1';

    const audio = root.querySelector<HTMLAudioElement>('[data-audio]')!;
    const playBtn = root.querySelector<HTMLButtonElement>('[data-play]')!;
    const track = root.querySelector<HTMLElement>('[data-track]')!;
    const fill = root.querySelector<HTMLElement>('[data-fill]')!;
    const knob = root.querySelector<HTMLElement>('[data-knob]')!;
    const time = root.querySelector<HTMLElement>('[data-time]')!;

    let scrubbing = false;

    // Com o ClientRouter, o <audio> chega por troca de DOM e o navegador nem
    // sempre inicia o preload sozinho -> loadedmetadata nunca dispara e o player
    // fica travado em -0:00. Forçar o load kicka o download de metadados.
    if (audio.readyState === 0) audio.load();

    const render = () => {
      const d = audio.duration;
      const pct = Number.isFinite(d) && d > 0 ? (audio.currentTime / d) * 100 : 0;
      fill.style.width = `${pct}%`;
      knob.style.left = `${pct}%`;
      track.setAttribute('aria-valuenow', String(Math.round(pct)));
      // Contagem regressiva: quanto ainda falta. Parado no início, isso é a
      // própria duração total, então o número já diz o tamanho do post.
      time.textContent = Number.isFinite(d) ? `-${fmt(Math.max(0, d - audio.currentTime))}` : '-0:00';
    };

    const seekFromPointer = (clientX: number) => {
      const r = track.getBoundingClientRect();
      const ratio = Math.min(1, Math.max(0, (clientX - r.left) / r.width));
      if (Number.isFinite(audio.duration)) audio.currentTime = ratio * audio.duration;
      render();
    };

    playBtn.addEventListener('click', () => {
      if (audio.paused) {
        // Só um player tocando por vez na página.
        document.querySelectorAll<HTMLAudioElement>('[data-audio]').forEach((o) => {
          if (o !== audio) o.pause();
        });
        audio.play().catch(() => {});
      } else {
        audio.pause();
      }
    });

    // Media Session: coloca o post na tela de bloqueio / central de mídia do
    // celular, com capa e controles que continuam funcionando de tela apagada.
    const ms = (navigator as any).mediaSession;
    const setupMediaSession = () => {
      if (!ms || typeof MediaMetadata === 'undefined') return;
      const art = root.dataset.artwork;
      ms.metadata = new MediaMetadata({
        title: root.dataset.title || document.title,
        artist: 'Fábio Machado',
        album: 'fabiomachado.com.br',
        // sizes precisa bater com o arquivo real, senão a tela de bloqueio
        // corta/distorce a capa. A og é 1200x630 (retangular, não quadrada).
        artwork: art ? [{ src: art, sizes: '1200x630', type: 'image/png' }] : [],
      });
      ms.setActionHandler('play', () => audio.play());
      ms.setActionHandler('pause', () => audio.pause());
      ms.setActionHandler('seekbackward', (d: any) => {
        audio.currentTime = Math.max(0, audio.currentTime - (d?.seekOffset || 10));
      });
      ms.setActionHandler('seekforward', (d: any) => {
        audio.currentTime = Math.min(audio.duration, audio.currentTime + (d?.seekOffset || 10));
      });
      ms.setActionHandler('seekto', (d: any) => {
        if (d?.seekTime != null) audio.currentTime = d.seekTime;
        render();
      });
    };

    const syncPositionState = () => {
      if (!ms?.setPositionState || !Number.isFinite(audio.duration)) return;
      try {
        ms.setPositionState({
          duration: audio.duration,
          playbackRate: audio.playbackRate,
          position: Math.min(audio.currentTime, audio.duration),
        });
      } catch {
        // setPositionState é sensível a valores fora de faixa; ignorar é seguro.
      }
    };

    audio.addEventListener('play', () => {
      root.setAttribute('data-playing', '');
      setupMediaSession();
      if (ms) ms.playbackState = 'playing';
      syncPositionState();
    });
    audio.addEventListener('pause', () => {
      root.removeAttribute('data-playing');
      if (ms) ms.playbackState = 'paused';
    });
    audio.addEventListener('ended', () => {
      root.removeAttribute('data-playing');
      if (ms) ms.playbackState = 'none';
    });
    audio.addEventListener('loadedmetadata', () => {
      render();
      syncPositionState();
    });
    // durationchange é mais confiável que loadedmetadata quando o elemento
    // entra por troca de DOM (ClientRouter) em vez de parser.
    audio.addEventListener('durationchange', render);
    audio.addEventListener('seeked', syncPositionState);
    audio.addEventListener('timeupdate', () => {
      if (!scrubbing) render();
    });

    track.addEventListener('pointerdown', (e) => {
      scrubbing = true;
      track.setPointerCapture(e.pointerId);
      seekFromPointer(e.clientX);
    });
    track.addEventListener('pointermove', (e) => {
      if (scrubbing) seekFromPointer(e.clientX);
    });
    track.addEventListener('pointerup', (e) => {
      scrubbing = false;
      track.releasePointerCapture(e.pointerId);
    });
    track.addEventListener('keydown', (e) => {
      if (!Number.isFinite(audio.duration)) return;
      const step = e.key === 'ArrowRight' ? 5 : e.key === 'ArrowLeft' ? -5 : 0;
      if (!step) return;
      e.preventDefault();
      audio.currentTime = Math.min(audio.duration, Math.max(0, audio.currentTime + step));
      render();
    });

    render();
   });
  }

  initAudioPlayers();
  document.addEventListener('astro:page-load', initAudioPlayers);
</script>
