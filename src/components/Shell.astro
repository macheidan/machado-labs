---
import { ClientRouter } from 'astro:transitions';
import type { ImageMetadata } from 'astro';
import BaseHead from './BaseHead.astro';

interface Props {
  title: string;
  description: string;
  lang: 'pt-BR' | 'en';
  alternateUrl?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  noindex?: boolean;
  image?: ImageMetadata | string;
  ogType?: 'website' | 'article';
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
  author?: string;
  keywords?: string[];
  active?: 'home' | 'about' | 'posts';
  variant?: 'default' | 'home';
}

const {
  title, description, lang, alternateUrl, jsonLd, noindex,
  image, ogType, publishedTime, modifiedTime, author, keywords,
  active, variant = 'default',
} = Astro.props;

const isEn = lang === 'en';
const homeUrl = isEn ? '/en' : '/';
const aboutUrl = isEn ? '/en/about' : '/about';
const aboutLabel = isEn ? 'About' : 'Sobre';
const switchLabel = isEn ? 'PT' : 'EN';
const switchUrl = alternateUrl ?? (isEn ? '/' : '/en');
const bodyClass = variant === 'home' ? 'home-body' : '';
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      lang={lang}
      alternateUrl={alternateUrl}
      ogType={ogType}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
      keywords={keywords}
      jsonLd={jsonLd}
      noindex={noindex}
    />
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg: #0a0a0c;
        --bg-elevated: #111114;
        --bg-card: rgba(22, 22, 26, 0.65);
        --line: rgba(255, 255, 255, 0.08);
        --line-strong: rgba(255, 255, 255, 0.16);
        --fg: #f3f3f5;
        --fg-soft: #c8c8cf;
        --fg-muted: #8e8e98;
        --fg-faint: #5a5a64;
        --accent: #ff5c2b;
        --accent-soft: rgba(255, 92, 43, 0.16);
        --violet: #8e6bff;
        --cyan: #4dd4ff;
        --pink: #ff5fa8;
        --header-h: 60px;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { background: var(--bg); color: var(--fg); }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 16px; line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        min-height: 100vh;
        overflow-x: hidden;
      }
      body.home-body { height: 100vh; height: 100dvh; overflow: hidden; padding-top: var(--header-h); display: flex; flex-direction: column; }
      body.home-body main.shell-content { flex: 1; min-height: 0; display: flex; }
      body.home-body .site-footer { flex-shrink: 0; }
      a { color: inherit; text-decoration: none; }
      button { font: inherit; }
      img { display: block; max-width: 100%; height: auto; }
      ::selection { background: var(--accent); color: #fff; }

      .site-header {
        position: fixed; top: 0; left: 0; right: 0; z-index: 50;
        height: var(--header-h);
        display: flex; align-items: center; justify-content: space-between;
        padding: 0 28px;
        background: rgba(10, 10, 12, 0.62);
        backdrop-filter: saturate(180%) blur(20px);
        -webkit-backdrop-filter: saturate(180%) blur(20px);
        border-bottom: 1px solid var(--line);
      }
      .site-header .brand { font-size: 14px; font-weight: 600; letter-spacing: -0.01em; color: var(--fg); }
      .site-header nav { display: flex; align-items: center; gap: 28px; font-size: 13px; color: var(--fg-soft); }
      .site-header nav a { color: var(--fg-soft); transition: color 160ms; }
      .site-header nav a:hover, .site-header nav a.active { color: var(--fg); }

      .aurora {
        position: fixed; inset: 0; z-index: 0;
        pointer-events: none; overflow: hidden;
      }
      .aurora .blob { position: absolute; border-radius: 50%; filter: blur(90px); opacity: 0.55; }
      .aurora .b1 { width: 60vw; height: 60vw; top: -18vw; left: -14vw; background: radial-gradient(circle, var(--accent) 0%, transparent 70%); animation: drift1 24s ease-in-out infinite; }
      .aurora .b2 { width: 55vw; height: 55vw; top: -8vw; right: -16vw; background: radial-gradient(circle, var(--violet) 0%, transparent 70%); animation: drift2 30s ease-in-out infinite; opacity: 0.5; }
      .aurora .b3 { width: 65vw; height: 65vw; left: 18vw; top: 32vh; background: radial-gradient(circle, var(--cyan) 0%, transparent 65%); filter: blur(110px); opacity: 0.28; animation: drift3 36s ease-in-out infinite; }
      .aurora .b4 { width: 45vw; height: 45vw; right: 10vw; bottom: -10vw; background: radial-gradient(circle, var(--pink) 0%, transparent 70%); filter: blur(100px); opacity: 0.32; animation: drift4 28s ease-in-out infinite; }
      .aurora::after {
        content: ''; position: absolute; inset: 0;
        background:
          radial-gradient(ellipse at 50% 0%, rgba(10,10,12,0) 0%, rgba(10,10,12,0.55) 60%, var(--bg) 100%),
          repeating-linear-gradient(0deg, rgba(255,255,255,0.012) 0 1px, transparent 1px 3px);
      }
      @keyframes drift1 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(40px,30px) scale(1.06); } }
      @keyframes drift2 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-50px,40px) scale(1.08); } }
      @keyframes drift3 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(30px,-40px) scale(1.05); } }
      @keyframes drift4 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-30px,-25px) scale(1.07); } }
      @media (prefers-reduced-motion: reduce) {
        .aurora .blob { animation: none; }
      }

      main.shell-content { position: relative; z-index: 1; }

      .btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 22px;
        font-size: 14px; font-weight: 600; letter-spacing: -0.005em;
        color: #fff;
        background: linear-gradient(180deg, #ff7a4d 0%, var(--accent) 100%);
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 6px 22px rgba(255, 92, 43, 0.35), inset 0 1px 0 rgba(255,255,255,0.25);
        transition: transform 180ms, box-shadow 200ms, filter 180ms;
        cursor: pointer;
      }
      .btn:hover { transform: translateY(-1px); filter: brightness(1.05); box-shadow: 0 10px 28px rgba(255, 92, 43, 0.45), inset 0 1px 0 rgba(255,255,255,0.3); }
      .btn .arrow { transition: transform 200ms; }
      .btn:hover .arrow { transform: translateX(3px); }

      .btn-ghost {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 10px 16px; font-size: 13px; font-weight: 500;
        color: var(--fg-soft);
        background: rgba(255,255,255,0.04);
        border: 1px solid var(--line);
        border-radius: 999px;
        transition: background 160ms, color 160ms, border-color 160ms;
      }
      .btn-ghost:hover { color: var(--fg); background: rgba(255,255,255,0.08); border-color: var(--line-strong); }

      .site-footer {
        position: relative; z-index: 2;
        padding: 56px 28px 36px;
        border-top: 1px solid var(--line);
        background: rgba(10, 10, 12, 0.6);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
      }
      .site-footer .wrap {
        max-width: 1180px; margin: 0 auto;
        display: grid; grid-template-columns: 1fr auto; gap: 40px; align-items: center;
      }
      .newsletter form {
        display: flex; gap: 8px; max-width: 520px;
      }
      .newsletter input[type="email"] {
        flex: 1; min-width: 0;
        padding: 12px 16px; font-size: 14px;
        color: var(--fg); background: rgba(255,255,255,0.05);
        border: 1px solid var(--line-strong);
        border-radius: 999px;
        outline: none;
        transition: border-color 180ms, background 180ms;
      }
      .newsletter input[type="email"]::placeholder { color: var(--fg-muted); }
      .newsletter input[type="email"]:focus { border-color: var(--accent); background: rgba(255,255,255,0.07); }
      .newsletter button {
        padding: 12px 18px;
        font-size: 13px; font-weight: 600;
        background: var(--fg); color: var(--bg);
        border: none; border-radius: 999px; cursor: pointer;
        transition: opacity 160ms;
      }
      .newsletter button:hover { opacity: 0.85; }

      .social { display: flex; align-items: center; gap: 22px; font-size: 13px; color: var(--fg-muted); }
      .social a { display: inline-flex; align-items: center; gap: 6px; color: var(--fg-soft); transition: color 160ms; }
      .social a:hover { color: var(--fg); }
      .social a.more { color: var(--fg-soft); }
      .social a.more:hover { color: var(--accent); }
      .social svg { width: 16px; height: 16px; }

      @media (max-width: 800px) {
        .site-header { padding: 0 16px; }
        .site-header nav { gap: 16px; }
        .site-footer { padding: 36px 16px 28px; }
        .site-footer .wrap { grid-template-columns: 1fr; gap: 24px; }
        .newsletter form { flex-direction: column; }
        .newsletter input[type="email"], .newsletter button { width: 100%; }
      }
      @media (max-width: 460px) {
        .site-header nav { gap: 12px; font-size: 12px; }
      }
    </style>
  </head>
  <body class={bodyClass}>
    <div class="aurora" aria-hidden="true" transition:persist="aurora">
      <div class="blob b1"></div>
      <div class="blob b2"></div>
      <div class="blob b3"></div>
      <div class="blob b4"></div>
    </div>

    <header class="site-header" transition:persist="header">
      <a class="brand" href={homeUrl}>Fábio Machado</a>
      <nav>
        <a class="lang" href={switchUrl}>{switchLabel}</a>
        <a href={aboutUrl} class={active === 'about' ? 'active' : ''}>{aboutLabel}</a>
      </nav>
    </header>

    <main class="shell-content" transition:name="content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div class="newsletter">
          <form class="nl-form" autocomplete="off">
            <input type="email" required placeholder={isEn ? 'enter your email' : 'diga seu email e receba novidades'} aria-label="Email" />
            <button type="submit">{isEn ? 'Subscribe' : 'Assinar'}</button>
          </form>
        </div>
        <div class="social">
          <a href="https://instagram.com/machadofabio" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.4A4 4 0 1 1 12.6 8 4 4 0 0 1 16 11.4z"/><line x1="17.5" y1="6.5" x2="17.5" y2="6.5"/></svg>
            @machadofabio
          </a>
          <a class="more" href={isEn ? '/en/posts' : '/posts'}>{isEn ? 'More articles →' : 'Mais artigos →'}</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        function bind() {
          document.querySelectorAll('form.nl-form').forEach((form) => {
            if (form.dataset.bound) return;
            form.dataset.bound = '1';
            form.addEventListener('submit', (e) => {
              e.preventDefault();
              const input = form.querySelector('input[type="email"]');
              const button = form.querySelector('button');
              if (!input.value) return;
              const original = button.textContent;
              button.textContent = button.dataset.thanks || 'Obrigado';
              button.disabled = true;
              input.value = '';
              setTimeout(() => { button.textContent = original; button.disabled = false; }, 2400);
            });
          });
        }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind);
        else bind();
        document.addEventListener('astro:page-load', bind);
      })();
    </script>
  </body>
</html>
