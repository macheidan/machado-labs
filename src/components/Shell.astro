---
import { Image } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import type { ImageMetadata } from 'astro';
import BaseHead from './BaseHead.astro';
import mountains from '../content/imgs/montanhas.png';

interface Props {
  title: string;
  description: string;
  lang: 'pt-BR' | 'en';
  alternateUrl?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  noindex?: boolean;
  image?: ImageMetadata | string;
  ogType?: 'website' | 'article';
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
  author?: string;
  keywords?: string[];
  active?: 'home' | 'about';
}

const {
  title, description, lang, alternateUrl, jsonLd, noindex,
  image, ogType, publishedTime, modifiedTime, author, keywords,
  active,
} = Astro.props;

const isEn = lang === 'en';
const homeUrl = isEn ? '/en' : '/';
const aboutUrl = isEn ? '/en/about' : '/about';
const aboutLabel = isEn ? 'about' : 'sobre';
const switchLabel = isEn ? 'português' : 'english';
const switchUrl = alternateUrl ?? (isEn ? '/' : '/en');
const navPersist = `nav-${isEn ? 'en' : 'pt'}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      lang={lang}
      alternateUrl={alternateUrl}
      ogType={ogType}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
      keywords={keywords}
      jsonLd={jsonLd}
      noindex={noindex}
    />
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@300;400;500;600;700&family=Noto+Serif:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg: #F4ECDC; --fg: #1A1410; --muted: #5C4F42;
        --faint: #8B7B6A; --line: #D9CCB8; --accent: #C2683A; --warm: #ECB05A;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { background: #F4ECDC; }
      html {
        background: linear-gradient(
          180deg,
          #6e5e7f 0%,
          #a88a87 7%,
          #c9b18d 16%,
          #d7b88b 26%,
          #e1ba81 36%,
          #e7b874 46%,
          #ecb05a 58%,
          #c28242 72%,
          #ecb15b 100%
        );
        background-attachment: fixed;
        background-size: 100% 100%;
      }
      body {
        background: transparent;
        color: var(--fg);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: 17px; line-height: 1.55;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }
      ::selection { background: var(--accent); color: #fff; }
      a { color: inherit; text-decoration: none; }

      .dawn-nav {
        position: relative; z-index: 5;
        display: grid; grid-template-columns: 1fr auto 1fr;
        align-items: center;
        padding: 28px 40px;
        color: #2c1f15;
      }
      .dawn-nav .left { font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.75; }
      .dawn-nav .brand {
        font-family: 'Fraunces', serif; font-weight: 500;
        font-size: 22px; letter-spacing: 0.18em; text-transform: uppercase;
        text-align: center;
        will-change: transform;
      }
      .dawn-nav .right { display: flex; gap: 12px; justify-content: flex-end; align-items: center; font-size: 13px; }
      .dawn-nav .right > a { opacity: 0.75; transition: opacity 150ms; }
      .dawn-nav .right > a:hover, .dawn-nav .right > a.active { opacity: 1; }
      .dawn-nav .right .sep { opacity: 0.35; user-select: none; }
      .x-icon { display: inline-flex; align-items: center; opacity: 0.75; transition: opacity 150ms; }
      .x-icon:hover { opacity: 1; }
      .x-icon svg { width: 14px; height: 14px; fill: currentColor; display: block; }

      .mountains-fixed {
        position: fixed;
        left: 0; right: 0; bottom: 0;
        width: 100%;
        z-index: 4;
        pointer-events: none;
        line-height: 0;
      }
      .mountains-fixed img {
        width: 100%;
        height: auto;
        display: block;
      }

      .brand-bottom {
        position: fixed;
        left: 0; right: 0; top: 0;
        z-index: 5;
        text-align: center;
        pointer-events: none;
        user-select: none;
        font-family: 'Fraunces', serif;
        font-weight: 500;
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #ffffff;
        transform: translateY(150vh);
        will-change: transform;
      }

      main.shell-content { position: relative; z-index: 1; }

      .featured, .stats { perspective: 1400px; perspective-origin: 50% 35%; }
      .featured .card, .featured .stat {
        transform-origin: 50% 50%;
        transform-style: preserve-3d;
        will-change: transform;
        animation: quadro-floatTilt var(--float-speed, 6s) ease-in-out infinite;
        animation-delay: var(--float-delay, 0s);
      }
      @keyframes quadro-floatTilt {
        0%, 100% {
          transform:
            perspective(var(--persp, 900px))
            translateY(calc(var(--float-amp, 14px) * -1))
            rotateX(var(--rx, 0deg))
            rotateY(var(--ry, 0deg));
        }
        50% {
          transform:
            perspective(var(--persp, 900px))
            translateY(var(--float-amp, 14px))
            rotateX(var(--rx, 0deg))
            rotateY(var(--ry, 0deg));
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .featured .card, .featured .stat { animation: none !important; }
      }

      ::view-transition-old(content) {
        animation: 700ms cubic-bezier(0.22, 1, 0.36, 1) both shell-out;
      }
      ::view-transition-new(content) {
        animation: 700ms cubic-bezier(0.32, 0, 0.67, 0) both shell-in;
        animation-delay: 120ms;
      }
      @keyframes shell-out {
        to { transform: translateY(200px); opacity: 0; }
      }
      @keyframes shell-in {
        from { transform: translateY(-200px); opacity: 0; }
      }
      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(content),
        ::view-transition-new(content) { animation: none !important; }
      }

      @media (max-width: 800px) {
        .dawn-nav { grid-template-columns: 1fr; gap: 8px; padding: 20px 24px; text-align: center; }
        .dawn-nav .left, .dawn-nav .right { justify-content: center; display: flex; }
      }
    </style>
  </head>
  <body>
    <nav class="dawn-nav" transition:persist={navPersist}>
      <span class="left">2026</span>
      <a href={homeUrl} class="brand">Fábio Machado</a>
      <span class="right">
        <a href={aboutUrl} class={active === 'about' ? 'active' : ''}>{aboutLabel}</a>
        <span class="sep">|</span>
        <a href={switchUrl}>{switchLabel}</a>
        <span class="sep">|</span>
        <a class="x-icon" href="https://x.com/machadofabio" target="_blank" rel="noopener" aria-label="X (Twitter)">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </span>
    </nav>

    <main class="shell-content" transition:name="content">
      <slot />
    </main>

    <div class="mountains-fixed" transition:persist="mountains">
      <Image src={mountains} alt="" width={2752} height={898} loading="eager" />
    </div>
    <div class="brand-bottom" transition:persist="brand-bottom">Fábio Machado</div>

    <script is:inline>
      (function () {
        let raf = null;
        function update() {
          const topBrand = document.querySelector('.dawn-nav .brand');
          const bot = document.querySelector('.brand-bottom');
          if (!topBrand || !bot) { raf = null; return; }
          topBrand.style.transform = 'translateY(' + (window.scrollY * 2 / 3) + 'px)';

          const r = topBrand.getBoundingClientRect();
          const vh = window.innerHeight;
          const mirror = r.top + vh;
          const REST = 10;
          const restCap = vh - bot.getBoundingClientRect().height - REST;
          const offset = Math.max(mirror, restCap);
          bot.style.transform = 'translateY(' + offset + 'px)';

          const copy = document.querySelector('.dawn-hero .copy, .post-hero .copy');
          if (copy) {
            copy.style.setProperty('--scrollPara', (window.scrollY * 0.4) + 'px');
          }
          raf = null;
        }
        function onScrollOrResize() { if (!raf) raf = requestAnimationFrame(update); }
        function attach() {
          window.addEventListener('scroll', onScrollOrResize, { passive: true });
          window.addEventListener('resize', onScrollOrResize, { passive: true });
          update();
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', attach);
        } else {
          attach();
        }
        document.addEventListener('astro:page-load', update);
        document.addEventListener('astro:after-swap', update);
      })();

      (function () {
        const SIGNS = { tl: [+1,-1], tr: [+1,+1], bl: [-1,-1], br: [-1,+1] };
        function applyTilt(el, opts) {
          const [sx, sy] = SIGNS[opts.corner] || SIGNS.br;
          const deg = Math.min(35, opts.depth / 8) * (opts.tilt || 1);
          el.style.setProperty('--rx', (sx * deg) + 'deg');
          el.style.setProperty('--ry', (sy * deg) + 'deg');
          el.style.setProperty('--persp', opts.persp + 'px');
          el.style.setProperty('--float-amp', opts.floatAmp + 'px');
          el.style.setProperty('--float-speed', opts.floatSpeed + 's');
          el.style.setProperty('--float-delay', (opts.floatDelay || 0) + 's');
        }
        function init() {
          const big = document.querySelector('.featured .card:not(.stat)');
          if (big) applyTilt(big, { corner: 'br', depth: 100, tilt: 1, persp: 900, floatAmp: 11, floatSpeed: 7, floatDelay: 0 });
          const stats = document.querySelectorAll('.featured .stat');
          stats.forEach((el, i) => applyTilt(el, { corner: 'br', depth: 100, tilt: 1, persp: 900, floatAmp: 11, floatSpeed: 7, floatDelay: 0.4 * (i + 1) }));
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
        document.addEventListener('astro:page-load', init);
        document.addEventListener('astro:after-swap', init);
      })();
    </script>
  </body>
</html>
