---
import { ClientRouter } from 'astro:transitions';
import type { ImageMetadata } from 'astro';
import BaseHead from './BaseHead.astro';

interface Props {
  title: string;
  description: string;
  lang: 'pt-BR' | 'en';
  alternateUrl?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  noindex?: boolean;
  image?: ImageMetadata | string;
  ogType?: 'website' | 'article';
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
  author?: string;
  keywords?: string[];
  active?: 'home' | 'about' | 'posts';
  variant?: 'default' | 'home';
}

const {
  title, description, lang, alternateUrl, jsonLd, noindex,
  image, ogType, publishedTime, modifiedTime, author, keywords,
  active, variant = 'default',
} = Astro.props;

const isEn = lang === 'en';
const homeUrl = isEn ? '/en' : '/';
const aboutUrl = isEn ? '/en/about' : '/about';
const aboutLabel = isEn ? 'About' : 'Sobre';
const switchLabel = isEn ? 'PT' : 'EN';
const switchUrl = alternateUrl ?? (isEn ? '/' : '/en');
const postsUrl = isEn ? '/en/posts' : '/posts';
const moreLabel = isEn ? 'More articles →' : 'Mais artigos →';
const emailPlaceholder = isEn ? 'Enter your email' : 'diga seu email e receba novidades';
const newsletterCopy = isEn ? 'Get product updates and posts. No spam.' : 'Receba os próximos posts no seu email. Sem spam.';
const submitLabel = isEn ? 'Subscribe' : 'Assinar';
const submitThanks = isEn ? 'Thanks' : 'Obrigado';
const bodyClass = variant === 'home' ? 'home-body' : '';
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      lang={lang}
      alternateUrl={alternateUrl}
      ogType={ogType}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
      keywords={keywords}
      jsonLd={jsonLd}
      noindex={noindex}
    />
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        /* Raycast design tokens (from raycast.com source) */
        --grey-50:  #e6e6e6;
        --grey-100: #cdcece;
        --grey-200: #9c9c9d;
        --grey-300: #6a6b6c;
        --grey-400: #434345;
        --grey-500: #2f3031;
        --grey-600: #1b1c1e;
        --grey-700: #111214;
        --grey-800: #0c0d0f;
        --grey-900: #07080a;

        --Base-White: #ffffff;
        --Text-Loud: var(--Base-White);
        --Text-Default: var(--grey-200);
        --Text-Muted: var(--grey-300);
        --Text-Faint: var(--grey-400);
        --Card-BG: linear-gradient(137deg, #111214 4.87%, #0c0d0f 75.88%);
        --Card-Border: rgba(255, 255, 255, 0.06);

        --spacing-0-5: 4px;
        --spacing-1: 8px;
        --spacing-1-5: 12px;
        --spacing-2: 16px;
        --spacing-2-5: 20px;
        --spacing-3: 24px;
        --spacing-4: 32px;
        --spacing-5: 40px;
        --spacing-6: 48px;

        --rounding-xs: 4px;
        --rounding-sm: 6px;
        --rounding-normal: 8px;
        --rounding-md: 12px;
        --rounding-lg: 16px;
        --rounding-xl: 20px;
        --rounding-xxl: 24px;
        --rounding-full: 100%;

        --container-width: 1204px;
        --navbar-height: 58px;

        --font-inter: 'Inter', 'Inter Fallback', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        --font-mono: 'Geist Mono', ui-monospace, SFMono-Regular, Menlo, monospace;

        /* Project accent (keep our orange) */
        --accent: #ff5c2b;
        --accent-soft: rgba(255, 92, 43, 0.16);
        --violet: #8e6bff;
        --cyan: #4dd4ff;
        --pink: #ff5fa8;

        /* Body bg */
        --bg: var(--grey-900);
        --bg-elevated: var(--grey-700);
        --fg: var(--Text-Loud);
        --fg-soft: var(--Text-Default);
        --fg-muted: var(--Text-Muted);
        --fg-faint: var(--Text-Faint);
        --line: var(--Card-Border);
        --line-strong: rgba(255, 255, 255, 0.12);

        /* Layout: pill takes 76px height + 16px top inset on desktop, 58px + 16px on mobile */
        --header-offset: 74px;
      }
      @media (min-width: 721px) {
        :root { --navbar-height: 76px; --header-offset: 92px; }
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { background: var(--bg); color: var(--fg); }
      body {
        font-family: var(--font-inter);
        font-size: 16px;
        line-height: 1.55;
        letter-spacing: 0.2px;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        min-height: 100vh;
        min-height: 100dvh;
        overflow-x: hidden;
        color: var(--Text-Default);
        /* Sticky-footer baseline: empurra o rodapé pro fim do viewport quando o conteúdo é curto */
        display: flex; flex-direction: column;
      }
      body > main.shell-content { flex: 1 0 auto; }
      body > .site-footer { flex-shrink: 0; }
      body.home-body {
        height: 100vh; height: 100dvh;
        overflow: hidden;
        padding-top: var(--header-offset);
      }
      body.home-body main.shell-content { flex: 1; min-height: 0; display: flex; }
      a { color: inherit; text-decoration: none; }
      button { font: inherit; }

      /* Fix gradient-text clipping on the last italic/em letter:
         italic glyphs extend past the box, so the background-image gets cut.
         padding-inline-end + matching negative margin-inline-end keeps layout
         while extending the gradient paint area. */
      :where(h1, h2, h3) :where(em, .accent) {
        padding-inline-end: 0.12em;
        margin-inline-end: -0.04em;
        box-decoration-break: clone;
        -webkit-box-decoration-break: clone;
      }
      img { display: block; max-width: 100%; height: auto; }
      ::selection { background: var(--Base-White); color: var(--grey-900); }
      ::-moz-selection { background: var(--Base-White); color: var(--grey-900); }

      /* ---------- Raycast Navbar (pill) ---------- */
      .nav-container {
        position: fixed;
        top: 0; left: 50%;
        z-index: 50;
        display: flex;
        justify-content: center;
        width: 100%;
        padding: var(--spacing-2) var(--spacing-2) 0 var(--spacing-2);
        transform: translateX(-50%);
        pointer-events: none;
      }
      .navbar {
        pointer-events: auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        max-width: var(--container-width);
        height: var(--navbar-height);
        padding: var(--spacing-2) var(--spacing-2-5);
        background: linear-gradient(137deg, rgba(17,18,20,0.75) 4.87%, rgba(12,13,15,0.9) 75.88%);
        backdrop-filter: blur(5px);
        -webkit-backdrop-filter: blur(5px);
        border: 1px solid var(--Card-Border);
        border-radius: var(--rounding-lg);
        box-shadow: inset 0 1px 1px 0 rgba(255,255,255,0.15);
      }
      @media (min-width: 721px) {
        .navbar { padding: var(--spacing-2) var(--spacing-4); }
      }
      .nav-brand {
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-1);
        font-size: 14px;
        font-weight: 600;
        line-height: 16px;
        letter-spacing: 0.2px;
        color: var(--Base-White);
        transition: transform 0.2s ease;
        white-space: nowrap;
      }
      .nav-brand:hover { transform: scale(1.03); }
      .nav-brand .mark {
        width: 20px; height: 20px;
        display: inline-block;
        border-radius: var(--rounding-sm);
        background: linear-gradient(135deg, var(--accent), var(--pink));
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.2);
      }
      .nav-right {
        display: flex;
        align-items: center;
        gap: var(--spacing-0-5);
      }
      .nav-link {
        padding: var(--spacing-1-5) var(--spacing-1);
        font-family: var(--font-inter);
        font-size: 14px;
        font-weight: 500;
        line-height: normal;
        letter-spacing: 0.2px;
        color: var(--Text-Default);
        white-space: nowrap;
        border-radius: var(--rounding-sm);
        transition: color 0.2s ease, background 0.2s ease;
      }
      .nav-link:hover, .nav-link.active { color: var(--Base-White); }
      .nav-link:focus-visible {
        background: rgba(255,255,255,0.05);
        outline: none;
      }

      /* ---------- Animated background (aurora) ---------- */
      .aurora { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
      .aurora .blob { position: absolute; border-radius: 50%; filter: blur(90px); opacity: 0.5; }
      .aurora .b1 { width: 60vw; height: 60vw; top: -18vw; left: -14vw; background: radial-gradient(circle, var(--accent) 0%, transparent 70%); animation: drift1 24s ease-in-out infinite; }
      .aurora .b2 { width: 55vw; height: 55vw; top: -8vw; right: -16vw; background: radial-gradient(circle, var(--violet) 0%, transparent 70%); animation: drift2 30s ease-in-out infinite; opacity: 0.45; }
      .aurora .b3 { width: 65vw; height: 65vw; left: 18vw; top: 32vh; background: radial-gradient(circle, var(--cyan) 0%, transparent 65%); filter: blur(110px); opacity: 0.24; animation: drift3 36s ease-in-out infinite; }
      .aurora .b4 { width: 45vw; height: 45vw; right: 10vw; bottom: -10vw; background: radial-gradient(circle, var(--pink) 0%, transparent 70%); filter: blur(100px); opacity: 0.28; animation: drift4 28s ease-in-out infinite; }
      .aurora::after {
        content: ''; position: absolute; inset: 0;
        background:
          radial-gradient(ellipse at 50% 0%, rgba(7,8,10,0) 0%, rgba(7,8,10,0.55) 60%, var(--bg) 100%),
          repeating-linear-gradient(0deg, rgba(255,255,255,0.012) 0 1px, transparent 1px 3px);
      }
      @keyframes drift1 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(40px,30px) scale(1.06); } }
      @keyframes drift2 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-50px,40px) scale(1.08); } }
      @keyframes drift3 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(30px,-40px) scale(1.05); } }
      @keyframes drift4 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-30px,-25px) scale(1.07); } }
      @media (prefers-reduced-motion: reduce) { .aurora .blob { animation: none; } }

      main.shell-content { position: relative; z-index: 1; }

      /* ---------- Buttons (raycast-style) ---------- */
      .btn {
        display: inline-flex; flex-direction: row;
        gap: var(--spacing-1); align-items: center; justify-content: center;
        min-height: 36px;
        padding: var(--spacing-1) var(--spacing-1-5);
        font-family: var(--font-inter);
        font-size: 14px; font-weight: 500; line-height: 16px;
        letter-spacing: 0.2px; white-space: nowrap;
        cursor: pointer; border: none;
        border-radius: var(--rounding-normal);
        color: var(--grey-500);
        background: var(--grey-50);
        box-shadow:
          0 0 0 2px rgba(0,0,0,0.5),
          0 0 14px 0 rgba(255,255,255,0.19),
          inset 0 -1px 0.4px 0 rgba(0,0,0,0.2),
          inset 0 1px 0.4px 0 #fff;
        transition: background 0.2s, box-shadow 0.2s, transform 0.1s;
      }
      .btn:hover { background: var(--Base-White); }
      .btn:active { background: var(--grey-100); transform: translateY(0.5px); }
      .btn > svg, .btn .arrow { width: 16px; height: 16px; display: inline-flex; align-items: center; justify-content: center; }
      .btn .arrow { transition: transform 0.2s; }
      .btn:hover .arrow { transform: translateX(3px); }

      .btn-dark {
        display: inline-flex; align-items: center; gap: var(--spacing-1);
        min-height: 36px;
        padding: var(--spacing-1) var(--spacing-1-5);
        font-family: var(--font-inter);
        font-size: 14px; font-weight: 500; line-height: 16px;
        letter-spacing: 0.2px;
        color: var(--Base-White);
        background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.1));
        border-radius: var(--rounding-normal);
        box-shadow:
          inset 0 1px 0 0 rgba(255,255,255,0.05),
          0 0 0 1px rgba(255,255,255,0.25),
          inset 0 -1px 0 0 rgba(0,0,0,0.2);
        transition: box-shadow 0.2s, transform 0.1s;
        cursor: pointer; border: none;
      }
      .btn-dark:hover { box-shadow: inset 0 1px 0 0 rgba(255,255,255,0.05), 0 0 0 1px rgba(255,255,255,0.5), inset 0 -1px 0 0 rgba(0,0,0,0.2); }
      .btn-dark:active { transform: translateY(0.5px); }

      /* ---------- Site footer / subscribe form ---------- */
      .site-footer {
        position: relative; z-index: 2;
        padding: var(--spacing-6) var(--spacing-3) var(--spacing-4);
        border-top: 1px solid var(--Card-Border);
        background: rgba(7,8,10,0.6);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
      }
      .site-footer .wrap {
        max-width: 1180px; margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: var(--spacing-5);
        align-items: end;
      }
      .newsletter h4 {
        font-family: var(--font-inter);
        font-size: 14px; font-weight: 500; line-height: 18px;
        letter-spacing: 0.2px;
        color: var(--Text-Loud);
        margin-bottom: var(--spacing-1);
      }
      .newsletter p {
        font-size: 12px; font-weight: 400; line-height: 18px;
        letter-spacing: 0.4px;
        color: rgba(255,255,255,0.4);
        margin-bottom: var(--spacing-2);
      }
      .nl-form {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: var(--spacing-1);
        max-width: 460px;
      }
      .nl-form input[type="email"] {
        min-height: 36px;
        padding: var(--spacing-1) var(--spacing-1-5);
        font-family: var(--font-inter);
        font-size: 14px; font-weight: 500; line-height: 16px;
        letter-spacing: 0.2px;
        color: var(--Text-Loud);
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: var(--rounding-normal);
        outline: none;
        transition: border-color 0.2s, background 0.2s;
      }
      .nl-form input[type="email"]::placeholder { color: var(--Text-Faint); }
      .nl-form input[type="email"]:focus { border-color: rgba(255,255,255,0.3); background: rgba(255,255,255,0.06); }

      .social {
        display: flex;
        align-items: center;
        gap: var(--spacing-3);
        font-size: 13px;
        color: var(--Text-Muted);
        letter-spacing: 0.2px;
      }
      .social a {
        display: inline-flex; align-items: center; gap: var(--spacing-0-5);
        color: var(--Text-Default);
        transition: color 0.2s;
      }
      .social a:hover { color: var(--Base-White); }
      .social a.more { color: var(--Text-Default); }
      .social a.more:hover { color: var(--accent); }
      .social svg { width: 16px; height: 16px; }

      @media (max-width: 720px) {
        .navbar { padding: var(--spacing-1-5) var(--spacing-2); }
        .nav-right { gap: 0; }
        .nav-link { padding: var(--spacing-1) var(--spacing-1); font-size: 13px; }
        .site-footer { padding: var(--spacing-4) var(--spacing-2) var(--spacing-3); }
        .site-footer .wrap { grid-template-columns: 1fr; gap: var(--spacing-3); }
        .nl-form { grid-template-columns: 1fr; max-width: 100%; }
      }
    </style>
  </head>
  <body class={bodyClass}>
    <div class="aurora" aria-hidden="true" transition:persist="aurora">
      <div class="blob b1"></div>
      <div class="blob b2"></div>
      <div class="blob b3"></div>
      <div class="blob b4"></div>
    </div>

    <div class="nav-container" id="navbar">
      <header class="navbar">
        <a class="nav-brand" href={homeUrl}>
          <span class="mark" aria-hidden="true"></span>
          Fábio Machado
        </a>
        <nav class="nav-right" aria-label="Primary">
          <a class="nav-link lang-toggle" href={switchUrl} data-lang={isEn ? 'en' : 'pt'}>{switchLabel}</a>
          <a class={`nav-link${active === 'about' ? ' active' : ''}`} href={aboutUrl}>{aboutLabel}</a>
        </nav>
      </header>
    </div>

    <main class="shell-content" transition:name="content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div class="newsletter">
          <h4>{isEn ? 'Subscribe to the newsletter' : 'Assine a newsletter'}</h4>
          <p>{newsletterCopy}</p>
          <form class="nl-form" autocomplete="off" data-thanks={submitThanks} data-default={submitLabel}>
            <input type="email" required placeholder={emailPlaceholder} aria-label="Email" />
            <button type="submit" class="btn-dark">{submitLabel}</button>
          </form>
        </div>
        <div class="social">
          <a href="https://instagram.com/machadofabio" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.4A4 4 0 1 1 12.6 8 4 4 0 0 1 16 11.4z"/><line x1="17.5" y1="6.5" x2="17.5" y2="6.5"/></svg>
            @machadofabio
          </a>
          <a class="more" href={postsUrl}>{moreLabel}</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        function bind() {
          document.querySelectorAll('form.nl-form').forEach((form) => {
            if (form.dataset.bound) return;
            form.dataset.bound = '1';
            form.addEventListener('submit', (e) => {
              e.preventDefault();
              const input = form.querySelector('input[type="email"]');
              const button = form.querySelector('button');
              if (!input.value) return;
              const original = form.dataset.default || button.textContent;
              button.textContent = form.dataset.thanks || 'Thanks';
              button.disabled = true;
              input.value = '';
              setTimeout(() => { button.textContent = original; button.disabled = false; }, 2400);
            });
          });
        }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind);
        else bind();
        document.addEventListener('astro:page-load', bind);
      })();
    </script>
  </body>
</html>
