---
import type { ImageMetadata } from 'astro';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata | string;
	lang?: 'pt-BR' | 'en';
	alternateUrl?: string;
	ogType?: 'website' | 'article';
	publishedTime?: Date | string;
	modifiedTime?: Date | string;
	jsonLd?: Record<string, any> | Record<string, any>[];
	noindex?: boolean;
	keywords?: string[];
	author?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	image,
	lang = 'pt-BR',
	alternateUrl,
	ogType = 'website',
	publishedTime,
	modifiedTime,
	jsonLd,
	noindex = false,
	keywords,
	author,
} = Astro.props;

const imageIsObject = typeof image === 'object' && image !== null;
const imageSrc = typeof image === 'string' ? image : image?.src ?? '/og-default.png';
const imageAbsolute = new URL(imageSrc, Astro.url).toString();
const imageWidth = imageIsObject && image?.width ? image.width : 1200;
const imageHeight = imageIsObject && image?.height ? image.height : 630;

const isEn = lang === 'en';
const ogLocale = isEn ? 'en_US' : 'pt_BR';
const ogLocaleAlt = isEn ? 'pt_BR' : 'en_US';

const altUrlAbsolute = alternateUrl ? new URL(alternateUrl, Astro.site).toString() : null;
const publishedISO = publishedTime
	? (publishedTime instanceof Date ? publishedTime : new Date(publishedTime)).toISOString()
	: null;
const modifiedISO = modifiedTime
	? (modifiedTime instanceof Date ? modifiedTime : new Date(modifiedTime)).toISOString()
	: null;
const keywordsContent = keywords && keywords.length > 0 ? keywords.join(', ') : null;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="theme-color" content="#1c1c1c" />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/favicon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="me" href="https://x.com/machadofabio" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL(isEn ? 'en/rss.xml' : 'rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Search engine verification -->
<meta name="google-site-verification" content="1jfwkr8YdCROFLps27BfJFsH8Cuop6qdbOEVt9fufO8" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- hreflang -->
{
	isEn ? (
		<>
			<link rel="alternate" hreflang="en" href={canonicalURL} />
			{altUrlAbsolute && <link rel="alternate" hreflang="pt-BR" href={altUrlAbsolute} />}
			{altUrlAbsolute && <link rel="alternate" hreflang="x-default" href={altUrlAbsolute} />}
		</>
	) : (
		<>
			<link rel="alternate" hreflang="pt-BR" href={canonicalURL} />
			{altUrlAbsolute && <link rel="alternate" hreflang="en" href={altUrlAbsolute} />}
			<link rel="alternate" hreflang="x-default" href={canonicalURL} />
		</>
	)
}

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
{author && <meta name="author" content={author} />}
{keywordsContent && <meta name="keywords" content={keywordsContent} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageAbsolute} />
<meta property="og:image:width" content={String(imageWidth)} />
<meta property="og:image:height" content={String(imageHeight)} />
<meta property="og:image:alt" content={title} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:locale:alternate" content={ogLocaleAlt} />
{publishedISO && <meta property="article:published_time" content={publishedISO} />}
{modifiedISO && <meta property="article:modified_time" content={modifiedISO} />}
{ogType === 'article' && author && <meta property="article:author" content={author} />}
{ogType === 'article' && keywords && keywords.map((tag) => (
  <meta property="article:tag" content={tag} />
))}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageAbsolute} />
<meta property="twitter:image:alt" content={title} />
<meta property="twitter:site" content="@machadofabio" />
<meta property="twitter:creator" content="@machadofabio" />

<!-- JSON-LD structured data -->
{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-7EFMWQDNMH"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-7EFMWQDNMH');

  document.addEventListener('click', function(e) {
    const el = e.target.closest('a, button, [role="button"]');
    if (!el) return;

    gtag('event', 'click', {
      element: el.tagName.toLowerCase(),
      label: (el.innerText || el.getAttribute('aria-label') || '').trim().slice(0, 100),
      href: el.href || null,
      page: window.location.pathname,
    });
  });
</script>
