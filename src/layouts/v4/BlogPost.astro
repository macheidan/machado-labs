---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';

type Props = CollectionEntry<'labs'>['data'];
const { title, description, pubDate } = Astro.props;
const dateFormatted = new Date(pubDate).toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' });
const dateNum = new Date(pubDate);
const dn = `${String(dateNum.getDate()).padStart(2,'0')}.${String(dateNum.getMonth()+1).padStart(2,'0')}.${dateNum.getFullYear()}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={title} description={description} lang="pt-BR" noindex={true} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Source+Sans+3:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #FAFAFA; --fg: #09090B; --muted: #3F3F46;
        --faint: #71717A; --line: #E4E4E7; --accent: #EC4899;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--bg); color: var(--fg);
        font-family: 'Source Sans 3', -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: 17px; line-height: 1.55; min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }
      ::selection { background: var(--accent); color: #fff; }
      a { color: inherit; text-decoration: none; }

      .container { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

      header.top {
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
        align-items: center; padding: 28px 0 24px;
        border-bottom: 1px solid var(--line);
      }
      .brand {
        grid-column: 1 / 4;
        font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 0.02em;
        line-height: 1;
      }
      .brand .dot { color: var(--accent); }
      .nav { grid-column: 8 / 13; display: flex; gap: 32px; justify-content: flex-end; align-items: center; font-size: 14px; font-weight: 500; }
      .nav > a { color: var(--muted); transition: color 150ms; }
      .nav > a:hover, .nav > a.active { color: var(--fg); }
      .skin-switch { display: flex; gap: 4px; }
      .skin-switch a { padding: 4px 9px; font-size: 12px; border: 1px solid var(--line); border-radius: 999px; color: var(--muted); transition: all 150ms; }
      .skin-switch a.active { background: var(--fg); color: var(--bg); border-color: var(--fg); }
      .skin-switch a:hover { border-color: var(--fg); color: var(--fg); }

      .post-wrap { display: grid; grid-template-columns: 1fr; gap: 40px; padding: 56px 0; }

      .post-header {
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
        padding-bottom: 32px; border-bottom: 1px solid var(--line); margin-bottom: 32px;
      }
      .back-link { grid-column: 1 / 13; font-size: 13px; color: var(--muted); display: inline-flex; gap: 6px; align-items: center; transition: color 150ms; }
      .back-link:hover { color: var(--accent); }

      .post-title {
        grid-column: 1 / 13;
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(48px, 7vw, 88px); line-height: 1.0; letter-spacing: 0.005em;
        text-transform: uppercase;
        margin-top: 24px;
      }
      .post-meta {
        grid-column: 1 / 13;
        display: flex; gap: 24px; align-items: center; flex-wrap: wrap;
        margin-top: 16px; font-size: 13px; color: var(--muted);
        font-variant-numeric: tabular-nums;
      }
      .post-meta .pill {
        background: var(--accent); color: #fff;
        padding: 3px 10px; border-radius: 999px;
        font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
      }

      .post-body {
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
      }
      .prose { grid-column: 2 / 11; font-size: 18px; line-height: 1.75; color: var(--fg); }
      .prose :global(p) { margin-bottom: 1.4em; }
      .prose :global(h2) {
        font-family: 'Bebas Neue', sans-serif; font-size: 36px; letter-spacing: 0.01em;
        line-height: 1.05; text-transform: uppercase; margin: 2.2em 0 0.6em; color: var(--fg);
      }
      .prose :global(h3) { font-size: 20px; font-weight: 700; margin: 1.8em 0 0.4em; }
      .prose :global(a) { color: var(--accent); border-bottom: 1px solid currentColor; transition: opacity 150ms; }
      .prose :global(a:hover) { opacity: 0.7; }
      .prose :global(strong) { font-weight: 700; }
      .prose :global(blockquote) {
        border-left: 3px solid var(--accent); padding: 8px 0 8px 20px;
        margin: 1.6em 0; color: var(--muted); font-style: italic;
        background: linear-gradient(to right, rgba(236, 72, 153, 0.04), transparent);
      }
      .prose :global(code) {
        background: #F4F4F5; border: 1px solid var(--line);
        padding: 2px 6px; border-radius: 4px; font-size: 14px;
        font-family: ui-monospace, Menlo, monospace;
      }
      .prose :global(pre) {
        background: var(--fg); color: #FAFAFA;
        padding: 20px; border-radius: 8px; overflow-x: auto;
        margin: 1.6em 0; font-size: 14px; line-height: 1.65;
      }
      .prose :global(pre code) { background: none; border: none; padding: 0; color: inherit; }
      .prose :global(ul), .prose :global(ol) { padding-left: 1.5em; margin-bottom: 1.4em; }
      .prose :global(li) { margin-bottom: 0.4em; }
      .prose :global(hr) { border: none; border-top: 1px solid var(--line); margin: 2.5em 0; }

      footer.bottom {
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
        padding: 32px 0; border-top: 1px solid var(--line); margin-top: 80px;
        font-size: 13px; color: var(--muted);
      }
      footer .left { grid-column: 1 / 7; }
      footer .right { grid-column: 7 / 13; text-align: right; }

      @media (max-width: 800px) {
        header.top { grid-template-columns: 1fr 1fr; }
        .brand, .nav { grid-column: span 1; }
        .nav { gap: 12px; flex-wrap: wrap; }
        .post-title { font-size: 44px; }
        .post-body { grid-template-columns: 1fr; }
        .prose { grid-column: 1; font-size: 16px; }
        .prose :global(h2) { font-size: 28px; }
        footer .left, footer .right { grid-column: 1; text-align: left; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header class="top">
        <a class="brand" href="/v4">FÁBIO MACHADO<span class="dot">.</span></a>
        <nav class="nav">
          <a href="/v4/about">sobre</a>
          <span class="skin-switch">
            <a href={Astro.url.pathname.replace('/v4/', '/')}>v1</a>
            <a href={Astro.url.pathname.replace('/v4/', '/v2/')}>v2</a>
            <a href={Astro.url.pathname.replace('/v4/', '/v3/')}>v3</a>
            <a href="" class="active">v4</a>
          </span>
        </nav>
      </header>

      <article class="post-wrap">
        <div class="post-header">
          <a href="/v4" class="back-link">← Todos os posts</a>
          <h1 class="post-title">{title}</h1>
          <div class="post-meta">
            <span class="pill">Lab</span>
            <span>@machadofabio</span>
            <span>·</span>
            <span>{dateFormatted}</span>
          </div>
        </div>

        <div class="post-body">
          <div class="prose"><slot /></div>
        </div>
      </article>

      <footer class="bottom">
        <span class="left">© Fábio Machado · {dn}</span>
        <span class="right">Skin v4 · Swiss Modernism</span>
      </footer>
    </div>
  </body>
</html>
