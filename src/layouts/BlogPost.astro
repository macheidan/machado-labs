---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import { articleGraph, SITE_URL } from '../lib/seo';
import { tagLabel, tagPathFor } from '../lib/tags';

type Props = CollectionEntry<'labs'>['data'] & {
  lang?: 'pt' | 'en';
  altUrl?: string;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroAlt,
  author,
  tags = [],
  keywords,
  lang = 'pt',
  altUrl,
} = Astro.props;
const isEn = lang === 'en';

const dateFormatted = new Date(pubDate).toLocaleDateString(
  isEn ? 'en-US' : 'pt-BR',
  { year: 'numeric', month: 'long', day: 'numeric' },
);

const homeUrl = isEn ? '/en' : '/';
const aboutUrl = isEn ? '/en/about' : '/about';
const aboutLabel = isEn ? 'about' : 'sobre';
const backLabel = isEn ? 'all posts' : 'todos os posts';
const fallbackAlt = isEn ? '/' : '/en';
const switchUrl = altUrl ?? fallbackAlt;
const labsLabel = 'Labs';
const homeLabel = 'Home';

const slug = Astro.url.pathname.replace(/^\/(en\/)?labs\//, '').replace(/\/$/, '');
const ogImageUrl = heroImage
  ? new URL(heroImage.src, SITE_URL).toString()
  : `${SITE_URL}/og-default.png`;
const heroImageAlt = heroAlt ?? title;

const seoKeywords = keywords && keywords.length > 0
  ? keywords
  : (tags.length > 0 ? tags.map((t) => tagLabel(t, lang)) : undefined);

const jsonLd = articleGraph({
  lang,
  title,
  description,
  pubDate: new Date(pubDate),
  updatedDate: updatedDate ? new Date(updatedDate) : undefined,
  slug,
  imageUrl: ogImageUrl,
  keywords: seoKeywords,
});
---

<!doctype html>
<html lang={isEn ? 'en' : 'pt-BR'}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={heroImage}
      lang={isEn ? 'en' : 'pt-BR'}
      alternateUrl={altUrl}
      ogType="article"
      publishedTime={pubDate}
      modifiedTime={updatedDate}
      author={author}
      keywords={seoKeywords}
      jsonLd={jsonLd}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #1c1c1c;
        --fg: #ededed;
        --fg-muted: #a1a1a1;
        --fg-faint: #6e6e6e;
        --max-width: 640px;
        --accent: #ededed;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html {
        -webkit-text-size-adjust: 100%;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      body {
        background: var(--bg);
        color: var(--fg);
        font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-feature-settings: 'ss01', 'cv11';
        font-size: 16px;
        line-height: 1.5;
        min-height: 100vh;
        letter-spacing: -0.01em;
      }

      ::selection { background: rgba(255,255,255,0.15); }
      a { color: inherit; text-decoration: none; }

      /* ── Container ── */
      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 32px 24px 80px;
      }

      /* ── Header ── */
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding-top: 16px;
        padding-bottom: 56px;
      }

      .site-name {
        font-size: 17px;
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1;
        transition: opacity 0.15s ease;
      }
      .site-name:hover { opacity: 0.7; }

      nav {
        display: flex;
        align-items: center;
        gap: 28px;
        font-size: 15px;
      }
      nav a { line-height: 1; transition: opacity 0.15s ease; }
      nav a:hover { opacity: 0.65; }

      .lang {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 15px;
        line-height: 1;
      }
      .lang a { color: var(--fg-muted); }
      .lang a.active { color: var(--fg); }
      .lang .pipe { color: var(--fg-faint); }

      .x-link { display: inline-flex; align-items: center; }
      .x-link svg { display: block; width: 14px; height: 14px; fill: currentColor; }

      /* ── Breadcrumb ── */
      .breadcrumb {
        font-family: 'Geist Mono', monospace;
        font-size: 11px;
        color: var(--fg-faint);
        margin-bottom: 24px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 6px;
        line-height: 1.4;
      }
      .breadcrumb a {
        color: var(--fg-muted);
        transition: color 0.15s ease;
      }
      .breadcrumb a:hover { color: var(--fg); }
      .breadcrumb .sep { color: var(--fg-faint); }
      .breadcrumb .current {
        color: var(--fg-muted);
        max-width: 280px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      /* ── Hero image ── */
      .hero {
        margin: 0 0 32px;
      }
      .hero img {
        width: 100%;
        height: auto;
        border-radius: 8px;
        display: block;
      }

      /* ── Tags ── */
      .tags {
        list-style: none;
        padding: 0;
        margin: 32px 0 24px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .tags li { margin: 0; }
      .tags a {
        font-family: 'Geist Mono', monospace;
        font-size: 12px;
        color: var(--fg-muted);
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 999px;
        padding: 4px 10px;
        line-height: 1;
        transition: color 0.15s ease, border-color 0.15s ease;
      }
      .tags a:hover {
        color: var(--fg);
        border-color: rgba(255,255,255,0.2);
      }

      /* ── Post header ── */
      .post-title {
        font-size: 24px;
        font-weight: 700;
        line-height: 2rem;
        color: var(--fg);
        margin-bottom: 4px;
      }

      .post-meta {
        font-family: 'Geist Mono', 'Courier New', monospace;
        font-size: 12px;
        color: #737373;
        display: flex;
        align-items: center;
        gap: 0;
        margin-bottom: 40px;
      }

      .post-meta .sep {
        margin: 0 8px;
        color: var(--fg-faint);
      }

      /* ── Prose ── */
      .prose {
        font-size: 16px;
        line-height: 1.75;
        color: var(--fg);
      }

      .prose :global(p) { margin-bottom: 1.4em; }

      .prose :global(h2) {
        font-size: 20px;
        font-weight: 700;
        color: var(--fg);
        margin-top: 2.25em;
        margin-bottom: 0.5em;
        line-height: 2rem;
      }

      .prose :global(h3) {
        font-size: 16px;
        font-weight: 700;
        color: var(--fg);
        margin-top: 1.75em;
        margin-bottom: 0.4em;
      }

      .prose :global(a) {
        color: var(--fg);
        text-decoration: underline;
        text-decoration-color: var(--fg-faint);
        text-underline-offset: 3px;
        transition: text-decoration-color 0.15s ease;
      }
      .prose :global(a:hover) { text-decoration-color: var(--fg); }

      .prose :global(strong) { font-weight: 600; color: var(--fg); }
      .prose :global(em) { font-style: italic; color: var(--fg-muted); }

      .prose :global(ul), .prose :global(ol) {
        padding-left: 1.5em;
        margin-bottom: 1.4em;
      }
      .prose :global(li) { margin-bottom: 0.35em; }
      .prose :global(li::marker) { color: var(--fg-faint); }

      .prose :global(blockquote) {
        border-left: 2px solid rgba(255,255,255,0.15);
        padding-left: 1.2em;
        margin: 1.4em 0;
        color: var(--fg-muted);
        font-style: italic;
      }

      .prose :global(code) {
        font-family: 'Geist Mono', 'Courier New', monospace;
        font-size: 13.5px;
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 4px;
        padding: 2px 6px;
        color: var(--fg);
      }

      .prose :global(pre) {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 8px;
        padding: 1.25em 1.5em;
        overflow-x: auto;
        margin-bottom: 1.4em;
      }
      .prose :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        font-size: 13.5px;
        line-height: 1.6;
      }

      .prose :global(img) {
        width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 1.4em 0;
      }

      .prose :global(hr) {
        border: none;
        border-top: 1px solid rgba(255,255,255,0.08);
        margin: 2em 0;
      }

      /* ── Back link ── */
      .back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--fg-muted);
        margin-bottom: 40px;
        transition: color 0.15s ease;
      }
      .back:hover { color: var(--fg); }
      .back::before { content: '←'; }

      /* ── Mobile ── */
      @media (max-width: 480px) {
        header { padding-bottom: 40px; }
        nav { gap: 18px; font-size: 14px; }
        .post-title { font-size: 20px; }
      }
    </style>
  </head>
  <body>
    <div class="container">

      <header>
        <a href={homeUrl} class="site-name">Fábio Machado</a>
        <nav>
          <a href={aboutUrl}>{aboutLabel}</a>
          <span class="lang">
            <a href={isEn ? Astro.url.pathname : switchUrl} class={isEn ? 'active' : ''}>en</a>
            <span class="pipe">|</span>
            <a href={isEn ? switchUrl : Astro.url.pathname} class={isEn ? '' : 'active'}>ptbr</a>
          </span>
          <a href="https://x.com/machadofabio" class="x-link" target="_blank" rel="noopener" aria-label="X">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
            </svg>
          </a>
        </nav>
      </header>

      <article>
        <nav class="breadcrumb" aria-label="breadcrumb">
          <a href={homeUrl}>{homeLabel}</a>
          <span class="sep" aria-hidden="true">/</span>
          <a href={homeUrl}>{labsLabel}</a>
          <span class="sep" aria-hidden="true">/</span>
          <span class="current" aria-current="page">{title}</span>
        </nav>

        <h1 class="post-title">{title}</h1>

        <div class="post-meta">
          <span>@machadofabio</span>
          <span class="sep">|</span>
          <span>{dateFormatted}</span>
        </div>

        {heroImage && (
          <figure class="hero">
            <Image
              src={heroImage}
              alt={heroImageAlt}
              widths={[480, 768, 1024, 1280]}
              sizes="(max-width: 480px) 100vw, (max-width: 768px) 90vw, 640px"
              loading="eager"
              fetchpriority="high"
              format="webp"
              quality={82}
            />
          </figure>
        )}

        <div class="prose">
          <slot />
        </div>

        {tags.length > 0 && (
          <ul class="tags" aria-label={isEn ? 'tags' : 'tags'}>
            {tags.map((tag) => (
              <li>
                <a href={tagPathFor(tag, lang)}>#{tagLabel(tag, lang)}</a>
              </li>
            ))}
          </ul>
        )}

        <a href={homeUrl} class="back">{backLabel}</a>
      </article>

    </div>
  </body>
</html>
