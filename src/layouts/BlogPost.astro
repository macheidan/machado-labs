---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';

type Props = CollectionEntry<'labs'>['data'];

const { title, description, pubDate } = Astro.props;

const dateFormatted = new Date(pubDate).toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #1c1c1c;
        --fg: #ededed;
        --fg-muted: #a1a1a1;
        --fg-faint: #6e6e6e;
        --max-width: 640px;
        --accent: #ededed;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html {
        -webkit-text-size-adjust: 100%;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      body {
        background: var(--bg);
        color: var(--fg);
        font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-feature-settings: 'ss01', 'cv11';
        font-size: 16px;
        line-height: 1.5;
        min-height: 100vh;
        letter-spacing: -0.01em;
      }

      ::selection { background: rgba(255,255,255,0.15); }
      a { color: inherit; text-decoration: none; }

      /* ── Container ── */
      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 32px 24px 80px;
      }

      /* ── Header ── */
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding-top: 16px;
        padding-bottom: 56px;
      }

      .site-name {
        font-size: 17px;
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1;
        transition: opacity 0.15s ease;
      }
      .site-name:hover { opacity: 0.7; }

      nav {
        display: flex;
        align-items: center;
        gap: 28px;
        font-size: 15px;
      }
      nav a { line-height: 1; transition: opacity 0.15s ease; }
      nav a:hover { opacity: 0.65; }

      .lang {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 15px;
        line-height: 1;
      }
      .lang a { color: var(--fg-muted); }
      .lang a.active { color: var(--fg); }
      .lang .pipe { color: var(--fg-faint); }

      .x-link { display: inline-flex; align-items: center; }
      .x-link svg { display: block; width: 14px; height: 14px; fill: currentColor; }

      /* ── Post header ── */
      .post-title {
        font-size: 24px;
        font-weight: 700;
        line-height: 2rem;
        color: var(--fg);
        margin-bottom: 4px;
      }

      .post-meta {
        font-family: 'Geist Mono', 'Courier New', monospace;
        font-size: 12px;
        color: #737373;
        display: flex;
        align-items: center;
        gap: 0;
        margin-bottom: 40px;
      }

      .post-meta .sep {
        margin: 0 8px;
        color: var(--fg-faint);
      }

      /* ── Prose ── */
      .prose {
        font-size: 16px;
        line-height: 1.75;
        color: var(--fg);
      }

      .prose :global(p) { margin-bottom: 1.4em; }

      .prose :global(h2) {
        font-size: 20px;
        font-weight: 700;
        color: var(--fg);
        margin-top: 2.25em;
        margin-bottom: 0.5em;
        line-height: 2rem;
      }

      .prose :global(h3) {
        font-size: 16px;
        font-weight: 700;
        color: var(--fg);
        margin-top: 1.75em;
        margin-bottom: 0.4em;
      }

      .prose :global(a) {
        color: var(--fg);
        text-decoration: underline;
        text-decoration-color: var(--fg-faint);
        text-underline-offset: 3px;
        transition: text-decoration-color 0.15s ease;
      }
      .prose :global(a:hover) { text-decoration-color: var(--fg); }

      .prose :global(strong) { font-weight: 600; color: var(--fg); }
      .prose :global(em) { font-style: italic; color: var(--fg-muted); }

      .prose :global(ul), .prose :global(ol) {
        padding-left: 1.5em;
        margin-bottom: 1.4em;
      }
      .prose :global(li) { margin-bottom: 0.35em; }
      .prose :global(li::marker) { color: var(--fg-faint); }

      .prose :global(blockquote) {
        border-left: 2px solid rgba(255,255,255,0.15);
        padding-left: 1.2em;
        margin: 1.4em 0;
        color: var(--fg-muted);
        font-style: italic;
      }

      .prose :global(code) {
        font-family: 'Geist Mono', 'Courier New', monospace;
        font-size: 13.5px;
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 4px;
        padding: 2px 6px;
        color: var(--fg);
      }

      .prose :global(pre) {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 8px;
        padding: 1.25em 1.5em;
        overflow-x: auto;
        margin-bottom: 1.4em;
      }
      .prose :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        font-size: 13.5px;
        line-height: 1.6;
      }

      .prose :global(img) {
        width: 100%;
        border-radius: 8px;
        margin: 1.4em 0;
      }

      .prose :global(hr) {
        border: none;
        border-top: 1px solid rgba(255,255,255,0.08);
        margin: 2em 0;
      }

      /* ── Back link ── */
      .back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--fg-muted);
        margin-bottom: 40px;
        transition: color 0.15s ease;
      }
      .back:hover { color: var(--fg); }
      .back::before { content: '←'; }

      /* ── Mobile ── */
      @media (max-width: 480px) {
        header { padding-bottom: 40px; }
        nav { gap: 18px; font-size: 14px; }
        .post-title { font-size: 20px; }
      }
    </style>
  </head>
  <body>
    <div class="container">

      <header>
        <a href="/" class="site-name">Fábio Machado</a>
        <nav>
          <a href="/about">Sobre</a>
          <span class="lang">
            <a href="?lang=en">en</a>
            <span class="pipe">|</span>
            <a href="?lang=pt" class="active">pt-br</a>
          </span>
          <a href="https://x.com/machadofabio" class="x-link" target="_blank" rel="noopener" aria-label="X">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
            </svg>
          </a>
        </nav>
      </header>

      <article>
        <a href="/" class="back">todos os posts</a>

        <h1 class="post-title">{title}</h1>

        <div class="post-meta">
          <span>@macheidan</span>
          <span class="sep">|</span>
          <span>{dateFormatted}</span>
        </div>

        <div class="prose">
          <slot />
        </div>
      </article>

    </div>
  </body>
</html>
