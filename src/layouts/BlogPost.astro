---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Shell from '../components/Shell.astro';
import { articleGraph, SITE_URL } from '../lib/seo';

type Props = CollectionEntry<'labs'>['data'] & {
  lang?: 'pt' | 'en';
  altUrl?: string;
};

const {
  title,
  heroTitle,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroAlt,
  author,
  tags = [],
  keywords,
  lang = 'pt',
  altUrl,
} = Astro.props;
const isEn = lang === 'en';
const shellLang = isEn ? 'en' : 'pt-BR';

const dateFormatted = new Date(pubDate).toLocaleDateString(
  isEn ? 'en-US' : 'pt-BR',
  { year: 'numeric', month: 'long', day: 'numeric' },
);

const postsUrl = isEn ? '/en/posts' : '/posts';
const backLabel = isEn ? '← Full archive' : '← Arquivo completo';
const backBottomLabel = isEn ? '← Back to archive' : '← Voltar ao arquivo completo';

const slug = Astro.url.pathname.replace(/^\/(en\/)?labs\//, '').replace(/\/$/, '');
const ogImageUrl = heroImage
  ? new URL(heroImage.src, SITE_URL).toString()
  : `${SITE_URL}/og-default.png`;
const heroImageAlt = heroAlt ?? title;

const seoKeywords = keywords && keywords.length > 0 ? keywords : undefined;

const jsonLd = articleGraph({
  lang,
  title,
  description,
  pubDate: new Date(pubDate),
  updatedDate: updatedDate ? new Date(updatedDate) : undefined,
  slug,
  imageUrl: ogImageUrl,
  keywords: seoKeywords,
});
---

<Shell
  title={title}
  description={description}
  image={heroImage}
  lang={shellLang}
  alternateUrl={altUrl}
  ogType="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  author={author}
  keywords={seoKeywords}
  jsonLd={jsonLd}
>
  <div class="post-back">
    <a href={postsUrl}>{backLabel}</a>
  </div>

  <section class="post-hero">
    <div class="post-meta-top">
      <span class="date">{dateFormatted}</span>
    </div>
    {heroTitle
      ? <h1 set:html={heroTitle} />
      : <h1>{title}</h1>}
    <p class="lede">{description}</p>
  </section>

  {heroImage && (
    <div class="post-cover">
      <div class="frame">
        <Image
          src={heroImage}
          alt={heroImageAlt}
          widths={[480, 768, 1024, 1280]}
          sizes="(max-width: 480px) 100vw, (max-width: 1024px) 90vw, 1080px"
          loading="eager"
          fetchpriority="high"
          format="webp"
          quality={82}
        />
      </div>
    </div>
  )}

  <article class="post-body">
    <slot />

    <div class="post-end">
      <a class="btn-ghost" href={postsUrl}>{backBottomLabel}</a>
    </div>
  </article>
</Shell>

<style>
  .post-back {
    max-width: 760px; margin: 0 auto 28px;
    padding: calc(var(--header-offset) + 48px) 28px 0;
  }
  .post-back a {
    font-size: 13px; color: var(--fg-muted);
    display: inline-flex; align-items: center; gap: 6px;
    transition: color 160ms;
  }
  .post-back a:hover { color: var(--fg); }

  .post-hero {
    max-width: 880px; margin: 0 auto;
    padding: 0 28px 32px;
    text-align: left;
  }
  .post-meta-top {
    display: flex; align-items: center; gap: 10px;
    font-size: 12px; color: var(--fg-muted);
    margin-bottom: 18px;
  }
  .post-meta-top .date { font-variant-numeric: tabular-nums; }
  .post-hero h1 {
    font-size: clamp(34px, 5.4vw, 64px);
    font-weight: 700; letter-spacing: -0.035em; line-height: 1.04;
    color: var(--fg);
    margin-bottom: 18px;
    text-wrap: balance;
  }
  .post-hero h1 :global(em) {
    font-style: italic; font-weight: 600;
    background: linear-gradient(120deg, #ffb088 0%, var(--accent) 60%, var(--pink) 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .post-hero h1 :global(.accent) {
    background: linear-gradient(120deg, var(--accent) 0%, var(--pink) 50%, var(--violet) 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .post-hero .lede {
    font-size: clamp(16px, 1.6vw, 19px);
    color: var(--fg-soft);
    line-height: 1.55;
    max-width: 60ch;
  }

  .post-cover {
    max-width: 1080px; margin: 12px auto 48px;
    padding: 0 28px;
  }
  .post-cover .frame {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: linear-gradient(135deg, rgba(255,92,43,0.18), rgba(142,107,255,0.18) 50%, rgba(77,212,255,0.16));
  }
  .post-cover :global(img) { width: 100%; height: auto; display: block; }

  .post-body {
    max-width: 720px; margin: 0 auto;
    padding: 0 28px;
    font-size: 17px; line-height: 1.75;
    color: var(--fg-soft);
  }
  .post-body :global(p) { margin: 0 0 1.4em; }
  .post-body :global(h2) {
    font-size: 28px; font-weight: 600;
    letter-spacing: -0.02em; line-height: 1.2;
    color: var(--fg);
    margin: 2.4em 0 0.7em;
  }
  .post-body :global(h3) {
    font-size: 20px; font-weight: 600;
    color: var(--fg);
    margin: 2em 0 0.6em;
  }
  .post-body :global(strong) { color: var(--fg); font-weight: 600; }
  .post-body :global(em) { font-style: italic; color: var(--fg); }
  .post-body :global(a) {
    color: var(--accent);
    border-bottom: 1px solid rgba(255,92,43,0.4);
    transition: border-color 160ms, opacity 160ms;
  }
  .post-body :global(a:hover) { border-color: var(--accent); opacity: 0.85; }
  .post-body :global(blockquote) {
    margin: 1.8em 0;
    padding: 18px 22px;
    border-left: 3px solid var(--accent);
    background: rgba(255,92,43,0.06);
    border-radius: 0 12px 12px 0;
    color: var(--fg);
    font-style: italic;
    font-size: 18px;
    line-height: 1.5;
  }
  .post-body :global(ul), .post-body :global(ol) {
    margin: 0 0 1.4em; padding-left: 1.4em;
  }
  .post-body :global(li) { margin-bottom: 0.5em; }
  .post-body :global(hr) {
    border: none; border-top: 1px solid var(--line);
    margin: 2.6em 0;
  }
  .post-body :global(code) {
    font-family: 'IBM Plex Mono', ui-monospace, Menlo, monospace;
    font-size: 0.88em;
    padding: 2px 7px;
    background: rgba(255,255,255,0.07);
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--fg);
  }
  .post-body :global(pre) {
    margin: 1.8em -8px;
    padding: 20px 22px;
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow-x: auto;
    font-family: 'IBM Plex Mono', ui-monospace, Menlo, monospace;
    font-size: 13px; line-height: 1.65;
    color: var(--fg-soft);
  }
  .post-body :global(pre code) {
    padding: 0; background: none; border: none; font-size: inherit;
  }
  .post-body :global(img) {
    width: 100%; height: auto;
    border-radius: 16px;
    border: 1px solid var(--line);
    margin: 2em -8px;
    display: block;
  }
  .post-body :global(figure) {
    margin: 2em -8px;
  }
  .post-body :global(figure img) { margin: 0; }
  .post-body :global(figcaption) {
    font-size: 12.5px; color: var(--fg-muted);
    margin-top: 10px; text-align: center;
    font-style: italic;
  }
  .post-body :global(iframe) {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--line);
    border-radius: 16px;
    margin: 2em -8px;
    display: block;
    background: #000;
  }

  .post-end {
    margin: 56px 0 0;
    display: flex; justify-content: center;
  }

  @media (max-width: 800px) {
    .post-back { padding: calc(var(--header-offset) + 24px) 16px 0; }
    .post-hero { padding: 0 16px 24px; }
    .post-cover { padding: 0 16px; }
    .post-body { padding: 0 16px; font-size: 16px; line-height: 1.7; }
    .post-body :global(h2) { font-size: 24px; }
    .post-body :global(h3) { font-size: 18px; }
    .post-body :global(pre), .post-body :global(img), .post-body :global(figure), .post-body :global(iframe) { margin-left: 0; margin-right: 0; }
    .post-body :global(blockquote) { font-size: 16px; padding: 14px 16px; }
  }
</style>
