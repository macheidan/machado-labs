---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Shell from '../components/Shell.astro';
import { articleGraph, SITE_URL } from '../lib/seo';
import { tagLabel, tagPathFor } from '../lib/tags';

type Props = CollectionEntry<'labs'>['data'] & {
  lang?: 'pt' | 'en';
  altUrl?: string;
};

const {
  title,
  heroTitle,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroAlt,
  author,
  tags = [],
  keywords,
  lang = 'pt',
  altUrl,
} = Astro.props;
const isEn = lang === 'en';
const shellLang = isEn ? 'en' : 'pt-BR';

const dateFormatted = new Date(pubDate).toLocaleDateString(
  isEn ? 'en-US' : 'pt-BR',
  { year: 'numeric', month: 'long', day: 'numeric' },
);
const dn = (() => {
  const d = new Date(pubDate);
  return `${String(d.getDate()).padStart(2,'0')}.${String(d.getMonth()+1).padStart(2,'0')}.${d.getFullYear()}`;
})();

const homeUrl = isEn ? '/en' : '/';
const backLabel = isEn ? '← All posts' : '← Todos os posts';

const slug = Astro.url.pathname.replace(/^\/(en\/)?labs\//, '').replace(/\/$/, '');
const ogImageUrl = heroImage
  ? new URL(heroImage.src, SITE_URL).toString()
  : `${SITE_URL}/og-default.png`;
const heroImageAlt = heroAlt ?? title;

const seoKeywords = keywords && keywords.length > 0
  ? keywords
  : (tags.length > 0 ? tags.map((t) => tagLabel(t, lang)) : undefined);

const jsonLd = articleGraph({
  lang,
  title,
  description,
  pubDate: new Date(pubDate),
  updatedDate: updatedDate ? new Date(updatedDate) : undefined,
  slug,
  imageUrl: ogImageUrl,
  keywords: seoKeywords,
});
---

<Shell
  title={title}
  description={description}
  image={heroImage}
  lang={shellLang}
  alternateUrl={altUrl}
  ogType="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  author={author}
  keywords={seoKeywords}
  jsonLd={jsonLd}
>
  <section class="post-hero">
    <div class="copy">
      {heroTitle
        ? <h1 class="post-hero-title" set:html={heroTitle} />
        : <h1 class="post-hero-title">{title}</h1>}
    </div>
  </section>

  <article class="post-container">
    <a href={homeUrl} class="back-link">{backLabel}</a>

    <div class="meta-row">
      <span class="meta-pill">Lab</span>
      <span>@machadofabio</span>
      <span>·</span>
      <span>{dateFormatted}</span>
    </div>

    {heroImage && (
      <figure class="post-hero-img">
        <Image
          src={heroImage}
          alt={heroImageAlt}
          widths={[480, 768, 1024, 1280]}
          sizes="(max-width: 480px) 100vw, (max-width: 768px) 90vw, 880px"
          loading="eager"
          fetchpriority="high"
          format="webp"
          quality={82}
        />
      </figure>
    )}

    <div class="prose"><slot /></div>

    <div class="to-top-row">
      <button class="to-top" type="button" onclick="window.scrollTo({top:0,behavior:'smooth'})">
        ↑ {isEn ? 'Top' : 'Subir'}
      </button>
    </div>

    {tags.length > 0 && (
      <ul class="tags" aria-label="tags">
        {tags.map((tag) => (
          <li><a href={tagPathFor(tag, lang)}>#{tagLabel(tag, lang)}</a></li>
        ))}
      </ul>
    )}

    <footer class="post-footer">
      <a href={homeUrl} class="back">{backLabel}</a>
      <span class="footer-meta">© Fábio Machado · {dn}</span>
    </footer>
  </article>
</Shell>

<style>
  .post-hero {
    position: relative;
    display: grid;
    grid-template-rows: 15fr 55fr 30fr;
    min-height: calc(100vh - 80px);
    max-width: 1280px;
    margin: 0 auto;
  }
  .post-hero .copy {
    grid-row: 2;
    display: flex; align-items: center; justify-content: center;
    padding: 0 24px;
    --scrollPara: 0px;
    transform: translate3d(0, calc(-10% - 45px + var(--scrollPara)), 0);
    will-change: transform;
  }
  .post-hero-title {
    font-family: 'Fraunces', serif;
    font-weight: 300; font-style: italic;
    font-size: clamp(64px, 12vw, 154px);
    line-height: 0.95; letter-spacing: -0.02em;
    color: #2a1a0e;
    text-align: center;
    text-wrap: balance;
  }
  .post-hero-title :global(em) {
    font-style: italic;
    font-weight: 500;
    color: #6b3d20;
    font-size: 1.1em;
  }
  .post-hero-title :global(.accent) {
    font-style: normal;
    font-weight: 600;
    color: #c2683a;
    font-size: 1.05em;
    letter-spacing: -0.025em;
  }

  .post-container {
    max-width: 880px; margin: 0 auto;
    padding: 0 32px 30vw;
    position: relative;
  }

  .back-link {
    display: inline-flex; gap: 6px; align-items: center;
    font-size: 13px; color: var(--muted); padding-top: 32px;
    transition: color 150ms;
  }
  .back-link:hover { color: var(--accent); }

  .meta-row {
    display: flex; gap: 14px; align-items: center; flex-wrap: wrap;
    padding: 32px 0 24px; font-size: 13px; color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .meta-pill {
    background: var(--accent); color: #fff;
    padding: 4px 12px; border-radius: 999px;
    font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
  }

  .post-hero-img { margin: 0 0 32px; }
  .post-hero-img :global(img) {
    width: 100%; height: auto; border-radius: 12px; display: block;
  }

  .prose {
    font-family: 'Noto Serif', Georgia, 'Times New Roman', serif;
    font-weight: 400;
    font-size: 18px; line-height: 32px; color: var(--fg);
    padding-bottom: 24px;
  }
  .prose :global(p) { margin-bottom: 1.4em; }
  .prose :global(h2) {
    font-family: 'Fraunces', serif; font-weight: 400;
    font-size: 32px; line-height: 1.15; letter-spacing: -0.01em;
    margin: 2.2em 0 0.6em; color: var(--fg);
  }
  .prose :global(h3) { font-family: 'Fraunces', serif; font-weight: 500; font-size: 22px; margin: 1.8em 0 0.4em; }
  .prose :global(a) { color: var(--accent); border-bottom: 1px solid currentColor; transition: opacity 150ms; }
  .prose :global(a:hover) { opacity: 0.7; }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(em) { font-style: italic; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent); padding: 12px 0 12px 22px;
    margin: 1.6em 0; color: var(--muted); font-style: italic;
    background: linear-gradient(to right, rgba(194, 104, 58, 0.06), transparent);
    font-family: 'Fraunces', serif; font-size: 19px;
  }
  .prose :global(code) {
    background: #EAE0CC; border: 1px solid var(--line);
    padding: 2px 6px; border-radius: 4px; font-size: 14px;
    font-family: ui-monospace, Menlo, monospace;
  }
  .prose :global(pre) {
    background: var(--fg); color: #F4ECDC;
    padding: 22px; border-radius: 10px; overflow-x: auto;
    margin: 1.6em 0; font-size: 14px; line-height: 1.65;
  }
  .prose :global(pre code) { background: none; border: none; padding: 0; color: inherit; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5em; margin-bottom: 1.4em; }
  .prose :global(li) { margin-bottom: 0.4em; }
  .prose :global(hr) { border: none; border-top: 1px solid var(--line); margin: 2.5em 0; }
  .prose :global(img) { max-width: 100%; height: auto; border-radius: 12px; margin: 1.6em 0; }

  .tags {
    list-style: none; padding: 0; margin: 24px 0 0;
    display: flex; flex-wrap: wrap; gap: 8px;
  }
  .tags li { margin: 0; }
  .tags a {
    font-family: ui-monospace, Menlo, monospace;
    font-size: 12px; color: var(--muted);
    background: rgba(0,0,0,0.04);
    border: 1px solid currentColor;
    border-radius: 999px; padding: 4px 10px; line-height: 1;
    transition: color 150ms, border-color 150ms;
  }
  .tags a:hover { color: var(--accent); }

  .to-top-row {
    display: flex; justify-content: center;
    margin: 24px 0 8px;
  }
  .to-top {
    font-family: 'Inter', sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--muted);
    background: transparent;
    border: 1px solid currentColor;
    border-radius: 999px; padding: 8px 18px;
    cursor: pointer;
    transition: color 150ms, transform 150ms;
  }
  .to-top:hover { color: var(--accent); transform: translateY(-2px); }

  .post-footer {
    margin-top: 16px;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 13px; color: var(--muted);
    flex-wrap: wrap; gap: 16px;
  }
  .post-footer .back {
    color: var(--muted); transition: color 150ms;
  }
  .post-footer .back:hover { color: var(--accent); }
  .footer-meta { font-variant-numeric: tabular-nums; }

  @media (max-width: 800px) {
    .post-hero { min-height: calc(100vh - 130px); }
    .post-hero .copy { padding: 0 16px; transform: translate3d(0, calc(-30px - 5% - 35px + var(--scrollPara)), 0); }
    .post-hero-title { font-size: 12vw; }
    .post-container { padding: 0 24px 30vw; }
    .prose { font-size: 18px; }
    .prose :global(h2) { font-size: 26px; }
  }
</style>
