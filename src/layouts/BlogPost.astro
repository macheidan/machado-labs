---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Shell from '../components/Shell.astro';
import { articleGraph, SITE_URL } from '../lib/seo';

type Props = CollectionEntry<'labs'>['data'] & {
  lang?: 'pt' | 'en';
  altUrl?: string;
};

const {
  title,
  heroTitle,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroAlt,
  author,
  tags = [],
  keywords,
  lang = 'pt',
  altUrl,
} = Astro.props;
const isEn = lang === 'en';
const shellLang = isEn ? 'en' : 'pt-BR';

const dateFormatted = new Date(pubDate).toLocaleDateString(
  isEn ? 'en-US' : 'pt-BR',
  { year: 'numeric', month: 'long' },
);

// Remove <br/> manuais — o título quebra naturalmente na largura da coluna.
const heroTitleClean = heroTitle?.replace(/<br\s*\/?>/gi, ' ').replace(/\s+/g, ' ').trim();

const postsUrl = isEn ? '/en/posts' : '/posts';

const slug = Astro.url.pathname.replace(/^\/(en\/)?labs\//, '').replace(/\/$/, '');
const ogImageUrl = heroImage
  ? new URL(heroImage.src, SITE_URL).toString()
  : `${SITE_URL}/og-default.png`;
const heroImageAlt = heroAlt ?? title;

const seoKeywords = keywords && keywords.length > 0 ? keywords : undefined;

const jsonLd = articleGraph({
  lang,
  title,
  description,
  pubDate: new Date(pubDate),
  updatedDate: updatedDate ? new Date(updatedDate) : undefined,
  slug,
  imageUrl: ogImageUrl,
  keywords: seoKeywords,
});
---

<Shell
  title={title}
  description={description}
  image={heroImage}
  lang={shellLang}
  alternateUrl={altUrl}
  ogType="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  author={author}
  keywords={seoKeywords}
  jsonLd={jsonLd}
>
  <section class="post-hero">
    <div class="post-meta-top">
      <span class="date">{dateFormatted}</span>
    </div>
    {heroTitleClean
      ? <h1 set:html={heroTitleClean} />
      : <h1>{title}</h1>}
    <p class="lede">{description}</p>
  </section>

  {heroImage && (
    <div class="post-cover">
      <div class="frame">
        <Image
          src={heroImage}
          alt={heroImageAlt}
          widths={[480, 768, 1024, 1280]}
          sizes="(max-width: 480px) 100vw, (max-width: 1024px) 90vw, 1080px"
          loading="eager"
          fetchpriority="high"
          format="webp"
          quality={82}
        />
      </div>
    </div>
  )}

  <article class="post-body">
    <slot />
  </article>
</Shell>

<style>
  .post-hero {
    max-width: 760px; margin: 0 auto;
    padding: calc(var(--header-offset) + 32px) 28px 32px;
    text-align: left;
  }
  .post-meta-top {
    display: flex; align-items: center; gap: 10px;
    font-size: 12px; color: var(--fg-muted);
    margin-bottom: 18px;
  }
  .post-meta-top .date { font-variant-numeric: tabular-nums; }
  /* Post header — replica .post-header_title / _description do raycast */
  .post-hero {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 28px;
    margin-bottom: 64px;
  }
  .post-hero h1 {
    font-size: clamp(34px, 5.4vw, 64px);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.04;
    color: var(--Base-White);
    margin-bottom: 18px;
    text-wrap: balance;
  }
  .post-hero h1 :global(em) {
    font-style: italic; font-weight: 600;
    background: linear-gradient(120deg, #ffb088 0%, var(--accent) 60%, var(--pink) 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .post-hero h1 :global(.accent) {
    background: linear-gradient(120deg, var(--accent) 0%, var(--pink) 50%, var(--violet) 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .post-hero .lede {
    margin-bottom: 8px;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: 0.2px;
    color: var(--grey-200);
  }
  .post-meta-top .date {
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 20px;
    color: var(--grey-200);
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }

  .post-cover {
    max-width: 760px; margin: 12px auto 48px;
    padding: 0 28px;
  }
  .post-cover .frame {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: linear-gradient(135deg, rgba(255,92,43,0.18), rgba(142,107,255,0.18) 50%, rgba(77,212,255,0.16));
  }
  .post-cover :global(img) { width: 100%; height: auto; display: block; }

  /* Post body — replica fielmente o .markdown do raycast.com/blog
     (font-color-rgb 255,255,255 / lines-color-rgb 255,255,255) */
  .post-body {
    max-width: 760px; margin: 0 auto;
    padding: 0 28px;
    color: rgba(255, 255, 255, 0.85);
  }
  .post-body > :global(*:first-child) { padding-top: 0; }

  .post-body :global(h1) {
    padding-top: 48px;
    font-size: 48px;
    font-weight: 600;
    line-height: 1.0625;
    letter-spacing: 0.02em;
    color: var(--Base-White);
  }
  .post-body :global(h2) {
    padding-top: 48px;
    margin-bottom: 32px;
    font-size: 24px;
    font-weight: 600;
    color: var(--Base-White);
  }
  .post-body :global(h2 + h3) { padding-top: 0; }
  .post-body :global(.case-summary + h2) { padding-top: 8px; }
  .post-body :global(h3) {
    padding-top: 48px;
    margin-bottom: 16px;
    font-size: 18px;
    font-weight: 600;
    color: var(--Base-White);
  }
  .post-body :global(h4) {
    padding-top: 8px;
    margin-bottom: 16px;
    font-size: 16px;
    font-weight: 600;
    color: var(--Base-White);
  }
  .post-body :global(p) {
    margin-bottom: 32px;
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.02em;
  }
  .post-body :global(p:only-child) { margin-bottom: 0; }
  .post-body :global(strong) {
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
  }
  .post-body :global(em) { font-style: italic; }

  .post-body :global(a) {
    color: #ff6363;
    text-decoration: none;
    text-underline-offset: 0;
    transition: text-underline-offset 0.1s ease-out;
  }
  .post-body :global(a:hover), .post-body :global(a:focus) {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-style: dashed;
    text-decoration-color: rgba(255, 255, 255, 0.4);
    text-underline-offset: 5px;
    outline: none;
  }
  .post-body :global(a:active) { transform: scale(0.98); }

  /* Lists com bullets/numbers custom do raycast (— pra ul, "01." mono pra ol) */
  .post-body :global(ul), .post-body :global(ol) {
    padding: 0 0 0 2rem;
    margin-top: 0;
    margin-bottom: 32px;
    list-style: none;
  }
  .post-body :global(li) {
    position: relative;
    margin: 0 0 0.8em;
    font-size: inherit;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.8);
  }
  .post-body :global(li:last-child) { margin-bottom: 0; }
  .post-body :global(ul li::before) {
    content: '';
    position: absolute;
    top: 0.6em;
    left: -32px;
    width: 16px;
    height: 1px;
    background-color: rgba(255, 255, 255, 0.5);
  }
  .post-body :global(ol) { counter-reset: listCounter; }
  .post-body :global(ol > li) { counter-increment: listCounter; }
  .post-body :global(ol > li::before) {
    --size: 32px;
    position: absolute;
    top: 0;
    left: calc(var(--size) * -1 - 0.8rem);
    width: var(--size);
    height: var(--size);
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 500;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.5);
    text-align: right;
    content: counter(listCounter) ".";
  }

  /* Card do resumo Desafio/Solução/Resultados dos posts de case */
  .post-body :global(.case-summary) {
    margin: 0 0 16px;
    padding: 28px 28px 6px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 16px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.02));
  }
  .post-body :global(.case-summary p) {
    margin-bottom: 26px;
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.78);
  }
  .post-body :global(.case-summary p > strong:first-child) {
    display: block;
    margin-bottom: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    background: linear-gradient(120deg, #ffb088 0%, var(--accent) 60%, var(--pink) 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }

  /* Blockquote com barra vertical à esquerda */
  .post-body :global(blockquote) {
    position: relative;
    padding-left: 16px;
    margin: 0 0 32px;
    font-size: 16px;
    font-style: italic;
    font-weight: 500;
    line-height: 1.6;
    color: rgba(255, 255, 255, 1);
    opacity: 0.8;
  }
  .post-body :global(blockquote::before) {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 6px;
    height: 100%;
    background-color: rgba(255, 255, 255, 0.3);
    border-radius: 3px;
  }
  .post-body :global(blockquote p) {
    position: relative;
    padding-left: 0;
    margin: 0 0 32px;
    font-size: 16px;
    font-style: italic;
    font-weight: 500;
    line-height: 1.6;
    color: rgba(255, 255, 255, 1);
  }
  .post-body :global(blockquote p:last-child) { margin-bottom: 0; }

  /* Code: inline em rosa, blocos com bg sutil */
  .post-body :global(:not(pre) > code) {
    display: inline-block;
    padding: 0 5px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 20px;
    color: #ff6363;
    background: rgba(255, 99, 99, 0.15);
    border-radius: 6px;
  }
  .post-body :global(pre) {
    padding: 24px;
    margin: 1rem 0;
    overflow: auto;
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.8);
    text-align: left;
    text-shadow: none;
    word-break: normal;
    word-spacing: normal;
    direction: ltr;
    tab-size: 4;
    white-space: pre;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 6px;
  }
  .post-body :global(pre code) {
    padding: 0;
    background: none;
    border: none;
    font-size: inherit;
    color: inherit;
    display: block;
  }

  /* Imagens, figuras e tabelas */
  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    margin-bottom: 20px;
    display: block;
  }
  .post-body :global(figure) {
    margin: 0 0 32px;
  }
  .post-body :global(figure img) { margin-bottom: 0; }
  .post-body :global(figcaption) {
    margin-top: 12px;
    font-size: 14px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.02em;
  }
  .post-body :global(table) {
    width: 100%;
    margin-bottom: 32px;
    text-align: left;
    border-collapse: collapse;
  }
  .post-body :global(table th),
  .post-body :global(table td) {
    padding: 12px 16px 12px 0;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 0.024em;
    vertical-align: top;
    border: 0;
  }
  .post-body :global(table th) { font-weight: 650; color: var(--Base-White); }
  .post-body :global(table td) { color: rgba(255, 255, 255, 0.6); }
  .post-body :global(table thead) { border-bottom: 1px solid rgba(255, 255, 255, 0.2); }
  .post-body :global(table tbody tr) { border-bottom: 1px dashed rgba(255, 255, 255, 0.2); }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin: 32px 0;
  }
  .post-body :global(iframe) {
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 0 0 32px;
    display: block;
    background: #000;
    border: 0;
    border-radius: 6px;
  }

  @media (max-width: 800px) {
    .post-hero { padding: calc(var(--header-offset) + 16px) 16px 24px; padding-bottom: 42px; margin-bottom: 42px; }
    .post-hero .lede { font-size: 16px; }
    .post-cover { padding: 0 16px; }
    .post-body { padding: 0 16px; }
    .post-body :global(blockquote) { padding-left: 12px; }
    .post-body :global(.case-summary) { padding: 20px 18px 2px; border-radius: 12px; }
  }
</style>
