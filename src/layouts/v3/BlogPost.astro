---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';

type Props = CollectionEntry<'labs'>['data'];
const { title, description, pubDate } = Astro.props;
const dateFormatted = new Date(pubDate).toLocaleDateString('pt-BR', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.');
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={title} description={description} lang="pt-BR" noindex={true} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Orbitron:wght@700;900&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #020617;
        --bg-2: #0F172A;
        --bg-3: #1E293B;
        --fg: #F8FAFC;
        --fg-muted: #94A3B8;
        --accent: #22C55E;
        --accent-2: #06B6D4;
        --danger: #EF4444;
        --border: #1E293B;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--bg);
        background-image:
          linear-gradient(rgba(34, 197, 94, 0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(34, 197, 94, 0.03) 1px, transparent 1px);
        background-size: 32px 32px;
        color: var(--fg);
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 15px; line-height: 1.7;
        min-height: 100vh;
      }
      ::selection { background: var(--accent); color: var(--bg); }
      a { color: inherit; text-decoration: none; }

      .container { max-width: 880px; margin: 0 auto; padding: 24px 24px 96px; }

      .terminal-bar {
        display: flex; align-items: center; gap: 8px;
        padding: 12px 16px; background: var(--bg-2);
        border: 1px solid var(--border); border-bottom: none;
        font-size: 12px; color: var(--fg-muted);
      }
      .dot { width: 11px; height: 11px; border-radius: 50%; }
      .dot.r { background: var(--danger); }
      .dot.y { background: #EAB308; }
      .dot.g { background: var(--accent); }
      .terminal-bar .path { margin-left: 12px; opacity: 0.6; }

      .terminal-body {
        background: var(--bg);
        border: 1px solid var(--border);
        padding: 32px 28px;
      }

      .top-nav {
        display: flex; align-items: center; justify-content: space-between;
        padding-bottom: 24px; margin-bottom: 32px;
        border-bottom: 1px dashed var(--border);
      }
      .brand { font-family: 'Orbitron', sans-serif; font-weight: 900; font-size: 18px; letter-spacing: 0.04em; color: var(--accent); text-shadow: 0 0 12px rgba(34, 197, 94, 0.4); }
      .nav-right { display: flex; gap: 12px; align-items: center; font-size: 12px; }
      .nav-right > a { color: var(--fg-muted); transition: color 150ms; }
      .nav-right > a:hover { color: var(--accent); }
      .skin-switch { display: flex; gap: 4px; }
      .skin-switch a { padding: 3px 7px; border: 1px solid var(--border); color: var(--fg-muted); font-size: 11px; border-radius: 3px; }
      .skin-switch a.active { background: var(--accent); color: var(--bg); border-color: var(--accent); }
      .skin-switch a:hover { color: var(--fg); border-color: var(--fg-muted); }

      .prompt { color: var(--accent); font-weight: 700; margin-right: 6px; }
      .cursor { display: inline-block; width: 8px; height: 16px; background: var(--accent); animation: blink 1s steps(1) infinite; vertical-align: text-bottom; margin-left: 4px; }
      @keyframes blink { 50% { opacity: 0; } }
      @media (prefers-reduced-motion: reduce) { .cursor { animation: none; } }

      .back {
        display: inline-flex; align-items: center; gap: 8px;
        font-size: 12px; color: var(--fg-muted); margin-bottom: 32px;
        padding: 6px 10px; border: 1px solid var(--border); border-radius: 3px;
        transition: color 150ms, border-color 150ms;
      }
      .back:hover { color: var(--accent); border-color: var(--accent); }

      h1.title {
        font-family: 'Orbitron', sans-serif;
        font-size: clamp(28px, 4.5vw, 40px); font-weight: 700;
        line-height: 1.15; letter-spacing: -0.01em; margin-bottom: 16px;
        text-shadow: 0 0 18px rgba(34, 197, 94, 0.15);
      }
      .meta {
        display: flex; gap: 16px; align-items: center; flex-wrap: wrap;
        padding: 10px 14px; background: var(--bg-2); border-left: 3px solid var(--accent);
        font-size: 12px; color: var(--fg-muted); margin-bottom: 40px;
      }
      .meta .key { color: var(--accent); font-weight: 700; }

      .prose { font-size: 15px; line-height: 1.85; color: var(--fg); }
      .prose :global(p) { margin-bottom: 1.4em; }
      .prose :global(h2) {
        font-family: 'Orbitron', sans-serif;
        font-size: 22px; font-weight: 700;
        margin: 2.4em 0 0.6em; color: var(--accent);
        text-shadow: 0 0 10px rgba(34, 197, 94, 0.25);
      }
      .prose :global(h2)::before { content: '## '; opacity: 0.5; font-family: 'JetBrains Mono', monospace; }
      .prose :global(h3) { font-size: 16px; font-weight: 700; margin: 1.8em 0 0.4em; color: var(--fg); }
      .prose :global(h3)::before { content: '### '; opacity: 0.5; color: var(--accent); }
      .prose :global(a) {
        color: var(--accent-2);
        border-bottom: 1px dashed var(--accent-2);
        transition: color 150ms, border-color 150ms;
      }
      .prose :global(a:hover) { color: var(--accent); border-color: var(--accent); }
      .prose :global(strong) { color: var(--accent); font-weight: 700; }
      .prose :global(em) { color: var(--accent-2); font-style: normal; }
      .prose :global(blockquote) {
        border-left: 3px solid var(--accent);
        background: rgba(34, 197, 94, 0.05);
        padding: 14px 18px; margin: 1.6em 0;
        color: var(--fg-muted); font-style: normal;
      }
      .prose :global(code) {
        background: var(--bg-2);
        border: 1px solid var(--border);
        color: var(--accent); font-size: 13px;
        padding: 2px 6px; border-radius: 3px;
      }
      .prose :global(pre) {
        background: var(--bg-2);
        border: 1px solid var(--border);
        border-left: 3px solid var(--accent);
        padding: 18px; overflow-x: auto;
        margin: 1.6em 0; border-radius: 4px;
        font-size: 13px; line-height: 1.65;
      }
      .prose :global(pre code) { background: none; border: none; padding: 0; color: var(--fg); }
      .prose :global(ul), .prose :global(ol) { padding-left: 1.5em; margin-bottom: 1.4em; }
      .prose :global(li) { margin-bottom: 0.4em; }
      .prose :global(li::marker) { color: var(--accent); }
      .prose :global(hr) { border: none; border-top: 1px dashed var(--border); margin: 2.5em 0; }

      .end {
        margin-top: 64px; padding-top: 24px; border-top: 1px dashed var(--border);
        font-size: 12px; color: var(--fg-muted); display: flex; justify-content: space-between;
      }
      .end .status { color: var(--accent); }

      @media (max-width: 600px) {
        .terminal-body { padding: 20px 16px; }
        h1.title { font-size: 26px; }
        .nav-right { gap: 8px; font-size: 11px; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="terminal-bar">
        <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
        <span class="path">~/machado-labs/posts/{title.toLowerCase().slice(0, 30).replace(/\s+/g, '-')}</span>
      </div>

      <div class="terminal-body">
        <header class="top-nav">
          <a href="/v3" class="brand">[ FM://LABS ]</a>
          <div class="nav-right">
            <a href="/v3/about">~/about</a>
            <span class="skin-switch">
              <a href={Astro.url.pathname.replace('/v3/', '/')}>v1</a>
              <a href={Astro.url.pathname.replace('/v3/', '/v2/')}>v2</a>
              <a href="" class="active">v3</a>
              <a href={Astro.url.pathname.replace('/v3/', '/v4/')}>v4</a>
            </span>
          </div>
        </header>

        <article>
          <a href="/v3" class="back">← cd ../</a>

          <h1 class="title">{title}</h1>
          <div class="meta">
            <span><span class="key">author:</span> @machadofabio</span>
            <span><span class="key">date:</span> {dateFormatted}</span>
            <span><span class="key">status:</span> published</span>
          </div>

          <div class="prose"><slot /></div>
        </article>

        <div class="end">
          <span><span class="prompt">$</span>EOF<span class="cursor"></span></span>
          <span class="status">// SKIN V3 / TERMINAL</span>
        </div>
      </div>
    </div>
  </body>
</html>
