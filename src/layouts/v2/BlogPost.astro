---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';

type Props = CollectionEntry<'labs'>['data'];

const { title, description, pubDate } = Astro.props;
const dateFormatted = new Date(pubDate).toLocaleDateString('pt-BR', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={title} description={description} lang="pt-BR" noindex={true} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #FAFAFA;
        --fg: #09090B;
        --muted: #3F3F46;
        --acid: #DFE104;
        --line: 2px solid #09090B;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: 'Space Mono', ui-monospace, monospace;
        font-size: 16px;
        line-height: 1.55;
        text-transform: none;
      }
      ::selection { background: var(--acid); color: var(--fg); }
      a { color: inherit; text-decoration: none; }

      .marquee {
        border-bottom: var(--line);
        background: var(--fg);
        color: var(--bg);
        overflow: hidden;
        white-space: nowrap;
      }
      .marquee-track {
        display: inline-block;
        padding: 10px 0;
        animation: scroll 22s linear infinite;
        font-weight: 700;
        font-size: 13px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .marquee-track span { padding: 0 28px; }
      @keyframes scroll {
        from { transform: translateX(0); }
        to { transform: translateX(-50%); }
      }
      @media (prefers-reduced-motion: reduce) {
        .marquee-track { animation: none; }
      }

      .container { max-width: 880px; margin: 0 auto; padding: 0 24px 96px; }

      header.top {
        display: flex; align-items: center; justify-content: space-between;
        padding: 20px 0;
        border-bottom: var(--line);
        margin-bottom: 56px;
      }
      .brand { font-weight: 700; font-size: 20px; text-transform: uppercase; letter-spacing: -0.02em; }
      .brand a:hover { background: var(--acid); }
      nav.top-nav { display: flex; gap: 14px; font-size: 12px; text-transform: uppercase; font-weight: 700; }
      nav.top-nav a { padding: 6px 10px; border: var(--line); transition: background 100ms, color 100ms; }
      nav.top-nav a:hover, nav.top-nav a.active { background: var(--fg); color: var(--bg); }
      nav.top-nav a.acid:hover { background: var(--acid); color: var(--fg); }

      .skin-switch { display: flex; gap: 6px; font-size: 11px; }
      .skin-switch a { padding: 4px 8px; border: 1px solid var(--fg); }
      .skin-switch a.active { background: var(--fg); color: var(--bg); }

      .back {
        display: inline-block; font-size: 12px; text-transform: uppercase;
        font-weight: 700; padding: 8px 12px; border: var(--line);
        margin-bottom: 40px; transition: background 100ms;
      }
      .back:hover { background: var(--acid); }

      h1.post-title {
        font-size: clamp(40px, 7vw, 72px);
        font-weight: 700;
        line-height: 0.95;
        letter-spacing: -0.04em;
        text-transform: uppercase;
        margin-bottom: 24px;
      }
      .meta {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 700;
        padding: 14px 0;
        border-top: var(--line);
        border-bottom: var(--line);
        margin-bottom: 48px;
        display: flex; justify-content: space-between;
      }

      .prose { font-size: 17px; line-height: 1.75; max-width: 680px; }
      .prose :global(p) { margin-bottom: 1.4em; }
      .prose :global(h2) {
        font-size: 28px; font-weight: 700; text-transform: uppercase;
        letter-spacing: -0.02em; margin: 2.5em 0 0.6em; padding-bottom: 8px;
        border-bottom: var(--line); line-height: 1.1;
      }
      .prose :global(h3) {
        font-size: 18px; font-weight: 700; text-transform: uppercase;
        margin: 2em 0 0.5em; letter-spacing: 0.02em;
      }
      .prose :global(a) {
        background: var(--fg); color: var(--bg); padding: 0 4px;
        transition: background 100ms;
      }
      .prose :global(a:hover) { background: var(--acid); color: var(--fg); }
      .prose :global(strong) { background: var(--acid); padding: 0 3px; font-weight: 700; }
      .prose :global(blockquote) {
        border-left: 6px solid var(--fg); padding: 12px 0 12px 20px;
        margin: 2em 0; background: var(--acid); font-style: normal;
      }
      .prose :global(code) {
        background: var(--fg); color: var(--bg);
        padding: 2px 6px; font-size: 14px; border-radius: 0;
      }
      .prose :global(pre) {
        background: var(--fg); color: var(--bg);
        border: var(--line); padding: 20px; overflow-x: auto;
        margin: 1.6em 0; font-size: 13px; line-height: 1.6;
      }
      .prose :global(pre code) { background: none; padding: 0; }
      .prose :global(ul), .prose :global(ol) { padding-left: 1.5em; margin-bottom: 1.4em; }
      .prose :global(li) { margin-bottom: 0.4em; }
      .prose :global(hr) { border: none; border-top: var(--line); margin: 2.5em 0; }

      footer.bottom {
        margin-top: 96px; padding-top: 32px; border-top: var(--line);
        font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em;
        font-weight: 700; display: flex; justify-content: space-between;
      }

      @media (max-width: 600px) {
        h1.post-title { font-size: 40px; }
        .prose :global(h2) { font-size: 22px; }
        nav.top-nav { gap: 8px; font-size: 10px; }
        nav.top-nav a { padding: 5px 7px; }
      }
    </style>
  </head>
  <body>
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        <span>MACHADO LABS</span><span>★</span><span>FASE 1 — OBSERVAR</span><span>★</span><span>FASE 2 — RESPONDER</span><span>★</span><span>AGENTES DE IA</span><span>★</span><span>AUTOMAÇÃO</span><span>★</span>
        <span>MACHADO LABS</span><span>★</span><span>FASE 1 — OBSERVAR</span><span>★</span><span>FASE 2 — RESPONDER</span><span>★</span><span>AGENTES DE IA</span><span>★</span><span>AUTOMAÇÃO</span><span>★</span>
      </div>
    </div>

    <div class="container">
      <header class="top">
        <div class="brand"><a href="/v2">FÁBIO//MACHADO</a></div>
        <nav class="top-nav">
          <a href="/v2/about">SOBRE</a>
          <span class="skin-switch">
            <a href={Astro.url.pathname.replace('/v2/', '/')}>v1</a>
            <a href="" class="active">v2</a>
            <a href={Astro.url.pathname.replace('/v2/', '/v3/')}>v3</a>
            <a href={Astro.url.pathname.replace('/v2/', '/v4/')}>v4</a>
            <a href={Astro.url.pathname.replace('/v2/', '/v5/')}>v5</a>
          </span>
        </nav>
      </header>

      <article>
        <a href="/v2" class="back">← TODOS OS POSTS</a>
        <h1 class="post-title">{title}</h1>
        <div class="meta">
          <span>@MACHADOFABIO</span>
          <span>{dateFormatted.toUpperCase()}</span>
        </div>
        <div class="prose"><slot /></div>
      </article>

      <footer class="bottom">
        <span>© FÁBIO MACHADO</span>
        <span>SKIN V2 / KINETIC BRUTALISM</span>
      </footer>
    </div>
  </body>
</html>
