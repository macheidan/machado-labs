---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import mountains from '../../content/imgs/montanhas.png';

type Props = CollectionEntry<'labs'>['data'];
const { title, description, pubDate } = Astro.props;
const dateFormatted = new Date(pubDate).toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' });
const dn = (() => {
  const d = new Date(pubDate);
  return `${String(d.getDate()).padStart(2,'0')}.${String(d.getMonth()+1).padStart(2,'0')}.${d.getFullYear()}`;
})();
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <BaseHead title={title} description={description} lang="pt-BR" noindex={true} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #F4ECDC; --fg: #1A1410; --muted: #5C4F42;
        --faint: #8B7B6A; --line: #D9CCB8; --accent: #C2683A; --warm: #ECB05A;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--bg); color: var(--fg);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        font-size: 17px; line-height: 1.55; min-height: 100vh; -webkit-font-smoothing: antialiased;
      }
      ::selection { background: var(--accent); color: #fff; }
      a { color: inherit; text-decoration: none; }

      .hero {
        position: relative; height: 56vh; min-height: 440px; overflow: hidden;
        background: linear-gradient(
          180deg,
          #6e5e7f 0%, #a88a87 14%, #c9b18d 32%, #d7b88b 46%,
          #e1ba81 58%, #e7b874 68%, #ecb05a 78%, #c28242 88%, #6b4628 100%
        );
      }
      .hero::after { content: ''; position: absolute; inset: 0; z-index: 1;
        background: radial-gradient(ellipse 70% 35% at 50% 78%, rgba(255,210,140,0.55), transparent 70%); }
      .hero-nav {
        position: absolute; top: 0; left: 0; right: 0; z-index: 5;
        display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
        padding: 28px 40px; color: #2c1f15;
      }
      .hero-nav .left { font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.75; }
      .hero-nav .brand { font-family: 'Fraunces', serif; font-weight: 500; font-size: 22px; letter-spacing: 0.18em; text-transform: uppercase; text-align: center; }
      .hero-nav .right { display: flex; gap: 12px; justify-content: flex-end; align-items: center; font-size: 13px; }
      .hero-nav .right > a { opacity: 0.75; transition: opacity 150ms; }
      .hero-nav .right > a:hover, .hero-nav .right > a.active { opacity: 1; }
      .hero-nav .right .sep { opacity: 0.35; user-select: none; }
      .x-icon { display: inline-flex; align-items: center; opacity: 0.75; transition: opacity 150ms; }
      .x-icon:hover { opacity: 1; }
      .x-icon svg { width: 14px; height: 14px; fill: currentColor; display: block; }
      .hero-nav .brand { will-change: transform; }

      .hero-title-wrap { position: absolute; left: 0; right: 0; bottom: 38%; z-index: 2; text-align: center; padding: 0 32px; }
      .hero-title {
        font-family: 'Fraunces', serif; font-weight: 400;
        font-size: clamp(32px, 6vw, 80px); line-height: 1.05;
        letter-spacing: -0.015em; color: #2a1a0e; max-width: 1100px; margin: 0 auto;
        text-wrap: balance;
      }
      .hero-mountains { position: absolute; left: 0; right: 0; bottom: 0; width: 100%; z-index: 3; line-height: 0; pointer-events: none; }
      .hero-mountains img { width: 100%; height: auto; display: block; }

      .container { max-width: 880px; margin: 0 auto; padding: 0 32px; }

      .meta-row {
        display: flex; gap: 20px; align-items: center; flex-wrap: wrap;
        padding: 40px 0 24px; font-size: 13px; color: var(--muted);
        font-variant-numeric: tabular-nums;
      }
      .meta-row .pill {
        background: var(--accent); color: #fff;
        padding: 4px 12px; border-radius: 999px;
        font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
      }
      .back-link {
        display: inline-flex; gap: 6px; align-items: center;
        font-size: 13px; color: var(--muted); padding-top: 32px;
        transition: color 150ms;
      }
      .back-link:hover { color: var(--accent); }

      .prose {
        font-size: 18px; line-height: 1.75; color: var(--fg);
        padding-bottom: 64px;
      }
      .prose :global(p) { margin-bottom: 1.4em; }
      .prose :global(h2) {
        font-family: 'Fraunces', serif; font-weight: 400;
        font-size: 32px; line-height: 1.15; letter-spacing: -0.01em;
        margin: 2.2em 0 0.6em; color: var(--fg);
      }
      .prose :global(h3) { font-family: 'Fraunces', serif; font-weight: 500; font-size: 22px; margin: 1.8em 0 0.4em; }
      .prose :global(a) { color: var(--accent); border-bottom: 1px solid currentColor; transition: opacity 150ms; }
      .prose :global(a:hover) { opacity: 0.7; }
      .prose :global(strong) { font-weight: 600; }
      .prose :global(em) { font-style: italic; }
      .prose :global(blockquote) {
        border-left: 3px solid var(--accent); padding: 12px 0 12px 22px;
        margin: 1.6em 0; color: var(--muted); font-style: italic;
        background: linear-gradient(to right, rgba(194, 104, 58, 0.06), transparent);
        font-family: 'Fraunces', serif; font-size: 19px;
      }
      .prose :global(code) {
        background: #EAE0CC; border: 1px solid var(--line);
        padding: 2px 6px; border-radius: 4px; font-size: 14px;
        font-family: ui-monospace, Menlo, monospace;
      }
      .prose :global(pre) {
        background: var(--fg); color: #F4ECDC;
        padding: 22px; border-radius: 10px; overflow-x: auto;
        margin: 1.6em 0; font-size: 14px; line-height: 1.65;
      }
      .prose :global(pre code) { background: none; border: none; padding: 0; color: inherit; }
      .prose :global(ul), .prose :global(ol) { padding-left: 1.5em; margin-bottom: 1.4em; }
      .prose :global(li) { margin-bottom: 0.4em; }
      .prose :global(hr) { border: none; border-top: 1px solid var(--line); margin: 2.5em 0; }
      .prose :global(img) { max-width: 100%; height: auto; border-radius: 12px; margin: 1.6em 0; }

      footer.site {
        padding: 32px 0; border-top: 1px solid var(--line);
        display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px;
        font-size: 13px; color: var(--muted);
      }
      footer .left { grid-column: 1 / 7; }
      footer .right { grid-column: 7 / 13; text-align: right; }

      @media (max-width: 800px) {
        .hero-nav { grid-template-columns: 1fr; gap: 8px; padding: 20px 24px; text-align: center; }
        .hero-nav .left, .hero-nav .right { justify-content: center; display: flex; }
        .hero-title { font-size: 28px; }
        .prose { font-size: 16px; }
        .prose :global(h2) { font-size: 26px; }
        footer .left, footer .right { grid-column: 1 / 13; text-align: left; }
      }
    </style>
  </head>
  <body>
    <section class="hero">
      <nav class="hero-nav">
        <span class="left">2026</span>
        <a href="/v5" class="brand">Fábio Machado</a>
        <span class="right">
          <a href="/v5/about">sobre</a>
          <span class="sep">|</span>
          <a href={Astro.url.pathname.replace('/v5/', '/en/')}>english</a>
          <span class="sep">|</span>
          <a class="x-icon" href="https://x.com/machadofabio" target="_blank" rel="noopener" aria-label="X (Twitter)">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </span>
      </nav>
      <div class="hero-title-wrap">
        <h1 class="hero-title">{title}</h1>
      </div>
      <div class="hero-mountains">
        <Image src={mountains} alt="" width={2752} height={898} loading="eager" />
      </div>
    </section>

    <article class="container">
      <a href="/v5" class="back-link">← Todos os posts</a>
      <div class="meta-row">
        <span class="pill">Lab</span>
        <span>@machadofabio</span>
        <span>·</span>
        <span>{dateFormatted}</span>
      </div>
      <div class="prose"><slot /></div>

      <footer class="site">
        <span class="left">© Fábio Machado · {dn}</span>
        <span class="right">Skin v5 · Dawn Ridge</span>
      </footer>
    </article>

    <script is:inline>
      (function () {
        const topBrand = document.querySelector('.hero-nav .brand');
        if (!topBrand) return;
        let raf = null;
        function update() {
          topBrand.style.transform = 'translateY(' + (window.scrollY * 2 / 3) + 'px)';
          raf = null;
        }
        window.addEventListener('scroll', () => { if (!raf) raf = requestAnimationFrame(update); }, { passive: true });
        update();
      })();
    </script>
  </body>
</html>
